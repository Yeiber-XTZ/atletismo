---
type CompetenciaItem = {
  title: string;
  status: string;
  date: string;
  location: string;
  type?: string;
  downloads?: Array<{
    label: string;
    href: string;
  }>;
};

type RankingItem = {
  rank: string;
  athlete: string;
  club: string;
  mark: string;
  status: string;
  category: string;
  discipline: string;
  gender: string;
  season: string;
  imageUrl?: string;
};

const { competencias = [] as CompetenciaItem[], rankings = [] as RankingItem[] } = Astro.props;

const recentCompetencias = competencias.slice(0, 4).map((comp) => ({
  ...comp,
  resultsUrl:
    comp.downloads?.find((item) => String(item.label ?? '').trim().toLowerCase() === 'resultados')?.href || '/resultados'
}));
const hasMoreCompetencias = competencias.length > 4;
const topRanking = rankings.slice(0, 6);
---

<section id="resultados-home" class="section-shell bg-white">
  <div class="mb-14 flex flex-col gap-6 md:flex-row md:items-end md:justify-between">
    <div>
      <h2 class="speed-line font-headline text-4xl font-black uppercase tracking-tight text-[#0b361d]">
        Resultados y Ranking
      </h2>
      <p class="mt-2 text-[#3b6447]">Consulta lo más reciente y el ranking destacado.</p>
    </div>
    <div class="flex flex-wrap gap-3">
      <a class="btn-primary btn-slant" href="/resultados">Resultados</a>
      <a class="btn-secondary btn-slant" href="/ranking">Ranking</a>
    </div>
  </div>

  <div class="grid grid-cols-1 gap-6 lg:grid-cols-12">
    <div class="rounded-2xl border border-[var(--border)] bg-[#eef8ec] p-8 shadow-[0_16px_34px_rgba(11,54,29,0.06)] lg:col-span-7">
      <div class="mb-6 flex items-center justify-between">
        <h3 class="font-headline text-2xl font-black uppercase tracking-tight text-[#006b1b]">Resultados recientes</h3>
        <span class="rounded-full bg-[#006b1b] px-4 py-1 text-xs font-black uppercase tracking-widest text-[#d1ffc8]">
          Actualizado
        </span>
      </div>

      {recentCompetencias.length ? (
        <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
          {recentCompetencias.map((comp) => (
            <article class="rounded-xl bg-white p-5 ring-1 ring-[#d4ead8] transition-all hover:-translate-y-0.5 hover:shadow-lg">
              <div class="flex items-start justify-between gap-3">
                <h4 class="font-headline text-lg font-black uppercase tracking-tight text-[#0b361d] leading-tight">
                  {comp.title}
                </h4>
                <span class="rounded-full bg-[#ecf8ef] px-3 py-1 text-[10px] font-black uppercase tracking-widest text-[#006b1b]">
                  {comp.status || 'Pendiente'}
                </span>
              </div>
              <p class="mt-3 text-sm text-[#3b6447]">{comp.location} · {comp.date}</p>
              <p class="mt-1 text-xs font-bold uppercase tracking-widest text-[#4252b4]">{comp.type || 'General'}</p>
              <a
                href={comp.resultsUrl}
                class="mt-4 inline-flex items-center rounded-lg bg-[#006b1b] px-4 py-2 text-xs font-black uppercase tracking-wider text-white hover:bg-[#0b361d]"
              >
                Ver resultados
              </a>
            </article>
          ))}
        </div>
      ) : (
        <div class="rounded-xl bg-white p-10 text-center text-[#3b6447]">
          <span class="material-symbols-outlined text-4xl text-[#006b1b]">fact_check</span>
          <p class="mt-3 font-bold">Aún no hay competencias publicadas.</p>
          <p class="mt-1 text-sm">Cuando se publiquen, aparecerán aquí.</p>
          <a class="mt-6 inline-flex btn-primary btn-slant" href="/resultados">Ver resultados</a>
        </div>
      )}

      {hasMoreCompetencias ? (
        <div class="mt-5 flex justify-end">
          <a class="btn-secondary btn-slant" href="/resultados">Ver más</a>
        </div>
      ) : null}
    </div>

    <div class="rounded-2xl border border-[var(--border)] bg-[#e6f4e3] p-8 shadow-[0_16px_34px_rgba(11,54,29,0.06)] lg:col-span-5">
      <div class="mb-6 flex items-center justify-between">
        <h3 class="font-headline text-2xl font-black uppercase tracking-tight text-[#006b1b]">Ranking destacado</h3>
        <a class="text-sm font-black uppercase tracking-tight text-[#006b1b] hover:underline" href="/ranking">Ver todo</a>
      </div>

      {topRanking.length ? (
        <div class="space-y-3">
          {topRanking.map((r, idx) => (
            <div class:list={['flex items-center justify-between gap-4 rounded-xl bg-white p-4', idx === 0 ? 'ring-2 ring-[#eab308]' : '']}>
              <div class="flex items-center gap-4">
                <div class:list={['flex h-11 w-11 items-center justify-center rounded-xl font-headline text-lg font-black uppercase', idx === 0 ? 'bg-[#eab308] text-[#5b4b00]' : 'bg-[#ddffe2] text-[#006b1b]']}>
                  {r.rank || String(idx + 1).padStart(2, '0')}
                </div>
                <div>
                  <p class="font-headline text-base font-black uppercase tracking-tight text-[#0b361d]">{r.athlete}</p>
                  <p class="text-sm text-[#3b6447]">{r.discipline} · {r.club}</p>
                </div>
              </div>
              <div class="text-right">
                <div class="font-headline text-lg font-black uppercase tracking-tight text-[#006b1b]">{r.mark}</div>
                <div class="text-[10px] font-black uppercase tracking-widest text-[#4252b4]">{r.season}</div>
              </div>
            </div>
          ))}
        </div>
      ) : (
        <div class="rounded-xl bg-white p-10 text-center text-[#3b6447]">
          <span class="material-symbols-outlined text-4xl text-[#006b1b]">leaderboard</span>
          <p class="mt-3 font-bold">Aún no hay ranking publicado.</p>
          <p class="mt-1 text-sm">Pronto estará disponible en esta sección.</p>
          <a class="mt-6 inline-flex btn-primary btn-slant" href="/ranking">Ver ranking</a>
        </div>
      )}
    </div>
  </div>
</section>
