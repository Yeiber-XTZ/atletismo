---
import { hasRole, type AuthUser } from '../lib/rbac';

const {
  badge = 'EL CORAZON DEL PACIFICO',
  headlineHtml = 'La Fuerza del <br/> <span class="text-[#eab308]">Chocó</span> en Cada <br/> Zancada',
  subtitle = 'Forjando los campeones que llevarán la bandera de Colombia a lo más alto. Velocidad pura, talento natural, excelencia tropical.',
  imageUrl = 'https://images.unsplash.com/photo-1530549387074-d56a99e148c9?w=4000&auto=format&fit=crop',
  nextEventName = 'Grand Prix Quibdó',
  nextEventDateText = 'Agosto 24, 2024'
} = Astro.props;
const user = Astro.locals.user as AuthUser | null;
const canSeeConvocatoria = hasRole(user, ['SUPERADMIN', 'ADMIN', 'LIGA', 'CLUB']);
---

<section id="inicio" class="hero-home">
  <div
    class="hero-home-bg"
    style={`background-image: url(${imageUrl});`}
  >
    <img src={imageUrl} alt="" loading="eager" fetchpriority="high" decoding="async" class="sr-only" />
  </div>
  <div class="hero-home-overlay"></div>

  <div class="hero-home-content">
    <div class="hero-home-copy">
      <span class="hero-home-badge">{badge}</span>
      <h1 class="hero-home-title" set:html={headlineHtml} />
      <p class="hero-home-subtitle">{subtitle}</p>

      <div class="hero-home-actions">
        <a class="hero-btn hero-btn-primary" href="/resultados">
          Ver resultados <span class="material-symbols-outlined">trending_up</span>
        </a>
        <a class="hero-btn hero-btn-secondary" href="/registro">Registrarme</a>
        {canSeeConvocatoria ? (
          <a class="hero-btn hero-btn-dark" href="/convocatorias">
            Convocatorias <span class="material-symbols-outlined">campaign</span>
          </a>
        ) : null}
      </div>
    </div>

    <div class="hero-home-next-event">
      <p class="hero-home-next-label">Próximo Evento</p>
      <h3 class="hero-home-next-title">{nextEventName}</h3>
      <p class="hero-home-next-date">{nextEventDateText}</p>
    </div>
  </div>
</section>

<style>
  .hero-home {
    position: relative;
    overflow: hidden;
    isolation: isolate;
    height: 760px;
    min-height: 760px;
    max-height: 760px;
    padding-top: var(--navbar-safe-space, 108px);
    background: #001205;
  }

  .hero-home-bg {
    position: absolute;
    inset: 0;
    z-index: -2;
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    transform: scale(1.02);
  }

  .hero-home-overlay {
    position: absolute;
    inset: 0;
    z-index: -1;
    background:
      linear-gradient(122deg, rgba(0, 18, 5, 0.34) 0%, rgba(0, 18, 5, 0.1) 46%, rgba(234, 179, 8, 0.1) 100%),
      linear-gradient(180deg, rgba(0, 0, 0, 0.02) 0%, rgba(0, 0, 0, 0.22) 100%);
  }

  .hero-home-content {
    position: relative;
    height: 100%;
    max-width: 1320px;
    margin: 0 auto;
    padding: 12px 24px 42px;
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(280px, 470px);
    gap: 28px;
    align-items: end;
  }

  .hero-home-copy {
    align-self: center;
    max-width: 820px;
  }

  .hero-home-badge {
    display: inline-block;
    margin-bottom: 18px;
    transform: rotate(-2deg);
    background: #eab308;
    color: #5b4b00;
    padding: 6px 18px;
    font-family: 'Sora', sans-serif;
    font-size: 13px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .hero-home-title {
    font-family: 'Sora', sans-serif;
    font-size: clamp(2.5rem, 6vw, 5rem);
    font-weight: 900;
    line-height: 0.95;
    letter-spacing: -0.03em;
    text-transform: uppercase;
    color: #d1ffc8;
    text-wrap: balance;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 4;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .hero-home-subtitle {
    margin-top: 16px;
    margin-bottom: 0;
    max-width: 650px;
    color: rgba(221, 255, 226, 0.95);
    font-size: clamp(1rem, 1.3vw, 1.3rem);
    line-height: 1.45;
    font-weight: 500;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .hero-home-actions {
    margin-top: 24px;
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }

  .hero-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    border-radius: 10px;
    padding: 12px 24px;
    font-family: 'Sora', sans-serif;
    font-weight: 800;
    text-transform: uppercase;
    text-decoration: none;
    letter-spacing: 0.01em;
    transition: transform 120ms ease, background-color 120ms ease;
  }

  .hero-btn:hover {
    transform: translateY(-1px);
  }

  .hero-btn-primary {
    background: #5aac32;
    color: #fff;
    clip-path: polygon(0 0, 100% 0, 95% 100%, 0 100%);
  }

  .hero-btn-primary:hover {
    background: #4a9528;
  }

  .hero-btn-secondary {
    background: #eab308;
    color: #5b4b00;
    clip-path: polygon(5% 0, 100% 0, 100% 100%, 0 100%);
  }

  .hero-btn-secondary:hover {
    background: #ca8a04;
  }

  .hero-btn-dark {
    background: rgba(0, 18, 5, 0.45);
    color: #ddffe2;
    border: 1px solid rgba(221, 255, 226, 0.4);
    clip-path: polygon(0 0, 100% 0, 95% 100%, 5% 100%);
  }

  .hero-btn-dark:hover {
    background: rgba(0, 18, 5, 0.6);
  }

  .hero-home-next-event {
    align-self: end;
    justify-self: end;
    width: min(100%, 470px);
    border-left: 4px solid #eab308;
    background: rgba(172, 236, 187, 0.14);
    backdrop-filter: blur(7px);
    padding: 20px;
    margin-bottom: 8px;
  }

  .hero-home-next-label {
    margin: 0;
    font-family: 'Sora', sans-serif;
    font-size: 12px;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #eab308;
  }

  .hero-home-next-title {
    margin: 6px 0 4px;
    font-family: 'Sora', sans-serif;
    font-size: clamp(1.2rem, 2vw, 2rem);
    font-weight: 900;
    line-height: 1.05;
    text-transform: uppercase;
    color: #d1ffc8;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .hero-home-next-date {
    margin: 0;
    font-size: 1rem;
    color: #ddffe2;
  }

  @media (max-width: 1279px) {
    .hero-home {
      height: 690px;
      min-height: 690px;
      max-height: 690px;
    }
  }

  @media (max-width: 1023px) {
    .hero-home {
      height: 620px;
      min-height: 620px;
      max-height: 620px;
      padding-top: var(--navbar-safe-space, 100px);
    }

    .hero-home-content {
      grid-template-columns: 1fr;
      align-items: end;
      padding: 8px 18px 24px;
      gap: 16px;
    }

    .hero-home-next-event {
      display: none;
    }

    .hero-home-actions {
      margin-top: 18px;
      gap: 10px;
    }
  }

  @media (max-width: 767px) {
    .hero-home {
      height: 560px;
      min-height: 560px;
      max-height: 560px;
    }

    .hero-home-title {
      font-size: clamp(2rem, 10vw, 2.8rem);
      -webkit-line-clamp: 3;
    }

    .hero-home-subtitle {
      font-size: 0.96rem;
      -webkit-line-clamp: 2;
      margin-top: 12px;
    }

    .hero-home-badge {
      margin-bottom: 12px;
      font-size: 12px;
      padding: 6px 14px;
    }

    .hero-btn {
      width: 100%;
      justify-content: center;
      padding: 11px 16px;
      font-size: 0.85rem;
    }
  }
</style>
