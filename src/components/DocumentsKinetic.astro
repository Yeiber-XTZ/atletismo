---
const { items = [] as Array<{ title: string; description: string; href: string }> } = Astro.props;

const defaultItems = [
  {
    title: 'Reglamento General',
    description: 'Normativa oficial de la liga (PDF).',
    href: '#'
  },
  {
    title: 'Calendario Oficial 2026',
    description: 'Fechas, sedes y categorías (PDF).',
    href: '#'
  },
  {
    title: 'Formato de Inscripción',
    description: 'Formulario para clubes y atletas (PDF).',
    href: '#'
  }
];

const docs = items.length ? items : defaultItems;
---
<section id="documentos" class="section-shell bg-[#eff8ee]">
  <div class="mb-14 flex flex-col gap-6 md:flex-row md:items-end md:justify-between">
    <div>
      <h2 class="speed-line font-headline text-4xl font-black uppercase tracking-tight text-[#0b361d]">Documentos Oficiales</h2>
      <p class="mt-2 text-[#3b6447]">Descargas y comunicados vigentes.</p>
    </div>
    <div class="rounded-xl bg-[#006b1b] px-5 py-3 text-sm font-bold uppercase tracking-tight text-[#d1ffc8]">
      Actualizado
    </div>
  </div>

  <div class="grid grid-cols-1 gap-6 md:grid-cols-3">
    {docs.map((doc) => (
      <article class="overflow-hidden rounded-xl border border-[#d7e7d4] bg-[#f5fbf4] p-8 transition-all hover:bg-[#ecf7e9]">
        <div class="flex items-start justify-between gap-4">
          <h3 class="font-headline text-xl font-black uppercase tracking-tight text-[#0b361d] break-words [overflow-wrap:anywhere]">{doc.title}</h3>
          <span class="material-symbols-outlined text-[#006b1b]">description</span>
        </div>
        <p class="mt-3 text-[#3b6447] break-words [overflow-wrap:anywhere]">{doc.description}</p>
        <a
          class="mt-6 inline-flex max-w-full items-center gap-2 rounded-[10px] bg-[#006b1b] px-5 py-2 font-headline text-sm font-bold uppercase tracking-tight text-[#d1ffc8] transition-colors hover:bg-[#09561a]"
          href={doc.href}
        >
          Descargar <span class="material-symbols-outlined text-[20px]">download</span>
        </a>
      </article>
    ))}
  </div>
</section>
