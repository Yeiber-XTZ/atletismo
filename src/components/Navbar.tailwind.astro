---
const { siteName = 'Liga Chocó', logoUrl = '/logo.png' } = Astro.props;

const currentPath = Astro.url.pathname;
const isActive = (href: string) => currentPath === href || (href !== '/' && currentPath.startsWith(href));

const direct = [
  { label: 'La Liga', href: '/la-liga' },
  { label: 'Clubes', href: '/clubes' },
  { label: 'Contacto', href: '/contacto' }
];

const groups = [
  {
    label: 'Deportivo',
    items: [
      { label: 'Convocatorias', href: '/convocatorias' },
      { label: 'Competencias', href: '/competencias' },
      { label: 'Calendario', href: '/calendario' },
      { label: 'Resultados', href: '/resultados' },
      { label: 'Ranking', href: '/ranking' }
    ]
  },
  {
    label: 'Comunidad',
    items: [
      { label: 'Noticias', href: '/noticias' },
      { label: 'Blog', href: '/blog' },
      { label: 'Documentos', href: '/documentos' }
    ]
  }
] as const;
---
<nav class="fixed inset-x-0 top-0 z-50 bg-white/95 backdrop-blur supports-[backdrop-filter]:bg-white/80 border-b border-slate-200">
  <div class="mx-auto flex h-[72px] max-w-7xl items-center gap-4 px-6">
    <a href="/" class="flex items-center gap-3" aria-label={siteName}>
      <img src={logoUrl} alt={siteName} class="h-12 w-auto object-contain" />
    </a>

    <!-- Desktop -->
    <div class="hidden flex-1 items-center justify-center gap-2 lg:flex">
      {direct.slice(0, 1).map((link) => (
        <a
          href={link.href}
          class:list={[
            'rounded-xl px-3 py-2 font-headline text-[12.5px] font-extrabold uppercase tracking-[0.06em] transition-colors',
            isActive(link.href) ? 'bg-slate-100 text-slate-900' : 'text-slate-500 hover:bg-slate-50 hover:text-slate-900'
          ]}
        >
          {link.label}
        </a>
      ))}

      {groups.map((group) => {
        const groupActive = group.items.some((item) => isActive(item.href));
        return (
          <details class="relative">
            <summary
              class:list={[
                'list-none cursor-pointer select-none rounded-xl px-3 py-2 font-headline text-[12.5px] font-extrabold uppercase tracking-[0.06em] transition-colors inline-flex items-center gap-1',
                groupActive ? 'bg-slate-100 text-slate-900' : 'text-slate-500 hover:bg-slate-50 hover:text-slate-900'
              ]}
              aria-label={group.label}
            >
              {group.label}
              <span class="material-symbols-outlined text-[18px] opacity-70" aria-hidden="true">expand_more</span>
            </summary>
            <div class="absolute left-1/2 top-[calc(100%+10px)] w-60 -translate-x-1/2 rounded-2xl border border-slate-200 bg-white p-2 shadow-xl">
              {group.items.map((item) => (
                <a
                  href={item.href}
                  class:list={[
                    'block rounded-xl px-3 py-2 text-sm font-bold transition-colors',
                    isActive(item.href) ? 'bg-slate-100 text-slate-900' : 'text-slate-600 hover:bg-slate-50 hover:text-slate-900'
                  ]}
                >
                  {item.label}
                </a>
              ))}
            </div>
          </details>
        );
      })}

      {direct.slice(1).map((link) => (
        <a
          href={link.href}
          class:list={[
            'rounded-xl px-3 py-2 font-headline text-[12.5px] font-extrabold uppercase tracking-[0.06em] transition-colors',
            isActive(link.href) ? 'bg-slate-100 text-slate-900' : 'text-slate-500 hover:bg-slate-50 hover:text-slate-900'
          ]}
        >
          {link.label}
        </a>
      ))}
    </div>

    <div class="ml-auto hidden items-center gap-3 sm:flex">
      <a
        href="/admin/login"
        class="inline-flex items-center justify-center rounded-2xl bg-white px-4 py-2 font-headline text-[12.5px] font-black uppercase tracking-[0.06em] text-[#0b361d] shadow-sm ring-1 ring-[rgba(90,172,50,0.45)] transition hover:bg-[#f0fdf4] hover:shadow-md"
      >
        Iniciar sesión
      </a>
    </div>

    <!-- Mobile -->
    <details class="relative ml-auto sm:hidden">
      <summary
        class="list-none cursor-pointer select-none rounded-xl bg-slate-50 px-3 py-2 text-slate-700 ring-1 ring-slate-200"
        aria-label="Abrir menú"
      >
        <span class="material-symbols-outlined">menu</span>
      </summary>
      <div class="absolute right-0 top-[calc(100%+10px)] w-[min(90vw,340px)] rounded-2xl border border-slate-200 bg-white p-3 shadow-xl">
        <div class="grid gap-2">
          {direct.map((link) => (
            <a
              href={link.href}
              class:list={[
                'rounded-xl px-3 py-2 font-headline text-[12.5px] font-extrabold uppercase tracking-[0.06em] transition-colors',
                isActive(link.href) ? 'bg-slate-100 text-slate-900' : 'text-slate-600 hover:bg-slate-50 hover:text-slate-900'
              ]}
            >
              {link.label}
            </a>
          ))}

          {groups.map((group) => (
            <div class="rounded-2xl border border-slate-100 bg-slate-50 p-2">
              <div class="px-2 pb-1 font-headline text-[11px] font-black uppercase tracking-[0.08em] text-slate-400">
                {group.label}
              </div>
              <div class="grid gap-1">
                {group.items.map((item) => (
                  <a
                    href={item.href}
                    class:list={[
                      'rounded-xl px-3 py-2 text-sm font-bold transition-colors',
                      isActive(item.href) ? 'bg-white text-slate-900' : 'text-slate-600 hover:bg-white hover:text-slate-900'
                    ]}
                  >
                    {item.label}
                  </a>
                ))}
              </div>
            </div>
          ))}

          <a
            href="/admin/login"
            class="mt-1 inline-flex items-center justify-center rounded-2xl bg-white px-4 py-2 font-headline text-[12.5px] font-black uppercase tracking-[0.06em] text-[#0b361d] shadow-sm ring-1 ring-[rgba(90,172,50,0.45)] transition hover:bg-[#f0fdf4] hover:shadow-md"
          >
            Iniciar sesión
          </a>
        </div>
      </div>
    </details>
  </div>
</nav>
