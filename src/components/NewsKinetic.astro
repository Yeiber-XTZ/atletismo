---
type NewsItem = {
  title: string;
  excerpt: string;
  category: string;
  dateText: string;
  href: string;
  imageUrl?: string;
};

const { items = [] as NewsItem[] } = Astro.props;
const featured = items[0];
const secondary = items[1];
const download = items[2];

const featuredImageUrl =
  featured?.imageUrl ||
  'https://images.unsplash.com/photo-1552674605-db6ffd4facb5?q=80&w=2070&auto=format&fit=crop';
---
<section id="noticias" class="section-shell bg-[#eff8ee]">
  <div class="mb-12 flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
    <div>
      <h2 class="speed-line font-headline text-4xl font-black uppercase tracking-tight text-[#0b361d]">Noticias Recientes</h2>
      <p class="mt-2 text-[#3b6447]">Los hitos que marcan nuestra historia.</p>
    </div>
    <a class="font-headline flex items-center gap-2 font-bold uppercase text-[#006b1b] transition-all hover:gap-3" href="/noticias">
      Ver Todas <span class="material-symbols-outlined">arrow_forward</span>
    </a>
  </div>
  <div class="grid grid-cols-1 gap-6 md:grid-cols-12">
    <a href={featured?.href || '/noticias'} class="group relative h-[460px] cursor-pointer overflow-hidden rounded-xl bg-[#acecbb] md:col-span-7">
      <img
        class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-110"
        src={featuredImageUrl}
        alt={featured?.title || 'Noticia destacada'}
        referrerpolicy="no-referrer"
        loading="lazy"
        decoding="async"
      />
      <div class="absolute inset-0 bg-gradient-to-t from-[#001205] via-transparent to-transparent"></div>
      <div class="absolute bottom-0 p-8 md:p-10">
        <span class="mb-4 inline-block bg-[#4252b4] px-3 py-1 text-xs font-headline font-bold uppercase text-[#f3f1ff]">{featured?.category || 'Destacado'}</span>
        <h3 class="font-headline text-3xl font-black uppercase tracking-tight text-white transition-colors group-hover:text-[#fdd835] md:text-4xl">
          {featured?.title || 'Noticia destacada'}
        </h3>
        <p class="mt-4 line-clamp-2 max-w-lg text-[#acecbb]">
          {featured?.excerpt || 'Consulta las novedades más recientes de la Liga.'}
        </p>
      </div>
    </a>
    <div class="grid grid-rows-2 gap-6 md:col-span-5">
      <a href={secondary?.href || '/noticias'} class="group rounded-xl bg-[#ddf4dc] p-8 transition-all hover:bg-[#e8f8e5]">
        <div class="mb-4 flex items-start justify-between">
          <span class="text-xs font-bold uppercase text-[#4252b4]">{secondary?.category || 'Anuncio'}</span>
          <span class="text-sm text-[#3b6447]">{secondary?.dateText || ''}</span>
        </div>
        <h4 class="font-headline text-2xl font-black uppercase tracking-tight transition-colors group-hover:text-[#006b1b]">
          {secondary?.title || 'Actualización institucional'}
        </h4>
        <p class="mt-3 text-[#3b6447]">{secondary?.excerpt || 'Novedades y comunicados oficiales.'}</p>
        <div class="mt-6 flex gap-4">
          <span class="material-symbols-outlined text-[#006b1b]">location_on</span>
          <span class="font-bold">Liga de Atletismo del Chocó</span>
        </div>
      </a>
      <div class="group relative overflow-hidden rounded-xl bg-[#0a5f1a] p-8 text-[#d1ffc8]">
        <div class="absolute -bottom-10 -right-10 opacity-10">
          <span class="material-symbols-outlined text-[200px]">sports_score</span>
        </div>
        <h4 class="font-headline text-2xl font-black uppercase tracking-tight">{download?.title || 'Documento destacado'}</h4>
        <p class="mt-3 opacity-90">{download?.excerpt || 'Accede a documentos oficiales y descargas vigentes.'}</p>
        <a
          class="mt-8 inline-block rounded-[10px] bg-[#d1ffc8] px-6 py-2 font-headline text-sm font-bold uppercase text-[#006b1b] transition-colors hover:bg-[#e4ffd6]"
          href={download?.href || '/documentos'}
        >
          Ver recurso
        </a>
      </div>
    </div>
  </div>
</section>
