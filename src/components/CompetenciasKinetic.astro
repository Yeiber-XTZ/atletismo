---
type EventItem = {
  name: string;
  date: string;
  location: string;
  status: string;
  resultsUrl?: string;
  imageUrl?: string;
};

const { events = [] as EventItem[] } = Astro.props;

const fmtDate = (iso: string) => {
  const parsed = new Date(iso);
  if (Number.isNaN(parsed.getTime())) return iso;
  return parsed.toLocaleDateString('es-CO', { year: 'numeric', month: 'long', day: 'numeric' });
};
---
<section id="competencias" class="section-shell bg-[#eff8ee]">
  <div class="mb-14 flex flex-col gap-6 md:flex-row md:items-end md:justify-between">
    <div>
      <h2 class="speed-line font-headline text-4xl font-black uppercase tracking-tight text-[#006b1b]">Competencias</h2>
      <p class="mt-2 text-[#3b6447]">Eventos programados y estado.</p>
    </div>
    <a class="font-headline font-bold uppercase tracking-tight text-[#006b1b] transition-all hover:translate-x-1" href="/competencias">
      Ver todas <span class="material-symbols-outlined align-middle">arrow_forward</span>
    </a>
  </div>

  <div class="grid grid-cols-1 gap-6 md:grid-cols-3">
    {events.map((event) => (
      <article class="overflow-hidden rounded-xl border border-[#d7e7d4] bg-[#f7fcf6] shadow-[0_14px_30px_rgba(11,54,29,0.06)]">
        <div class="h-36 w-full bg-[#cafdd4]">
          {event.imageUrl ? (
            <img class="h-full w-full object-cover" src={event.imageUrl} alt={event.name} referrerpolicy="no-referrer" loading="lazy" />
          ) : (
            <div class="flex h-full w-full items-center justify-center text-[#006b1b]/60">
              <span class="material-symbols-outlined text-4xl">image</span>
            </div>
          )}
        </div>
        <div class="p-8">
        <div class="flex items-start justify-between gap-4">
          <div>
            <p class="text-xs font-bold uppercase tracking-widest text-[#4252b4]">{event.status}</p>
            <h3 class="mt-2 font-headline text-xl font-black uppercase tracking-tight text-[#0b361d]">{event.name}</h3>
          </div>
          <span class="material-symbols-outlined text-[#006b1b]">sports</span>
        </div>
        <div class="mt-5 space-y-2 text-sm text-[#3b6447]">
          <div class="flex items-center gap-2">
            <span class="material-symbols-outlined text-[20px] text-[#006b1b]">calendar_month</span>
            <span class="font-bold">{fmtDate(event.date)}</span>
          </div>
          <div class="flex items-center gap-2">
            <span class="material-symbols-outlined text-[20px] text-[#006b1b]">location_on</span>
            <span>{event.location}</span>
          </div>
        </div>
        {event.resultsUrl ? (
          <a class="mt-6 inline-flex items-center gap-2 font-headline text-sm font-bold uppercase tracking-tight text-[#006b1b]" href={event.resultsUrl}>
            Ver resultados <span class="material-symbols-outlined text-[20px]">trending_up</span>
          </a>
        ) : (
          <div class="mt-6 text-xs font-bold uppercase tracking-widest text-[#006b1b]/70">Resultados: pendiente</div>
        )}
        </div>
      </article>
    ))}
  </div>
</section>
