---
---
<section class="relative h-[921px] overflow-hidden bg-[#001205] kinetic-slant">
    <div class="absolute inset-0 opacity-60">
        <img 
            class="w-full h-full object-cover" 
            src="https://images.unsplash.com/photo-1530549387074-d56a99e148c9?q=80&w=2070&auto=format&fit=crop" 
            alt="Sprinter at maximum speed"
            referrerpolicy="no-referrer"
        />
    </div>
    <div class="absolute inset-0 bg-gradient-to-tr from-[#006b1b]/80 via-transparent to-[#fdd835]/20"></div>
    <div class="relative z-10 h-full flex flex-col justify-center px-8 md:px-24">
        <div class="max-w-4xl">
            <span class="inline-block bg-[#fdd835] text-[#5b4b00] px-4 py-1 font-headline font-black uppercase text-sm mb-6 -rotate-2">
                EL CORAZÓN DEL PACÍFICO
            </span>
            <h1 class="text-6xl md:text-8xl font-headline font-black text-[#d1ffc8] leading-none uppercase tracking-tighter italic">
                La Fuerza del <br/> <span class="text-[#fdd835]">Chocó</span> en Cada <br/> Zancada
            </h1>
            <p class="mt-8 text-xl text-[#ddffe2]/90 max-w-xl font-medium leading-relaxed">
                Forjando los campeones que llevarán la bandera de Colombia a lo más alto. Velocidad pura, talento natural, excelencia tropical.
            </p>
            <div class="mt-12 flex flex-wrap gap-6">
                <button class="bg-[#006b1b] text-[#d1ffc8] px-10 py-4 font-headline font-bold uppercase tracking-tight flex items-center gap-3 transition-transform hover:scale-105 active:scale-90" style="clip-path: polygon(0 0, 100% 0, 95% 100%, 0 100%);">
                    Discover Records <span class="material-symbols-outlined">trending_up</span>
                </button>
                <button class="bg-[#fdd835] text-[#5b4b00] px-10 py-4 font-headline font-bold uppercase tracking-tight transition-transform hover:scale-105" style="clip-path: polygon(5% 0, 100% 0, 100% 100%, 0 100%);">
                    Join the League
                </button>
            </div>
        </div>
    </div>
    <div class="absolute bottom-20 right-12 hidden lg:block">
        <div class="bg-[#acecbb]/10 backdrop-blur-md p-6 border-l-4 border-[#fdd835]">
            <p class="text-[#fdd835] font-headline font-bold uppercase text-xs">Próximo Evento</p>
            <h3 class="text-[#d1ffc8] text-2xl font-headline font-black uppercase">Grand Prix Quibdó</h3>
            <p class="text-[#ddffe2] text-sm">Agosto 24, 2024</p>
        </div>
    </div>
</section>
