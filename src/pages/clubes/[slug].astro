---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar.astro';
import FooterKinetic from '../../components/FooterKinetic.astro';
import { getHomeData } from '../../lib/content';
import { slugify } from '../../lib/slug';

const data = await getHomeData();
const { settings, clubs } = data;

const slug = Astro.params.slug ?? '';
const club = (clubs ?? []).find((c) => slugify(c.name) === slug);
if (!club) {
  Astro.response.status = 404;
}
---
<BaseLayout
  title={`${club ? club.name : 'Club no encontrado'} | Liga de Atletismo del Chocó`}
  description="Ficha pública del club afiliado."
>
  <Navbar siteName={settings.siteName} logoUrl={settings.logoUrl || '/logo.png'} />

  <main class="pt-[72px]">
    <section class="page-hero">
      <div class="container mx-auto px-6">
        <nav class="page-breadcrumb">
          <a href="/" class="page-breadcrumb-link">
            <span class="material-symbols-outlined text-sm">home</span>
            Inicio
          </a>
          <span class="material-symbols-outlined text-sm">chevron_right</span>
          <a href="/clubes" class="page-breadcrumb-link">Clubes</a>
          <span class="material-symbols-outlined text-sm">chevron_right</span>
          <span class="page-breadcrumb-current">{club ? club.name : 'No encontrado'}</span>
        </nav>
        <h1 class="page-title">{club ? club.name : 'Club no encontrado'}</h1>
        <p class="page-subtitle">
          {club
            ? `Municipio: ${club.municipality} · Entrenador: ${club.coach}`
            : 'El club solicitado no existe o fue retirado.'}
        </p>
      </div>
    </section>

    <section class="page-section">
      <div class="container mx-auto px-6">
        {club ? (
          <div class="grid gap-10 md:grid-cols-3">
            <div class="md:col-span-2">
              <h2 class="section-heading">Resumen</h2>
              <div class="rounded-2xl border border-[var(--border)] bg-white p-6 text-[var(--text-secondary)] leading-relaxed">
                <p>
                  Esta es la ficha pública del club. En la siguiente fase se mostrará historial competitivo, documentos cargados y vigencia de
                  afiliación (según permisos).
                </p>
              </div>
            </div>
            <aside class="rounded-2xl border border-[var(--border)] bg-white p-6">
              <div class="text-xs font-bold uppercase tracking-wider text-[var(--tertiary)]">Estado</div>
              <div class="mt-2">
                <span
                  class:list={[
                    'rounded-full px-3 py-1 text-xs font-bold uppercase',
                    club.status === 'Activo' ? 'bg-[#e8f5e0] text-[#006b1b]' : 'bg-[#f1f5f9] text-[#334155]'
                  ]}
                >
                  {club.status}
                </span>
              </div>
              <div class="mt-6 space-y-3 text-sm text-[var(--text-secondary)]">
                <div class="flex items-center gap-2">
                  <span class="material-symbols-outlined text-base">location_on</span>
                  <strong class="text-[#0f172a]">{club.municipality}</strong>
                </div>
                <div class="flex items-center gap-2">
                  <span class="material-symbols-outlined text-base">group</span>
                  <strong class="text-[#0f172a]">{club.athletes}</strong> atletas
                </div>
                <div class="flex items-center gap-2">
                  <span class="material-symbols-outlined text-base">person</span>
                  <strong class="text-[#0f172a]">{club.coach}</strong>
                </div>
              </div>
              <div class="mt-8 flex flex-col gap-3">
                <a href="/registro/club" class="btn-primary">Afiliar mi club</a>
                <a href="/contacto" class="btn-secondary">Contactar</a>
              </div>
            </aside>
          </div>
        ) : (
          <div class="rounded-2xl border border-[var(--border)] bg-white p-8">
            <p class="text-[var(--text-secondary)]">Vuelve al directorio de clubes para continuar.</p>
            <div class="mt-6">
              <a href="/clubes" class="btn-primary">Ver clubes</a>
            </div>
          </div>
        )}
      </div>
    </section>
  </main>

  <FooterKinetic siteName={settings.siteName} social={settings.social} />
</BaseLayout>
