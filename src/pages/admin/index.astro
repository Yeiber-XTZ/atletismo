            const allDetails = document.querySelectorAll('.js-athlete-edit-details');
            allDetails.forEach((node) => {
              if (!(node instanceof HTMLDetailsElement)) return;
              if (node === target) return;
              node.open = false;
            });
          },
          true
        );
      })();
    </script>
  </AdminShell>
</BaseLayout>

