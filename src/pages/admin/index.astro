                            <input type="checkbox" name="disciplines" value={disciplineName} />
                            <span>{disciplineName}</span>
                          </label>
                        ))}
                    </div>
                  </div>
                </div>
              </div>
              <div class="md:col-span-12 flex justify-end">
                <button class="admin-btn admin-btn-primary" type="submit">
                  <span class="material-symbols-outlined">save</span>
                  Guardar atleta
                </button>
              </div>
            </form>
          </div>

          <form method="GET" action="/admin" class="rounded-xl border border-gray-200 p-3 grid gap-3 md:grid-cols-12">
            <input type="hidden" name="tab" value="athletes" />
            <div class="md:col-span-5">
              <label class="admin-label">Buscar</label>
              <input class="admin-input" name="athleteQ" value={athleteQuery} placeholder="Nombre, documento, email, municipio" />
            </div>
            <div class="md:col-span-3">
              <label class="admin-label">Estado</label>
              <select class="admin-input" name="athleteStatus">
                <option value="all" selected={athleteStatusFilter === 'all'}>Todos</option>
                <option value="active" selected={athleteStatusFilter === 'active'}>Activo</option>
                <option value="inactive" selected={athleteStatusFilter === 'inactive'}>Inactivo</option>
              </select>
            </div>
            {canManageAllAthletes ? (
              <div class="md:col-span-3">
                <label class="admin-label">Club</label>
                <select class="admin-input" name="athleteClubId">
                  <option value="" selected={!athleteClubFilterId}>Todos los clubes</option>
                  {clubsWithId.map((club) => (
                    <option value={String(club.id)} selected={athleteClubFilterId === club.id}>#{club.id} · {club.name}</option>
                  ))}
                </select>
              </div>
            ) : (
              <input type="hidden" name="athleteClubId" value={String(ownClubId || '')} />
            )}
            <div class="md:col-span-1 flex items-end">
              <button class="admin-btn admin-btn-primary w-full" type="submit">
                <span class="material-symbols-outlined">filter_alt</span>
                Filtrar
              </button>
            </div>
          </form>

          <div class="overflow-x-auto rounded-xl border border-gray-200">
            <table class="min-w-[980px] w-full text-sm table-fixed">
              <thead class="bg-gray-50 text-gray-600">
                <tr>
                  <th class="w-[190px] text-left p-3 font-medium">Atleta</th>
                  <th class="w-[140px] text-left p-3 font-medium">Documento</th>
                  <th class="w-[130px] text-left p-3 font-medium">Club</th>
                  <th class="w-[160px] text-left p-3 font-medium">Datos</th>
                  <th class="w-[150px] text-left p-3 font-medium">Disciplinas</th>
                  <th class="w-[170px] text-left p-3 font-medium">Acciones</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-gray-200 bg-white">
                {athletes.map((a) => (
                  <tr>
                    <td class="p-3 align-top">
                      <div class="flex items-center gap-3 min-w-0">
                        <div class="h-10 w-10 overflow-hidden rounded-full border border-gray-200 bg-gray-50">
                          {a.photoUrl ? (
                            <img src={a.photoUrl} alt={a.fullName} class="h-full w-full object-cover" />
                          ) : (
                            <div class="flex h-full w-full items-center justify-center text-xs text-gray-400">N/A</div>
                          )}
                        </div>
                        <div class="min-w-0">
                          <div class="font-semibold text-gray-800">{a.fullName}</div>
                          <div class="text-xs text-gray-500">#{a.id} · {a.gender} · {a.birthdate || '-'}</div>
                        </div>
                      </div>
                    </td>
                    <td class="p-3 align-top">
                      <div class="text-sm text-gray-700">{a.documentType} {a.document}</div>
                      <div class="text-xs text-gray-500">{a.email || '-'}</div>
                    </td>
                    <td class="p-3 align-top">
                      {a.clubId ? `#${a.clubId} · ${a.clubName}` : a.clubName || '(sin club)'}
                    </td>
                    <td class="p-3 align-top">
                      <div class="text-xs text-gray-600">Municipio: {a.municipalityName || a.municipality || '-'}</div>
                      <div class="text-xs text-gray-600">Coach: {a.coach || '-'}</div>
                      <div class="text-xs text-gray-600">EPS: {a.eps || '-'}</div>
                      <div class="text-xs text-gray-600">Emergencia: {a.emergencyContact || '-'}</div>
                    </td>
                    <td class="p-3 align-top">
                      <div class="text-xs text-gray-700 whitespace-pre-wrap break-words">{a.disciplines.join(', ') || '-'}</div>
                    </td>
                    <td class="p-3 align-top w-[170px] relative">
                      <details class="rounded-xl border border-gray-200 bg-gray-50 js-athlete-edit-details">
                        <summary class="list-none cursor-pointer px-3 py-2 text-sm font-semibold text-gray-700 flex items-center justify-between gap-2">
                          <span class="inline-flex items-center gap-2">
                            <span class="material-symbols-outlined text-base">edit</span>
                            Editar atleta
                          </span>
                          <span class="material-symbols-outlined text-base">expand_more</span>
                        </summary>
                        <div class="border-t border-gray-200 p-3 bg-white lg:absolute lg:right-0 lg:top-full lg:mt-2 lg:w-[920px] lg:max-w-[calc(100vw-340px)] lg:rounded-xl lg:border lg:shadow-xl lg:z-20">
                          <form id={`athlete-update-${a.id}`} method="POST" action="/api/admin/athletes" encType="multipart/form-data" class="grid gap-3 min-w-0">
                            <input type="hidden" name="intent" value="update" />
                            <input type="hidden" name="id" value={a.id} />
                            <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-2">
                              <input class="admin-input min-w-0" name="firstName" value={a.firstName} required />
                              <input class="admin-input min-w-0" name="lastName" value={a.lastName} required />
                              <select class="admin-input min-w-0" name="documentType">
                                <option value="CC" selected={a.documentType === 'CC'}>CC</option>
                                <option value="TI" selected={a.documentType === 'TI'}>TI</option>
                                <option value="CE" selected={a.documentType === 'CE'}>CE</option>
                                <option value="PP" selected={a.documentType === 'PP'}>PP</option>
                              </select>
                              <input class="admin-input min-w-0" name="document" value={a.document} required />
                              <select class="admin-input min-w-0" name="sexCode">
                                {sexCatalog.map((sex) => (
                                  <option value={sex.code} selected={a.sexCode === sex.code || a.gender === sex.code}>{sex.name}</option>
                                ))}
                              </select>
                              <input class="admin-input min-w-0" type="date" name="birthdate" value={a.birthdate} required />
                              <input class="admin-input min-w-0" type="email" name="email" value={a.email} placeholder="Email" />
                              <select class="admin-input min-w-0 js-geo-country" name="countryIso2" data-geo-scope={`edit-${a.id}`}>
                                <option value="">Selecciona país</option>
                                {geoCountries.map((country) => (
                                  <option value={country.iso2} selected={a.countryIso2 === country.iso2}>{country.shortName}</option>
                                ))}
                              </select>
                              <select class="admin-input min-w-0 js-geo-department" name="departmentCode" data-geo-scope={`edit-${a.id}`} data-selected={a.departmentCode}>
                                <option value="">Selecciona departamento</option>
                              </select>
                              <select class="admin-input min-w-0 js-geo-municipality" name="municipalityCode" data-geo-scope={`edit-${a.id}`} data-selected={a.municipalityCode}>
                                <option value="">Selecciona municipio</option>
                              </select>
                              <input type="hidden" name="municipality" value={a.municipalityName || a.municipality} class="js-geo-municipality-name" data-geo-scope={`edit-${a.id}`} />
                              <input class="admin-input min-w-0" name="coach" value={a.coach} placeholder="Coach" />
                              <input class="admin-input min-w-0" name="eps" value={a.eps} placeholder="EPS" />
                              <input class="admin-input min-w-0" name="emergencyContact" value={a.emergencyContact} placeholder="Emergencia" />
                              <input class="admin-input min-w-0" type="file" name="photoFile" accept="image/*" />
                              <input type="hidden" name="photoUrl" value={a.photoUrl || ''} />
                              <select class="admin-input min-w-0" name="status">
                                <option value="active" selected={a.status === 'active'}>Activo</option>
                                <option value="inactive" selected={a.status === 'inactive'}>Inactivo</option>
                              </select>
                              {canManageAllAthletes ? (
                                <select class="admin-input min-w-0" name="clubId" required>
                                  <option value="">Selecciona club</option>
                                  {clubsWithId.map((club) => (
                                    <option value={String(club.id)} selected={Number(a.clubId ?? 0) === club.id}>#{club.id} · {club.name}</option>
                                  ))}
                                </select>
                              ) : (
                                <input type="hidden" name="clubId" value={String(ownClubId || '')} />
                              )}
                              <div class="rounded-xl border border-gray-300 bg-gray-50 js-discipline-picker md:col-span-2 xl:col-span-3">
                                <button
                                  type="button"
                                  class="js-discipline-toggle flex w-full items-center justify-between px-3 py-2 text-sm text-gray-700"
                                  aria-expanded="false"
                                >
                                  <span>Selección disciplinas</span>
                                  <span class="js-discipline-count inline-flex min-w-[28px] items-center justify-center rounded-full bg-amber-100 px-2 py-0.5 text-xs font-semibold text-amber-800">0</span>
                                </button>
                                <div class="js-discipline-panel hidden max-h-36 overflow-auto border-t border-gray-300 p-2">
                                  <div class="grid gap-1">
                                    {athleticsDisciplineNames
                                      .slice()
                                      .sort((x, y) => x.localeCompare(y, 'es-CO'))
                                      .map((disciplineName) => (
                                        <label class="inline-flex items-center gap-2 rounded-md px-2 py-1 text-xs font-semibold uppercase tracking-wide text-gray-800 hover:bg-white">
                                          <input
                                            type="checkbox"
                                            name="disciplines"
                                            value={disciplineName}
                                            checked={a.disciplines.includes(disciplineName)}
                                          />
                                          <span>{disciplineName}</span>
                                        </label>
                                      ))}
                                  </div>
                                </div>
                              </div>
                            </div>
                          </form>
                          <div class="mt-3 flex flex-col-reverse sm:flex-row sm:items-center sm:justify-end gap-2">
                            <form method="POST" action="/api/admin/athletes" onsubmit="return confirm('¿Eliminar atleta? Esta acción no se puede deshacer.');">
                              <input type="hidden" name="intent" value="delete" />
                              <input type="hidden" name="id" value={a.id} />
                              <button class="admin-btn admin-btn-danger w-full sm:w-auto" type="submit">
                                <span class="material-symbols-outlined">delete</span>
                                Eliminar
                              </button>
                            </form>
                            <button class="admin-btn admin-btn-primary w-full sm:w-auto" type="submit" form={`athlete-update-${a.id}`}>
                              <span class="material-symbols-outlined">save</span>
                              Guardar cambios
                            </button>
                          </div>
                        </div>
                      </details>
                    </td>
                  </tr>
                ))}
                {athletes.length === 0 ? (
                  <tr>
                    <td class="p-6 text-center text-gray-400" colSpan={6}>No hay atletas registrados con los filtros actuales.</td>
                  </tr>
                ) : null}
              </tbody>
            </table>
          </div>
        </div>
      </section>
    ) : null}

    {contentTab === 'solicitudes' ? (
      <section class="admin-card">
        <div class="admin-card-header">
          <h4 class="admin-card-title">Solicitudes de Registro</h4>
        </div>
        <div class="admin-card-body space-y-4">
          <p class="text-sm text-gray-500">
            Gestiona las solicitudes de registro pendientes: revisa datos, asigna rol y aprueba o rechaza.
          </p>

          <div class="space-y-3">
            {registrationRadicados.map((item) => (
              <form method="POST" action="/api/admin/radicados" class="rounded-xl border border-gray-200 bg-gray-50 p-4 grid gap-3 md:grid-cols-10">
                <input type="hidden" name="id" value={item.id} />
                <div class="md:col-span-3">
                  <div class="text-xs uppercase tracking-wide text-gray-400">Radicado</div>
                  <div class="font-semibold text-gray-700">{item.radicado}</div>
                  <div class="text-xs text-gray-500 mt-1">{new Date(item.createdAt).toLocaleString('es-CO')}</div>
                  <div class="text-xs mt-2 inline-flex rounded-full bg-white border border-gray-200 px-2 py-0.5 text-gray-700">
                    Perfil: {item.profile}
                  </div>
                </div>
                <div class="md:col-span-3">
                  <div class="text-xs uppercase tracking-wide text-gray-400">Solicitante</div>
                  <div class="font-medium text-gray-700">{item.name}</div>
                  <div class="text-sm text-gray-600">{item.email}</div>
                </div>
                <div class="md:col-span-2">
                  <label class="admin-label">Rol al aprobar</label>
                  <select class="admin-input" name="role">
                    <option value="CLUB" selected={item.profile === 'club'}>CLUB</option>
                  </select>
                </div>
                <div class="md:col-span-10">
                  <label class="admin-label">Notas de revision</label>
                  <input class="admin-input" name="reviewNotes" placeholder="Opcional" />
                </div>
                <div class="md:col-span-2 flex items-end justify-end gap-2">
                  <button class="admin-btn admin-btn-secondary" type="submit" name="decision" value="rejected">
                    <span class="material-symbols-outlined">close</span>
                    Rechazar
                  </button>
                  <button class="admin-btn admin-btn-primary" type="submit" name="decision" value="approved">
                    <span class="material-symbols-outlined">check</span>
                    Aprobar
                  </button>
                </div>
              </form>
            ))}
            {registrationRadicados.length === 0 ? (
              <div class="rounded-xl border border-gray-200 bg-white p-6 text-sm text-gray-500">
                No hay solicitudes pendientes.
              </div>
            ) : null}
          </div>

          <div class="pt-4 border-t border-gray-200">
            <h5 class="text-sm font-semibold text-gray-700">Solicitudes de cambio de perfil (CLUB)</h5>
            <p class="text-xs text-gray-500 mt-1">Aprueba o rechaza cambios de nombre/correo solicitados desde Mi Perfil.</p>
            <div class="space-y-3 mt-3">
              {pendingProfileRequests.map((item) => {
                const payload = item.payload;
                const requestedName = String(payload.displayName ?? '');
                const requestedEmail = String(payload.email ?? '');
                const requestedClubName = String(payload.clubName ?? '');
                const requestedClubMunicipality = String(payload.clubMunicipality ?? '');
                const requestedClubCoach = String(payload.clubCoach ?? '');
                return (
                  <form method="POST" action="/api/admin/approvals" class="rounded-xl border border-gray-200 bg-white p-4 grid gap-3 md:grid-cols-10">
                    <input type="hidden" name="id" value={item.id} />
                    <div class="md:col-span-3">
                      <div class="text-xs uppercase tracking-wide text-gray-400">Solicitud</div>
                      <div class="font-semibold text-gray-700">#{item.id} · {item.module}</div>
                      <div class="text-xs text-gray-500 mt-1">{new Date(item.createdAt).toLocaleString('es-CO')}</div>
                    </div>
                    <div class="md:col-span-5">
                      <div class="text-xs uppercase tracking-wide text-gray-400">Datos solicitados</div>
                      <div class="text-sm text-gray-700"><strong>Nombre:</strong> {requestedName || '-'}</div>
                      <div class="text-sm text-gray-700"><strong>Email:</strong> {requestedEmail || '-'}</div>
                      <div class="text-sm text-gray-700"><strong>Club:</strong> {requestedClubName || '-'}</div>
                      <div class="text-sm text-gray-700"><strong>Municipio:</strong> {requestedClubMunicipality || '-'}</div>
                      <div class="text-sm text-gray-700"><strong>Entrenador:</strong> {requestedClubCoach || '-'}</div>
                    </div>
                    <div class="md:col-span-10">
                      <label class="admin-label">Notas de revisión</label>
                      <input class="admin-input" name="reviewNotes" placeholder="Opcional" />
                    </div>
                    <div class="md:col-span-2 flex items-end justify-end gap-2">
                      <button class="admin-btn admin-btn-secondary" type="submit" name="decision" value="rejected">
                        <span class="material-symbols-outlined">close</span>
                        Rechazar
                      </button>
                      <button class="admin-btn admin-btn-primary" type="submit" name="decision" value="approved">
                        <span class="material-symbols-outlined">check</span>
                        Aprobar
                      </button>
                    </div>
                  </form>
                );
              })}
              {pendingProfileRequests.length === 0 ? (
                <div class="rounded-xl border border-gray-200 bg-gray-50 p-4 text-sm text-gray-500">
                  No hay solicitudes de cambio de perfil pendientes.
                </div>
              ) : null}
            </div>
          </div>
        </div>
      </section>
    ) : null}

    {contentTab === 'roles' ? (
      <section class="admin-card">
        <div class="admin-card-header">
