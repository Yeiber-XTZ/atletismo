    <script is:inline>
      (() => {
        if (globalThis.__adminConvCatalogV3Bound === true) return;
        globalThis.__adminConvCatalogV3Bound = true;

        const norm = (value) => String(value || '').trim().toLowerCase();

        const bindCatalog = (catalogRoot) => {
          if (!(catalogRoot instanceof HTMLElement)) return;
          if (catalogRoot.dataset.convCatalogV2Bound === '1') return;
          catalogRoot.dataset.convCatalogV2Bound = '1';

          const disciplineSelect = catalogRoot.querySelector('.js-conv-discipline-select-v3');
          const eventChecks = Array.from(catalogRoot.querySelectorAll('.js-conv-event-check-v3'));
          const selectVisibleBtn = catalogRoot.querySelector('.js-conv-select-visible-events-v3');
          const clearVisibleBtn = catalogRoot.querySelector('.js-conv-clear-visible-events-v3');
          const disciplinesHidden = catalogRoot.querySelector('.js-conv-disciplines-hidden-v3');
          const eventsHidden = catalogRoot.querySelector('.js-conv-events-hidden-v3');
          const selectedCount = catalogRoot.querySelector('.js-conv-events-count-v3');

          if (
            !(disciplineSelect instanceof HTMLSelectElement) ||
            !(disciplinesHidden instanceof HTMLTextAreaElement) ||
            !(eventsHidden instanceof HTMLTextAreaElement)
          ) return;

          const syncHidden = () => {
            const selectedDiscipline = String(disciplineSelect.value || '').trim();
            const selectedEvents = eventChecks
              .filter((el) => el instanceof HTMLInputElement && el.checked)
              .map((el) => (el instanceof HTMLInputElement ? String(el.value || '').trim() : ''))
              .filter(Boolean);
            disciplinesHidden.value = selectedDiscipline ? selectedDiscipline : '';
            eventsHidden.value = selectedEvents.join('\n');
            if (selectedCount instanceof HTMLElement) selectedCount.textContent = String(selectedEvents.length);
          };

          const refresh = () => {
            const selectedDiscipline = norm(disciplineSelect.value);

            eventChecks.forEach((el) => {
              if (!(el instanceof HTMLInputElement)) return;
              const row = el.closest('label') || el.parentElement;
              const discipline = norm(el.getAttribute('data-discipline'));
              const visible = !selectedDiscipline || discipline === selectedDiscipline;
              el.disabled = !visible;
              if (row instanceof HTMLElement) {
                row.style.display = visible ? '' : 'none';
                row.setAttribute('aria-hidden', visible ? 'false' : 'true');
              }
            });

            syncHidden();
          };

          const initFromHidden = () => {
            const selectedDiscipline = String(disciplinesHidden.value || '')
              .split(/\r?\n/)
              .map((item) => String(item || '').trim())
              .find(Boolean) || '';
            const selectedEvents = new Set(
              String(eventsHidden.value || '')
                .split(/\r?\n/)
                .map((item) => norm(item))
                .filter(Boolean)
            );

            disciplineSelect.value = selectedDiscipline;
            eventChecks.forEach((el) => {
              if (!(el instanceof HTMLInputElement)) return;
              el.checked = selectedEvents.has(norm(el.value));
            });
            refresh();
          };

          disciplineSelect.addEventListener('change', (event) => {
            event.stopPropagation();
            refresh();
          });

          eventChecks.forEach((el) => {
            if (!(el instanceof HTMLInputElement)) return;
            el.addEventListener('change', (event) => {
              event.stopPropagation();
              syncHidden();
            });
            el.addEventListener('click', (event) => event.stopPropagation());
          });

          if (selectVisibleBtn instanceof HTMLButtonElement) {
            selectVisibleBtn.addEventListener('click', (event) => {
              event.preventDefault();
              event.stopPropagation();
              refresh();
              eventChecks.forEach((ev) => {
                if (!(ev instanceof HTMLInputElement)) return;
                if (!ev.disabled) ev.checked = true;
              });
              syncHidden();
            });
          }

          if (clearVisibleBtn instanceof HTMLButtonElement) {
            clearVisibleBtn.addEventListener('click', (event) => {
              event.preventDefault();
              event.stopPropagation();
              refresh();
              eventChecks.forEach((ev) => {
                if (!(ev instanceof HTMLInputElement)) return;
                if (!ev.disabled) ev.checked = false;
              });
              syncHidden();
            });
          }

          initFromHidden();
        };

        const bindAll = () => {
          document.querySelectorAll('.js-conv-catalog-v3').forEach((item) => bindCatalog(item));
        };

        bindAll();
        setTimeout(bindAll, 0);

        const observer = new MutationObserver(() => bindAll());
        observer.observe(document.body, { childList: true, subtree: true });
      })();
    </script>
    <script is:inline>
      (() => {
        const pickerState = globalThis.__adminDisciplinePickerState || (globalThis.__adminDisciplinePickerState = { handlersBound: false });

        const syncCount = (root) => {
          if (!(root instanceof HTMLElement)) return;
          const countEl = root.querySelector('.js-discipline-count');
          if (!(countEl instanceof HTMLElement)) return;
          const checked = root.querySelectorAll('input[name="disciplines"]:checked').length;
          countEl.textContent = String(checked);
        };

        const closePanel = (root) => {
          const panel = root.querySelector('.js-discipline-panel');
          const toggle = root.querySelector('.js-discipline-toggle');
          if (panel instanceof HTMLElement) panel.classList.add('hidden');
          if (toggle instanceof HTMLButtonElement) toggle.setAttribute('aria-expanded', 'false');
        };

        const openPanel = (root) => {
          const panel = root.querySelector('.js-discipline-panel');
          const toggle = root.querySelector('.js-discipline-toggle');
          if (panel instanceof HTMLElement) panel.classList.remove('hidden');
          if (toggle instanceof HTMLButtonElement) toggle.setAttribute('aria-expanded', 'true');
        };

        const bindPicker = (root) => {
          if (!(root instanceof HTMLElement)) return;
          if (root.dataset.boundDisciplinesPicker === '1') return;
          root.dataset.boundDisciplinesPicker = '1';

          const toggle = root.querySelector('.js-discipline-toggle');
          const panel = root.querySelector('.js-discipline-panel');
          if (!(toggle instanceof HTMLButtonElement) || !(panel instanceof HTMLElement)) return;

          toggle.addEventListener('click', (event) => {
            event.preventDefault();
            event.stopPropagation();
            const isOpen = !panel.classList.contains('hidden');
            if (isOpen) closePanel(root);
            else openPanel(root);
          });

          root.querySelectorAll('input[name="disciplines"]').forEach((input) => {
            input.addEventListener('change', () => syncCount(root));
          });

          syncCount(root);
        };

        const bindAll = () => {
          document.querySelectorAll('.js-discipline-picker').forEach((root) => bindPicker(root));
        };

        if (!pickerState.handlersBound) {
          document.addEventListener('click', (event) => {
            const target = event.target;
            if (!(target instanceof Element)) return;
            document.querySelectorAll('.js-discipline-picker').forEach((root) => {
              if (!(root instanceof HTMLElement)) return;
              if (!root.contains(target)) closePanel(root);
            });
          });

          document.addEventListener('astro:page-load', () => {
            bindAll();
            setTimeout(bindAll, 0);
          });
          pickerState.handlersBound = true;
        }

        bindAll();
        setTimeout(bindAll, 0);
      })();
    </script>
    <script is:inline>
      (() => {
        const state = globalThis.__adminCsvExportState || (globalThis.__adminCsvExportState = { bound: false });
        if (state.bound) return;
        state.bound = true;

        const modal = document.getElementById('csv-export-modal');
        const modalTitle = document.getElementById('csv-export-modal-title');
        const modalMessage = document.getElementById('csv-export-modal-message');
        const closeBtn = document.getElementById('csv-export-modal-close');
        const okBtn = document.getElementById('csv-export-modal-ok');

        const closeModal = () => {
          if (!(modal instanceof HTMLElement)) return;
          modal.classList.add('hidden');
          modal.classList.remove('flex');
          modal.setAttribute('aria-hidden', 'true');
        };

        const openModal = (title, message) => {
          if (!(modal instanceof HTMLElement)) return;
          if (modalTitle instanceof HTMLElement) modalTitle.textContent = title;
          if (modalMessage instanceof HTMLElement) modalMessage.textContent = message;
          modal.classList.remove('hidden');
          modal.classList.add('flex');
          modal.setAttribute('aria-hidden', 'false');
        };

        closeBtn?.addEventListener('click', closeModal);
        okBtn?.addEventListener('click', closeModal);
        modal?.addEventListener('click', (event) => {
          if (event.target === modal) closeModal();
        });

        const getFilename = (contentDisposition) => {
          const raw = String(contentDisposition || '');
          const match = raw.match(/filename=\"?([^\";]+)\"?/i);
          if (!match?.[1]) return `postulaciones-${new Date().toISOString().slice(0, 10)}.csv`;
          return match[1];
        };

        document.addEventListener('click', async (event) => {
          const target = event.target;
          if (!(target instanceof Element)) return;
          const button = target.closest('.js-export-postulations-csv');
          if (!(button instanceof HTMLButtonElement)) return;
          event.preventDefault();

          const exportUrl = String(button.dataset.exportUrl || '').trim();
          if (!exportUrl) {
            openModal('Exportación CSV', 'No se pudo iniciar la exportación. Intenta nuevamente.');
            return;
          }

          button.disabled = true;
          const previousLabel = button.innerHTML;
          button.innerHTML = '<span class="material-symbols-outlined">hourglass_top</span> Exportando...';
          try {
            const response = await fetch(exportUrl, { method: 'GET', credentials: 'same-origin' });
            if (!response.ok) {
              if (response.status === 401) {
                openModal('Sesión expirada', 'Debes iniciar sesión nuevamente para exportar el CSV.');
                return;
              }
              if (response.status === 403) {
                openModal('Acceso denegado', 'Tu rol no tiene permisos para exportar postulaciones en CSV.');
                return;
              }
              openModal('Error de exportación', 'No se pudo generar el archivo CSV en este momento.');
              return;
            }

            const contentType = String(response.headers.get('content-type') || '').toLowerCase();
            if (!contentType.includes('text/csv')) {
              openModal('Error de exportación', 'La respuesta no corresponde a un archivo CSV válido.');
              return;
            }

            const blob = await response.blob();
            const filename = getFilename(response.headers.get('content-disposition'));
            const blobUrl = URL.createObjectURL(blob);
            const link = document.createElement('a');
            link.href = blobUrl;
            link.download = filename;
            document.body.appendChild(link);
            link.click();
            link.remove();
            URL.revokeObjectURL(blobUrl);

            openModal('Exportación completada', 'El archivo CSV se descargó correctamente.');
          } catch (error) {
            openModal('Error de exportación', 'No fue posible exportar el CSV. Revisa tu conexión e intenta nuevamente.');
          } finally {
            button.disabled = false;
            button.innerHTML = previousLabel;
          }
        });
      })();
    </script>
