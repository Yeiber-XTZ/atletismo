              <div class="md:col-span-2">
                <label class="admin-label">Tipo doc.</label>
                <select class="admin-input" name="documentType">
                  <option value="CC">CC</option>
                  <option value="TI">TI</option>
                  <option value="CE">CE</option>
                  <option value="PP">PP</option>
                </select>
              </div>
              <div class="md:col-span-2">
                <label class="admin-label">Documento</label>
                <input class="admin-input" name="document" required />
              </div>
              <div class="md:col-span-2">
                <label class="admin-label">Sexo</label>
                <select class="admin-input" name="sexCode" required>
                  {sexCatalog.map((sex) => (
                    <option value={sex.code}>{sex.name}</option>
