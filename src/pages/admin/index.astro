    <script is:inline define:vars={{ geoDepartments, geoMunicipalities }}>
      (() => {
      const root = document;
      root.addEventListener('toggle', (event) => {
        const details = event.target instanceof HTMLDetailsElement ? event.target : null;
        if (!details || !details.open) return;
        const groupSelector = details.getAttribute('data-accordion-group');
        if (!groupSelector) return;
        const group = root.querySelector(groupSelector);
        if (!group) return;
        group.querySelectorAll(`details[data-accordion-group="${groupSelector}"]`).forEach((node) => {
          if (node instanceof HTMLDetailsElement && node !== details) {
            node.open = false;
          }
        });
      }, true);
      const baseState = globalThis.__adminBaseBindingsState || (globalThis.__adminBaseBindingsState = { handlersBound: false });
      const GEO_DEPARTMENTS = geoDepartments;
      const GEO_MUNICIPALITIES = geoMunicipalities;

      const normalizeCode = (value) => String(value || '').trim().toUpperCase();
      const matchesCode = (left, right) => {
        const a = normalizeCode(left);
        const b = normalizeCode(right);
        if (!a || !b) return false;
        return a === b || a.startsWith(b) || b.startsWith(a);
      };

      const fillSelect = (selectEl, items, selectedValue, valueKey = 'code', labelKey = 'name') => {
        if (!(selectEl instanceof HTMLSelectElement)) return;
        const firstOption = selectEl.querySelector('option');
        const placeholder = firstOption ? firstOption.textContent || '' : 'Selecciona';
        selectEl.innerHTML = '';
        const ph = document.createElement('option');
        ph.value = '';
        ph.textContent = placeholder;
        selectEl.appendChild(ph);
        for (const item of items) {
          const opt = document.createElement('option');
          opt.value = String(item?.[valueKey] ?? '');
          opt.textContent = String(item?.[labelKey] ?? '');
          if (selectedValue && opt.value === String(selectedValue)) opt.selected = true;
          selectEl.appendChild(opt);
        }
      };

      const initGeoScope = (scope) => {
        const country = root.querySelector(`.js-geo-country[data-geo-scope=\"${scope}\"]`);
        const department = root.querySelector(`.js-geo-department[data-geo-scope=\"${scope}\"]`);
        const municipality = root.querySelector(`.js-geo-municipality[data-geo-scope=\"${scope}\"]`);
        const municipalityNameInput = root.querySelector(`.js-geo-municipality-name[data-geo-scope=\"${scope}\"]`);
        if (!(country instanceof HTMLSelectElement) || !(department instanceof HTMLSelectElement) || !(municipality instanceof HTMLSelectElement)) return;

        const selectedDepartment = department.getAttribute('data-selected') || department.value || '';
        const selectedMunicipality = municipality.getAttribute('data-selected') || municipality.value || '';
        const countryCode = normalizeCode(country.value || 'CO');
        if (!country.value) country.value = countryCode;
