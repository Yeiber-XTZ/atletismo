              </div>
              <div class="md:col-span-2">
                <label class="admin-label">Nacimiento</label>
                <input class="admin-input" type="date" name="birthdate" required />
              </div>
              <div class="md:col-span-3">
                <label class="admin-label">Email</label>
                <input class="admin-input" type="email" name="email" />
              </div>
              <div class="md:col-span-3">
                <label class="admin-label">País</label>
                <select class="admin-input js-geo-country" name="countryIso2" data-geo-scope="create">
                  <option value="">Selecciona país</option>
                  {geoCountries.map((country) => (
                    <option value={country.iso2} selected={country.iso2 === 'CO'}>{country.shortName}</option>
                  ))}
                </select>
              </div>
              <div class="md:col-span-3">
                <label class="admin-label">Departamento</label>
                <select class="admin-input js-geo-department" name="departmentCode" data-geo-scope="create">
                  <option value="">Selecciona departamento</option>
                </select>
              </div>
              <div class="md:col-span-3">
                <label class="admin-label">Municipio</label>
                <select class="admin-input js-geo-municipality" name="municipalityCode" data-geo-scope="create">
                  <option value="">Selecciona municipio</option>
                </select>
                <input type="hidden" name="municipality" class="js-geo-municipality-name" data-geo-scope="create" />
              </div>
              <div class="md:col-span-2">
                <label class="admin-label">Estado</label>
                <select class="admin-input" name="status">
                  <option value="active">Activo</option>
                  <option value="inactive">Inactivo</option>
                </select>
              </div>
              {canManageAllAthletes ? (
                <div class="md:col-span-2">
                  <label class="admin-label">Club</label>
                  <select class="admin-input" name="clubId" required>
                    <option value="">Selecciona club</option>
                    {clubsWithId.map((club) => (
                      <option value={String(club.id)}>#{club.id} · {club.name}</option>
                    ))}
                  </select>
                </div>
              ) : null}
              <div class="md:col-span-4">
                <label class="admin-label">Entrenador</label>
                <input class="admin-input" name="coach" />
              </div>
              <div class="md:col-span-4">
                <label class="admin-label">EPS</label>
                <input class="admin-input" name="eps" />
              </div>
              <div class="md:col-span-4">
                <label class="admin-label">Contacto emergencia</label>
                <input class="admin-input" name="emergencyContact" />
              </div>
              <div class="md:col-span-4">
                <label class="admin-label">Foto</label>
                <input class="admin-input" type="file" name="photoFile" accept="image/*" />
                <input type="hidden" name="photoUrl" value="" />
              </div>
              <div class="md:col-span-12">
                <label class="admin-label">Pruebas / disciplinas</label>
                <div class="rounded-xl border border-gray-300 bg-gray-50 js-discipline-picker">
                  <button
                    type="button"
                    class="js-discipline-toggle flex w-full items-center justify-between px-3 py-2 text-sm text-gray-700"
                    aria-expanded="false"
                  >
                    <span>Selección disciplinas</span>
                    <span class="js-discipline-count inline-flex min-w-[28px] items-center justify-center rounded-full bg-amber-100 px-2 py-0.5 text-xs font-semibold text-amber-800">0</span>
                  </button>
                  <div class="js-discipline-panel hidden max-h-36 overflow-auto border-t border-gray-300 p-2">
                    <div class="grid gap-1">
                      {athleticsDisciplineNames
                        .slice()
                        .sort((a, b) => a.localeCompare(b, 'es-CO'))
