---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AdminShell from '../../components/admin/AdminShell.astro';
import { getAdminData, listDocuments } from '../../lib/admin';
import { hasPermission, PERMISSIONS, ROLES, type AuthUser } from '../../lib/rbac';
import { listRolePermissionMatrix } from '../../lib/role-permissions';
import { getUserById, listUsers } from '../../lib/users';
import { listPqrs } from '../../lib/pqrs';
import { listPostulaciones, PostulationStatus, summarizePostulaciones } from '../../lib/postulaciones';
import { listAssemblyMeetings, summarizeAssemblyAttendance, summarizeAssemblyMeetings } from '../../lib/asambleas';
import { getAdminAnalytics } from '../../lib/analytics';
import { getAdminAlerts } from '../../lib/alerts';
import { listNotifications, listNotificationsForRole } from '../../lib/notificaciones';
import { listAuditLogs } from '../../lib/audit';
import { listRadicados } from '../../lib/radicados';
import { listApprovalRequests } from '../../lib/approvals';
import { listConvocatoriaCategories } from '../../lib/convocatoria-categories';
import { listAthletes } from '../../lib/athletes-admin';
import { getClubByOwnerUserId } from '../../lib/clubs';
import { listAthleticsCatalogs, listGeoCatalogs, listSexCatalog } from '../../lib/catalogs';

const user = Astro.locals.user as AuthUser | null;
const requestedTab = Astro.url.searchParams.get('tab') ?? ((user?.role === 'SUPERADMIN' || user?.role === 'ADMIN') ? 'dashboard' : 'settings');
const tabAliases: Record<string, string> = {
  home: 'settings',
  hero: 'settings',
  content: 'settings',
  institucional: 'liga-publica',
  liga: 'liga-publica',
  analytics: 'dashboard',
  calendar: 'competencias',
  calendario: 'competencias',
  permissions: 'permisos',
  radicados: 'solicitudes'
};
const navAliases: Record<string, string> = {
  home: 'settings',
  hero: 'settings',
  content: 'settings',
  institucional: 'liga-publica',
  liga: 'liga-publica',
  analytics: 'dashboard',
  calendar: 'competencias',
  calendario: 'competencias',
  permissions: 'permisos',
  radicados: 'solicitudes'
};
const activeTab = navAliases[requestedTab] ?? requestedTab;
const contentTab = tabAliases[requestedTab] ?? requestedTab;
const saved = Astro.url.searchParams.get('saved');
const error = Astro.url.searchParams.get('error');
const settingsViewParam = (Astro.url.searchParams.get('settingsView') ?? '').trim().toLowerCase();
const settingsViews = new Set(['general', 'hero', 'home']);
const settingsView = settingsViews.has(settingsViewParam) ? settingsViewParam : '';
const ligaViewParam = (Astro.url.searchParams.get('ligaView') ?? '').trim().toLowerCase();
const ligaViews = new Set(['hero', 'info', 'estructura']);
const ligaView = ligaViews.has(ligaViewParam) ? ligaViewParam : '';
const errorMessages: Record<string, string> = {
  invalid_schema: 'Hay campos inválidos o incompletos. Revisa el formulario.',
  missing_club: 'Tu usuario no tiene club asociado para registrar atletas.',
  missing_municipality: 'Debes seleccionar un municipio válido.',
  duplicate_document: 'Ya existe un atleta con ese número de documento.',
  duplicate_email: 'El correo ya está registrado por otro usuario.'
};
const errorMessage = error ? (errorMessages[error] ?? 'Error al guardar los cambios') : '';
const savedMessages: Record<string, string> = {
  '1': 'Cambios guardados exitosamente',
  profile_updated: 'Perfil actualizado exitosamente',
  profile_request_sent: 'Solicitud de cambio enviada. Se aplicará cuando sea aprobada.'
};
const savedMessage = saved ? (savedMessages[saved] ?? 'Cambios guardados exitosamente') : '';
const openCreateDocumentForm = error === 'missing_file' || error === 'invalid_schema';
const postulationStatusFilter = Astro.url.searchParams.get('postStatus') ?? 'all';
const postulationQuery = (Astro.url.searchParams.get('postQ') ?? '').trim();
const athleteStatusFilter = Astro.url.searchParams.get('athleteStatus') ?? 'all';
const athleteQuery = (Astro.url.searchParams.get('athleteQ') ?? '').trim();
const athleteClubFilterId = Number(Astro.url.searchParams.get('athleteClubId') ?? 0);
const auditAction = (Astro.url.searchParams.get('auditAction') ?? '').trim();
const auditEntity = (Astro.url.searchParams.get('auditEntity') ?? '').trim();
const auditUserId = Number(Astro.url.searchParams.get('auditUserId') ?? 0);
const auditPage = Math.max(1, Number(Astro.url.searchParams.get('auditPage') ?? 1));
const auditPageSize = Math.min(100, Math.max(10, Number(Astro.url.searchParams.get('auditPageSize') ?? 25)));

const data = await getAdminData();
const sexCatalog = await listSexCatalog();
const geoCatalog = await listGeoCatalogs();
const geoCountries = geoCatalog.countries ?? [];
const geoDepartments = geoCatalog.departments ?? [];
const geoMunicipalities = geoCatalog.municipalities ?? [];
const athleticsCatalog = await listAthleticsCatalogs();
const managedConvocatoriaCategories = await listConvocatoriaCategories();
const docs = await listDocuments();
const marks: Array<{ id: number; athlete: string; discipline: string; value: string; unit: string; recordDate: string }> = [];
const convocatoriaCategoryOptions = Array.from(
  new Set(
    [
      ...managedConvocatoriaCategories.map((item) => String(item.name ?? '').trim()),
      ...(data.convocatorias ?? []).map((item) => String(item.category ?? '').trim())
    ].filter(Boolean)
  )
).sort((a, b) => a.localeCompare(b, 'es-CO'));

const normalizeGeoText = (value: unknown) =>
  String(value ?? '')
    .normalize('NFD')
    .replace(/[\u0300-\u036f]/g, '')
    .trim()
    .toLowerCase();
const municipalityGeoIndex = new Map(
  (geoMunicipalities ?? []).map((item) => [normalizeGeoText(item.name), item])
);

const isSuperAdmin = user?.role === 'SUPERADMIN';
const isAdminRoot = user?.role === 'SUPERADMIN' || user?.role === 'ADMIN';
const canDelegateAssemblyPermissions = user?.role === 'LIGA' || user?.role === 'ORGANO_ADMIN';
const delegatedAssemblyPermissions = [
  'assembly:self_panel',
  'assembly:attendance:create',
  'assembly:observations:create',
  'documents:read_private_asamblea'
];
const canManageUsers = hasPermission(user, 'users:manage');
const canManageApprovals = hasPermission(user, 'approvals:manage');
const canManageAsambleas = hasPermission(user, 'asambleas:manage');
const canViewAsambleasPanel = canManageAsambleas || hasPermission(user, 'assembly:self_panel');
const canManageNotifications = hasPermission(user, 'notificaciones:manage');
const canViewNotifications = canManageNotifications || hasPermission(user, 'assembly:self_panel') || user?.role === 'CLUB';
const canViewAlerts = hasPermission(user, 'records:manage');
const canManageAllAthletes = hasPermission(user, 'athletes:manage');
const canManageClubAthletes = hasPermission(user, 'athletes:self_manage');
const canAccessAthletesTab = canManageAllAthletes || canManageClubAthletes;
let ownClubId = user?.clubId ? Number(user.clubId) : 0;
if (!ownClubId && user?.role === 'CLUB' && user?.id) {
  const ownedClub = await getClubByOwnerUserId(Number(user.id));
  ownClubId = ownedClub?.id ?? 0;
}
if ((contentTab === 'roles' || contentTab === 'permisos') && !isSuperAdmin) {
  return Astro.redirect('/acceso-denegado');
}
if (contentTab === 'notificaciones' && !canViewNotifications) {
  return Astro.redirect('/acceso-denegado');
}
if (contentTab === 'alertas' && !canViewAlerts) {
  return Astro.redirect('/acceso-denegado');
}
if (contentTab === 'asambleas' && !canViewAsambleasPanel) {
  return Astro.redirect('/acceso-denegado');
}
if (contentTab === 'athletes' && !canAccessAthletesTab) {
  return Astro.redirect('/acceso-denegado');
}
if (contentTab === 'perfil' && user?.role === 'SUPERADMIN') {
  return Astro.redirect('/acceso-denegado');
}
const currentProfileUser = user?.id ? await getUserById(Number(user.id)) : null;
const users = canManageUsers ? await listUsers() : [];
const usersForUsersTab =
  user?.role === 'LIGA' || user?.role === 'ORGANO_ADMIN'
    ? users.filter((u) => (u.roles?.[0] ?? '') === 'CLUB')
    : users;
const athleteScopeClubId = canManageAllAthletes
  ? (Number.isFinite(athleteClubFilterId) && athleteClubFilterId > 0 ? athleteClubFilterId : undefined)
  : (ownClubId > 0 ? ownClubId : undefined);
const athletes = canAccessAthletesTab
  ? (!canManageAllAthletes && !athleteScopeClubId
      ? []
      : await listAthletes({
          clubId: athleteScopeClubId,
          query: athleteQuery,
          status: athleteStatusFilter
        }))
  : [];
const pqrs = isAdminRoot ? await listPqrs(500) : [];
const canApprovePostulations = hasPermission(user, 'postulations:approve');
const postulationsDb = (canApprovePostulations || user?.role === 'CLUB') ? await listPostulaciones() : [];
const postulations = user?.role === 'CLUB' ? postulationsDb.filter(p => String(p.clubId) === String(user.clubId)) : postulationsDb;
const postulationSummary = canApprovePostulations
  ? await summarizePostulaciones()
  : { total: 0, byStatus: [], byConvocatoria: [] };
const asambleas = canViewAsambleasPanel ? await listAssemblyMeetings() : [];
const asambleaAttendanceSummary = canManageAsambleas
  ? await summarizeAssemblyAttendance()
  : { total: 0, byStatus: [] };
const asambleaMeetingsSummary = canManageAsambleas ? await summarizeAssemblyMeetings() : [];
const analytics = user && (user.role === 'SUPERADMIN' || user.role === 'ADMIN' || user.role === 'LIGA' || user.role === 'ORGANO_ADMIN') ? await getAdminAnalytics() : null;
const alerts = canViewAlerts ? await getAdminAlerts() : [];
const notificationsManaged = canManageNotifications ? await listNotifications() : [];
const notificationsForUser = canViewNotifications && user?.role ? await listNotificationsForRole(user.role) : [];
const registrationRadicados = canManageApprovals ? await listRadicados('pending') : [];
const pendingProfileRequests = canManageApprovals
  ? (await listApprovalRequests('pending')).filter((item) => item.module === 'profile_update')
  : [];
const auditLogResult = isAdminRoot
  ? await listAuditLogs({
      action: auditAction || undefined,
      entityType: auditEntity || undefined,
      userId: Number.isFinite(auditUserId) && auditUserId > 0 ? auditUserId : undefined,
      limit: auditPageSize,
      offset: (auditPage - 1) * auditPageSize
    })
  : { rows: [], total: 0, limit: auditPageSize, offset: 0 };
const auditLogs = auditLogResult.rows;
const auditTotal = auditLogResult.total;
const auditTotalPages = Math.max(1, Math.ceil(auditTotal / auditPageSize));
const auditPrevPage = Math.max(1, auditPage - 1);
const auditNextPage = Math.min(auditTotalPages, auditPage + 1);
const auditBaseParams = new URLSearchParams();
auditBaseParams.set('tab', 'auditoria');
if (auditAction) auditBaseParams.set('auditAction', auditAction);
if (auditEntity) auditBaseParams.set('auditEntity', auditEntity);
if (Number.isFinite(auditUserId) && auditUserId > 0) auditBaseParams.set('auditUserId', String(auditUserId));
auditBaseParams.set('auditPageSize', String(auditPageSize));
const getAuditPageHref = (page: number) => {
  const params = new URLSearchParams(auditBaseParams);
  params.set('auditPage', String(Math.max(1, page)));
  return `/admin?${params.toString()}`;
};
const dashboardCards = [
  { label: 'Convocatorias', value: analytics?.totals.convocatorias ?? 0, color: 'from-emerald-500 to-emerald-700' },
  { label: 'Competencias', value: analytics?.totals.competencias ?? 0, color: 'from-sky-500 to-sky-700' },
  { label: 'Clubes', value: analytics?.totals.clubes ?? 0, color: 'from-violet-500 to-violet-700' },
  { label: 'Noticias', value: analytics?.totals.noticias ?? 0, color: 'from-amber-500 to-amber-700' },
  { label: 'Documentos', value: analytics?.totals.documents ?? 0, color: 'from-rose-500 to-rose-700' },
  { label: 'Usuarios', value: users.length, color: 'from-slate-600 to-slate-800' }
];
const totalManagedContent = dashboardCards.reduce((acc, card) => acc + Number(card.value || 0), 0);
const postStatusMap = new Map<string, number>(
  (analytics?.postulationsByStatus ?? []).map((item) => [String(item.status ?? '').trim().toLowerCase(), Number(item.count ?? 0)])
);
const pqrsStatusMap = new Map<string, number>(
  (analytics?.pqrsByStatus ?? []).map((item) => [String(item.status ?? '').trim().toLowerCase(), Number(item.count ?? 0)])
);
const postulationsTotal = Number(postulationSummary?.total ?? 0);
const postulationsApproved = Array.from(postStatusMap.entries())
  .filter(([status]) => status.includes('aprob'))
  .reduce((acc, [, count]) => acc + count, 0);
const postulationsPending = Array.from(postStatusMap.entries())
  .filter(([status]) => status.includes('postul') || status.includes('revisi') || status.includes('pend'))
  .reduce((acc, [, count]) => acc + count, 0);
const postulationsRejected = Array.from(postStatusMap.entries())
  .filter(([status]) => status.includes('rechaz') || status.includes('incomplet'))
  .reduce((acc, [, count]) => acc + count, 0);
const pqrsTotal = (analytics?.pqrsByStatus ?? []).reduce((acc, item) => acc + Number(item.count ?? 0), 0);
const pqrsResolved = Array.from(pqrsStatusMap.entries())
  .filter(([status]) => status.includes('resuelt') || status.includes('cerrad'))
  .reduce((acc, [, count]) => acc + count, 0);
const pqrsOpen = Math.max(0, pqrsTotal - pqrsResolved);
const approvalRate = postulationsTotal > 0 ? Math.round((postulationsApproved / postulationsTotal) * 100) : 0;
const pqrsResolutionRate = pqrsTotal > 0 ? Math.round((pqrsResolved / pqrsTotal) * 100) : 0;
const activityLast7Post = (analytics?.last7Days ?? []).reduce((acc, day) => acc + Number(day.postulations ?? 0), 0);
const activityLast7Pqrs = (analytics?.last7Days ?? []).reduce((acc, day) => acc + Number(day.pqrs ?? 0), 0);
const activityPeak = Math.max(
  1,
  ...(analytics?.last7Days ?? []).map((day) => Math.max(Number(day.postulations ?? 0), Number(day.pqrs ?? 0)))
);
const todayActivity = (() => {
  const today = new Date().toISOString().slice(0, 10);
  return (analytics?.last7Days ?? []).find((day) => day.day === today);
})();
const operationalPulse =
  approvalRate >= 60 && pqrsResolutionRate >= 60
    ? 'Estable'
    : approvalRate >= 40 || pqrsResolutionRate >= 40
      ? 'En seguimiento'
      : 'Crítico';
const operationalPulseClass =
  operationalPulse === 'Estable'
    ? 'bg-emerald-100 text-emerald-800 border-emerald-200'
    : operationalPulse === 'En seguimiento'
      ? 'bg-amber-100 text-amber-800 border-amber-200'
      : 'bg-red-100 text-red-800 border-red-200';
const todayIso = new Date().toISOString().slice(0, 10);
const convocatoriasAbiertas = (data.convocatorias ?? []).filter((item) => String(item.status ?? '').toLowerCase().includes('abierta')).length;
const clubesActivos = (data.clubs ?? []).filter((item) => {
  const status = String(item.status ?? '').toLowerCase();
  return status.includes('activo') || status.includes('aprobado');
}).length;
const proximasCompetencias = (data.competencias ?? []).filter((item) => {
  const value = String(item.date ?? '').trim();
  return value && value >= todayIso;
}).length;
const metricCards = [
  {
    label: 'Convocatorias Abiertas',
    value: convocatoriasAbiertas,
    growth: `${data.convocatorias?.length ?? 0} total`,
    color: 'text-emerald-700 bg-emerald-100',
    progress: Math.min(100, Math.round((convocatoriasAbiertas / Math.max(1, data.convocatorias?.length ?? 1)) * 100))
  },
  {
    label: 'Clubes Activos',
    value: clubesActivos,
    growth: `${data.clubs?.length ?? 0} registrados`,
    color: 'text-amber-700 bg-amber-100',
    progress: Math.min(100, Math.round((clubesActivos / Math.max(1, data.clubs?.length ?? 1)) * 100))
  },
  {
    label: 'Competencias Proximas',
    value: proximasCompetencias,
    growth: 'Calendario vigente',
    color: 'text-sky-700 bg-sky-100',
    progress: Math.min(100, Math.round((proximasCompetencias / Math.max(1, data.competencias?.length ?? 1)) * 100))
  },
  {
    label: 'Radicados Pendientes',
    value: registrationRadicados.length,
    growth: 'Solicitudes por revisar',
    color: 'text-violet-700 bg-violet-100',
    progress: Math.min(100, Math.round((registrationRadicados.length / Math.max(1, users.length || 1)) * 100))
  }
];
const trendRows = (analytics?.last7Days ?? []).map((day) => ({
  day: String(day.day ?? '').slice(5),
  postulations: Number(day.postulations ?? 0),
  pqrs: Number(day.pqrs ?? 0)
}));
const trendMax = Math.max(1, ...trendRows.map((row) => Math.max(row.postulations, row.pqrs)));
const buildLinePoints = (values: number[]) => {
  if (values.length === 0) return '';
  if (values.length === 1) {
    const y = 90 - Math.round((values[0] / Math.max(1, trendMax)) * 70);
    return `6,${Math.max(12, Math.min(90, y))}`;
  }
  return values
    .map((value, index) => {
      const x = 6 + (index * 88) / (values.length - 1);
      const y = 90 - Math.round((value / Math.max(1, trendMax)) * 70);
      return `${x.toFixed(2)},${Math.max(12, Math.min(90, y)).toFixed(2)}`;
    })
    .join(' ');
};
const trendPostLinePoints = buildLinePoints(trendRows.map((row) => row.postulations));
const trendPqrsLinePoints = buildLinePoints(trendRows.map((row) => row.pqrs));
const distributionRows = [
  { label: 'Convocatorias', value: Number(analytics?.totals.convocatorias ?? 0), color: '#5AAC32' },
  { label: 'Competencias', value: Number(analytics?.totals.competencias ?? 0), color: '#E7D916' },
  { label: 'Clubes', value: Number(analytics?.totals.clubes ?? 0), color: '#6dad90' },
  { label: 'Documentos', value: Number(analytics?.totals.documents ?? 0), color: '#e2e8f0' }
];
const distributionTotal = distributionRows.reduce((acc, row) => acc + row.value, 0);
const distributionConic = (() => {
  if (!distributionTotal) return 'conic-gradient(#e2e8f0 0 100%)';
  let cursor = 0;
  const segments: string[] = [];
  for (const row of distributionRows) {
    const portion = (row.value / distributionTotal) * 100;
    const start = cursor;
    const end = cursor + portion;
    segments.push(`${row.color} ${start}% ${end}%`);
    cursor = end;
  }
  return `conic-gradient(${segments.join(', ')})`;
})();
const recentOperationalRows = [
  ...(data.competencias ?? []).slice(0, 2).map((item) => ({
    title: String(item.title ?? ''),
    context: `Competencia - ${String(item.location ?? 'Sin ubicación')}`,
    status: String(item.status ?? 'Confirmado'),
    value: String(item.date ?? '')
  })),
  ...(data.convocatorias ?? []).slice(0, 2).map((item) => ({
    title: String(item.title ?? ''),
    context: `Convocatoria - ${String(item.category ?? 'General')}`,
    status: String(item.status ?? 'Abierta'),
    value: `${String(item.openDate ?? '')} / ${String(item.closeDate ?? '')}`
  }))
].slice(0, 4);

const filteredPostulations = postulations.filter((p) => {
  if (postulationStatusFilter !== 'all' && p.status !== postulationStatusFilter) return false;
  if (!postulationQuery) return true;
  const q = postulationQuery.toLowerCase();
  return (
    p.id.toLowerCase().includes(q) ||
    p.athleteName.toLowerCase().includes(q) ||
    p.convocatoriaTitle.toLowerCase().includes(q) ||
    String(p.eventName ?? '').toLowerCase().includes(q) ||
    String(p.discipline ?? '').toLowerCase().includes(q) ||
    String(p.clubId).includes(q)
  );
});

const postulationStatusClass = (status: string) => {
  const value = status.toLowerCase();
  if (value.includes('aprobado') || value.includes('seleccionada') || value.includes('habilitada')) {
    return 'bg-emerald-100 text-emerald-700 border-emerald-200';
  }
  if (value.includes('rechazada') || value.includes('incompleta')) {
    return 'bg-red-100 text-red-700 border-red-200';
  }
  if (value.includes('revisión') || value.includes('postulada')) {
    return 'bg-amber-100 text-amber-700 border-amber-200';
  }
  return 'bg-slate-100 text-slate-700 border-slate-200';
};

const logoUrl = data.settings.logoUrl || '/logo.png';
const assignableRoles = ROLES.filter((role) => isSuperAdmin || role !== 'SUPERADMIN');
const linesFromArray = (items: string[] | undefined) => (items ?? []).join('\n');
const downloadsToLines = (downloads: Array<{ label: string; href: string }> | undefined) =>
  (downloads ?? []).map((item) => `${item.label}|${item.href}`).join('\n');
const resultsLinkFromDownloads = (downloads: Array<{ label: string; href: string }> | undefined) =>
  (downloads ?? []).find((item) => String(item.label ?? '').trim().toLowerCase() === 'resultados')?.href ?? '';
const slugFromHref = (href: string) => {
  const parts = String(href ?? '').split('/').filter(Boolean);
  return parts[parts.length - 1] ?? '';
};
const featuredNewsOrderMap = new Map<string, number>();
for (const [index, item] of (data.home.news ?? []).entries()) {
  const slug = slugFromHref(item.href);
  if (slug) featuredNewsOrderMap.set(slug, index + 1);
}
const currentFeaturedCompetenciaTitle = String(data.home?.eventHighlight?.sourceCompetenciaTitle ?? '');
const currentFeaturedEventDateTime = String(data.home?.eventHighlight?.eventDateTime ?? '');
const pageHeroMap = data.publicSite?.pageHeroes ?? {};
const rolePermissionData = isSuperAdmin
  ? await listRolePermissionMatrix()
  : {
      roles: [] as Array<{ name: (typeof ROLES)[number]; description: string }>,
      permissions: [] as Array<{ name: (typeof PERMISSIONS)[number]; description: string }>,
      matrix: new Map<(typeof ROLES)[number], Set<(typeof PERMISSIONS)[number]>>()
    };
const rolesMeta = rolePermissionData.roles;
const permissionsMeta = rolePermissionData.permissions;
const rolePermissionMatrix = rolePermissionData.matrix;
const clubsWithId = (data.clubs ?? [])
  .filter((club: any) => Number.isFinite(Number(club?.id)))
  .map((club: any) => ({ ...club, id: Number(club.id) }))
  .sort((a: any, b: any) => String(a.name ?? '').localeCompare(String(b.name ?? ''), 'es-CO'));
const clubNameById = new Map<number, string>(clubsWithId.map((club: any) => [Number(club.id), String(club.name ?? '')]));
const athleticsDisciplineNames = (athleticsCatalog.disciplines ?? []).map((item) => String(item.name ?? '')).filter(Boolean);
const athleticsEventNames = (athleticsCatalog.events ?? []).map((item) => String(item.name ?? '')).filter(Boolean);
const athleticsEventsCatalog = athleticsCatalog.events ?? [];
const laLigaContent = data.publicSite?.laLiga;
const laLigaPrinciplesRows = (laLigaContent?.principles?.length ? laLigaContent.principles : [{ icon: 'star', title: '', desc: '' }]);
const laLigaGovernanceRows = (laLigaContent?.governanceItems?.length ? laLigaContent.governanceItems : [{ label: '', title: '' }]);
const laLigaNormativeRows = (laLigaContent?.normativeDocs?.length ? laLigaContent.normativeDocs : [{ icon: 'menu_book', title: '', href: '/documentos' }]);
const rankingRows = (data.rankings?.length ? data.rankings : [
  {
    rank: '',
    athlete: '',
    club: '',
    mark: '',
    status: 'Verificado',
    imageUrl: '',
    category: '',
    discipline: '',
    gender: '',
    season: ''
  }
]) as typeof data.rankings;

const rawNavItems = [
  { id: 'dashboard', label: 'Dashboard', icon: 'dashboard' },
  { id: 'perfil', label: 'Mi Perfil', icon: 'person' },
  { id: 'settings', label: 'Configuración', icon: 'settings' },
  { id: 'liga-publica', label: 'Liga pública', icon: 'public' },
  { id: 'users', label: 'Usuarios', icon: 'manage_accounts' },
  { id: 'solicitudes', label: 'Solicitudes', icon: 'assignment' },
  { id: 'roles', label: 'Roles', icon: 'badge' },
  { id: 'permisos', label: 'Permisos', icon: 'verified_user' },
  { id: 'pqrs', label: 'PQRS', icon: 'support_agent' },
  { id: 'asambleas', label: 'Asambleas', icon: 'groups_2' },
  { id: 'alertas', label: 'Alertas', icon: 'warning' },
  { id: 'notificaciones', label: 'Notificaciones', icon: 'notifications' },
  { id: 'aprobaciones', label: 'Aprobaciones', icon: 'fact_check' },
  { id: 'auditoria', label: 'Auditoria', icon: 'manage_search' },
  { id: 'clubs', label: 'Clubes', icon: 'groups' },
  { id: 'athletes', label: 'Atletas', icon: 'directions_run' },
  { id: 'convocatorias', label: 'Convocatorias', icon: 'campaign' },
  { id: 'competencias', label: 'Competencias', icon: 'sports' },
  { id: 'ranking', label: 'Ranking', icon: 'leaderboard' },
  { id: 'results', label: 'Resultados', icon: 'fact_check' },
  { id: 'noticias', label: 'Noticias', icon: 'newspaper' },
  { id: 'blog', label: 'Blog', icon: 'article' },
  { id: 'documents', label: 'Documentos', icon: 'newspaper' }
];

const NAV_PERMS: Record<string, Parameters<typeof hasPermission>[1] | 'admin:all'> = {
  settings: 'site:manage',
  'liga-publica': 'site:manage',
  dashboard: 'records:manage',
  users: 'users:manage',
  solicitudes: 'approvals:manage',
  roles: 'super:all',
  permisos: 'super:all',
  pqrs: 'pqrs:manage',
  asambleas: 'asambleas:manage',
  alertas: 'records:manage',
  notificaciones: 'notificaciones:manage',
  aprobaciones: 'approvals:manage',
  auditoria: 'audit:read',
  noticias: 'news:manage',
  blog: 'blog:manage',
  stats: 'records:manage',
  clubs: 'clubs:manage',
  athletes: 'athletes:manage',
  competencias: 'competencias:manage',
  convocatorias: 'convocatorias:manage',
  results: 'results:manage',
  ranking: 'rankings:manage',
  documents: 'documents:manage'
};

const navItems = rawNavItems.filter((item) => {
  if (item.id === 'perfil') return user?.role !== 'SUPERADMIN';
  if (item.id === 'asambleas') return canViewAsambleasPanel;
  if (item.id === 'athletes') return canAccessAthletesTab;
  const r = user?.role;
  if (r === 'CLUB' && ['convocatorias', 'competencias', 'documents'].includes(item.id)) return true;
  const need = NAV_PERMS[item.id] ?? 'admin:all';
  if (need === 'admin:all') return hasPermission(user, 'admin:all');
  return hasPermission(user, need);
});

if (!navItems.some((n) => n.id === activeTab)) {
  const fallback = navItems[0]?.id ?? 'clubs';
  return Astro.redirect(`/admin?tab=${fallback}`);
}

const currentLabel = navItems.find((n) => n.id === activeTab)?.label ?? 'Dashboard';
---

<BaseLayout title="Admin | Liga de Atletismo" description="Panel administrativo">
  <AdminShell title={currentLabel} logoUrl={logoUrl} siteName={data.settings.siteName}>
    <div slot="nav" class="space-y-1">
      {navItems.map((item) => (
        <a
          href={`/admin?tab=${item.id}`}
          class={`nav-item ${activeTab === item.id ? 'active' : ''}`}
        >
          <span class="material-symbols-outlined">{item.icon}</span>
          <span>{item.label}</span>
        </a>
      ))}
    </div>

    <header
      slot="header"
      class="admin-header sticky top-0 z-40 flex items-center justify-between px-8 py-4"
    >
      <div class="flex items-center gap-3">
        <h2 class="admin-header-title">{currentLabel}</h2>
        <div class="admin-badge">En vivo</div>
      </div>

      <div class="flex items-center gap-4">
        {canManageApprovals ? (
          <a
            class="relative flex items-center justify-center w-10 h-10 rounded-full hover:bg-gray-50 transition-colors text-gray-400 hover:text-gray-600"
            href="/admin?tab=solicitudes"
            aria-label={`Solicitudes pendientes: ${registrationRadicados.length}`}
            title={`Solicitudes pendientes: ${registrationRadicados.length}`}
          >
            <span class="material-symbols-outlined">notifications</span>
            {registrationRadicados.length > 0 ? (
              <span class="absolute -top-1 -right-1 min-w-[18px] h-[18px] px-1 rounded-full bg-[#e7d916] text-[#2d3e50] text-[10px] font-black leading-[18px] text-center">
                {registrationRadicados.length > 99 ? '99+' : registrationRadicados.length}
              </span>
            ) : null}
          </a>
        ) : null}
        <a class="flex items-center justify-center w-10 h-10 rounded-full hover:bg-gray-50 transition-colors text-gray-400 hover:text-gray-600" href="/admin?tab=settings" aria-label="Configuración">
          <span class="material-symbols-outlined">settings</span>
        </a>
        <div class="flex items-center gap-3 border-l border-gray-200 pl-4">
          <div class="h-9 w-9 overflow-hidden rounded-full border border-gray-200 bg-gray-50">
            <img src={logoUrl} alt="Admin" class="h-full w-full object-contain" />
          </div>
          <a class="flex items-center justify-center w-10 h-10 rounded-full hover:bg-gray-50 transition-colors text-gray-400 hover:text-red-600" href="/admin/logout" aria-label="Cerrar sesión">
            <span class="material-symbols-outlined">logout</span>
          </a>
        </div>
      </div>
    </header>

    {saved ? (
      <div class="admin-alert admin-alert-success">
        <span class="material-symbols-outlined">check_circle</span>
        <span>{savedMessage}</span>
      </div>
    ) : null}

    {error ? (
      <div class="admin-alert admin-alert-error">
        <span class="material-symbols-outlined">error</span>
        <span>{errorMessage}</span>
      </div>
    ) : null}
    <div id="csv-export-modal" class="fixed inset-0 z-[110] hidden items-center justify-center bg-slate-900/40 p-4" aria-hidden="true">
      <div class="w-full max-w-md rounded-2xl bg-white shadow-2xl border border-slate-200">
        <div class="flex items-center justify-between border-b border-slate-100 px-5 py-4">
          <h5 id="csv-export-modal-title" class="text-base font-bold text-slate-800">Exportación CSV</h5>
          <button id="csv-export-modal-close" type="button" class="inline-flex h-9 w-9 items-center justify-center rounded-lg border border-slate-200 text-slate-500 hover:bg-slate-50" aria-label="Cerrar">
            <span class="material-symbols-outlined text-[18px]">close</span>
          </button>
        </div>
        <div class="px-5 py-4">
          <p id="csv-export-modal-message" class="text-sm text-slate-600">Estado de la exportación.</p>
        </div>
        <div class="flex justify-end border-t border-slate-100 px-5 py-4">
          <button id="csv-export-modal-ok" type="button" class="admin-btn admin-btn-primary">Entendido</button>
        </div>
      </div>
    </div>

    {contentTab === 'perfil' ? (
      <section class="admin-card">
        <div class="admin-card-header">
          <h4 class="admin-card-title">Mi Perfil</h4>
        </div>
        <div class="admin-card-body space-y-4">
          <p class="text-sm text-gray-500">
            {user?.role === 'CLUB'
              ? 'Puedes actualizar nombre y correo. En rol CLUB los cambios se envían a aprobación y solo se reflejan cuando sean aprobados.'
              : 'Puedes actualizar tu nombre y correo directamente desde esta vista.'}
          </p>
          <form method="POST" action="/api/admin/profile_request" class="grid gap-5 rounded-xl border border-gray-200 bg-white p-5">
            <h5 class="text-sm font-semibold text-gray-700">Información del Usuario</h5>
            <div class="grid gap-5 md:grid-cols-2">
              <div>
                <label class="admin-label">Nombre</label>
                <input class="admin-input" type="text" name="displayName" value={currentProfileUser?.displayName ?? ''} required />
              </div>
              <div>
                <label class="admin-label">Email</label>
                <input class="admin-input" type="email" name="email" value={currentProfileUser?.email ?? user?.email ?? ''} required />
              </div>
            </div>
            
            {user?.clubId ? (
              <>
                <h5 class="text-sm font-semibold text-gray-700 mt-4 border-t pt-4">Información del Club asociado</h5>
                <div class="grid gap-5 md:grid-cols-4">
                  {[data.clubs.find(c => c.id === user.clubId) || { name: '', municipality: '', coach: '' }].map(myClub => {
                    const selectedGeoMunicipality = municipalityGeoIndex.get(normalizeGeoText(myClub.municipality));
                    const selectedDepartmentCode = String(selectedGeoMunicipality?.departmentCode ?? '');
                    const selectedMunicipalityCode = String(selectedGeoMunicipality?.code ?? '');
                    return (
                    <>
                      <div class="md:col-span-1">
                          <label class="admin-label">Nombre del Club</label>
                          <input class="admin-input" name="clubName" value={myClub.name} required />
                      </div>
                      <div class="md:col-span-1">
                          <label class="admin-label">Departamento</label>
                          <select class="admin-input js-geo-country" data-geo-scope="profile-club" name="clubCountryIso2">
                            <option value="CO" selected>Colombia</option>
                          </select>
                          <select
                            class="admin-input mt-2 js-geo-department"
                            data-geo-scope="profile-club"
                            data-selected={selectedDepartmentCode}
                            name="clubDepartmentCode"
                            required
                          >
                            <option value="">Selecciona departamento</option>
                          </select>
                        </div>
                        <div class="md:col-span-1">
                          <label class="admin-label">Municipio</label>
                          <select
                            class="admin-input js-geo-municipality"
                            data-geo-scope="profile-club"
                            data-selected={selectedMunicipalityCode}
                            required
                          >
                            <option value="">Selecciona municipio</option>
                          </select>
                          <input
                            type="hidden"
                            name="clubMunicipality"
                            value={myClub.municipality}
                            class="js-geo-municipality-name"
                            data-geo-scope="profile-club"
                          />
                      </div>
                      <div class="md:col-span-1">
                          <label class="admin-label">Entrenador</label>
                          <input class="admin-input" name="clubCoach" value={myClub.coach} required />
                      </div>
                    </>
                  )})}
                </div>
              </>
            ) : null}
            
            <div class="flex items-center justify-end pt-2">
              <button class="admin-btn admin-btn-primary" type="submit">
                <span class="material-symbols-outlined">{user?.role === 'CLUB' ? 'send' : 'save'}</span>
                {user?.role === 'CLUB' ? 'Solicitar Cambio' : 'Guardar cambios'}
              </button>
            </div>
          </form>
        </div>
      </section>
    ) : null}

    {contentTab === 'settings' ? (
      <section class="admin-card">
        <div class="admin-card-header">
          <h4 class="admin-card-title">Configuración del Home</h4>
        </div>
        <div class="admin-card-body space-y-4">
          {!settingsView ? (
            <>
              <div class="rounded-xl border border-emerald-200 bg-emerald-50 p-4">
                <h5 class="text-sm font-semibold text-emerald-800">Módulos de configuración</h5>
                <p class="text-sm text-emerald-700 mt-1">Elige una tarjeta para abrir su formulario en una vista dedicada.</p>
              </div>
              <div class="grid gap-4 md:grid-cols-3">
                <a href="/admin?tab=settings&settingsView=general" class="group rounded-2xl border border-gray-200 bg-white p-5 shadow-sm transition hover:-translate-y-0.5 hover:border-emerald-300 hover:shadow-md">
                  <div class="flex items-start justify-between">
                    <span class="material-symbols-outlined text-emerald-600">tune</span>
                    <span class="text-xs font-semibold text-gray-400 group-hover:text-emerald-700">Abrir</span>
                  </div>
                  <h5 class="mt-3 text-base font-semibold text-gray-800">Ajustes Generales</h5>
                  <p class="mt-1 text-sm text-gray-500">Nombre del sitio, logo, colores y canales de contacto.</p>
                </a>
                <a href="/admin?tab=settings&settingsView=hero" class="group rounded-2xl border border-gray-200 bg-white p-5 shadow-sm transition hover:-translate-y-0.5 hover:border-emerald-300 hover:shadow-md">
                  <div class="flex items-start justify-between">
                    <span class="material-symbols-outlined text-emerald-600">wallpaper</span>
                    <span class="text-xs font-semibold text-gray-400 group-hover:text-emerald-700">Abrir</span>
                  </div>
                  <h5 class="mt-3 text-base font-semibold text-gray-800">Hero Principal</h5>
                  <p class="mt-1 text-sm text-gray-500">Título, subtítulo, badge e imagen principal de portada.</p>
                </a>
                <a href="/admin?tab=settings&settingsView=home" class="group rounded-2xl border border-gray-200 bg-white p-5 shadow-sm transition hover:-translate-y-0.5 hover:border-emerald-300 hover:shadow-md">
                  <div class="flex items-start justify-between">
                    <span class="material-symbols-outlined text-emerald-600">campaign</span>
                    <span class="text-xs font-semibold text-gray-400 group-hover:text-emerald-700">Abrir</span>
                  </div>
                  <h5 class="mt-3 text-base font-semibold text-gray-800">CTA y Patrocinadores</h5>
                  <p class="mt-1 text-sm text-gray-500">Botones de acción final y bloque de aliados/sponsors.</p>
                </a>
              </div>
            </>
          ) : null}

          {settingsView === 'general' ? (
            <div class="rounded-xl border border-gray-200 bg-gray-50 p-2">
              <div class="mb-2 px-3 py-2 flex items-center justify-between">
                <h5 class="text-sm font-semibold text-gray-700">1) Ajustes generales</h5>
                <a href="/admin?tab=settings" class="text-xs font-semibold text-emerald-700 hover:underline">← Volver a módulos</a>
              </div>
          <form method="POST" action="/api/admin/settings" encType="multipart/form-data" class="grid gap-5 rounded-xl border border-gray-200 bg-white p-5">
            <h5 class="text-sm font-semibold text-gray-700">1) Ajustes generales</h5>
            <div class="grid gap-5 md:grid-cols-2">
              <div>
                <label class="admin-label">Nombre del sitio</label>
                <input class="admin-input" type="text" name="siteName" value={data.settings.siteName} required />
              </div>
              <div>
                <label class="admin-label">Logo</label>
                <input class="admin-input" type="file" name="logoFile" accept="image/*" />
                <input type="hidden" name="logoUrl" value={data.settings.logoUrl} />
                {data.settings.logoUrl && (
                  <p class="text-xs text-gray-500 mt-1">Actual: {data.settings.logoUrl}</p>
                )}
              </div>
              <div>
                <label class="admin-label">Color principal</label>
                <div class="flex gap-2">
                  <input class="admin-input w-20 p-1" type="color" name="primaryColorPicker" value={data.settings.primaryColor} on:input={(e) => { const target = e.target as HTMLInputElement; (target.closest('form')?.querySelector('input[name=primaryColor]') as HTMLInputElement).value = target.value; }} />
                  <input class="admin-input flex-1" type="text" name="primaryColor" value={data.settings.primaryColor} required />
                </div>
              </div>
              <div>
                <label class="admin-label">Color secundario</label>
                <div class="flex gap-2">
                  <input class="admin-input w-20 p-1" type="color" name="secondaryColorPicker" value={data.settings.secondaryColor} on:input={(e) => { const target = e.target as HTMLInputElement; (target.closest('form')?.querySelector('input[name=secondaryColor]') as HTMLInputElement).value = target.value; }} />
                  <input class="admin-input flex-1" type="text" name="secondaryColor" value={data.settings.secondaryColor} required />
                </div>
              </div>
              <div>
                <label class="admin-label">Email de contacto</label>
                <input class="admin-input" type="email" name="contactEmail" value={data.settings.contactEmail} />
              </div>
              <div>
                <label class="admin-label">Teléfono de contacto</label>
                <input class="admin-input" type="text" name="contactPhone" value={data.settings.contactPhone} />
              </div>
              <div>
                <label class="admin-label">Instagram</label>
                <input class="admin-input" type="text" name="socialInstagram" value={data.settings.social?.instagram ?? ''} />
              </div>
              <div>
                <label class="admin-label">Facebook</label>
                <input class="admin-input" type="text" name="socialFacebook" value={data.settings.social?.facebook ?? ''} />
              </div>
              <div class="md:col-span-2">
                <label class="admin-label">X (Twitter)</label>
                <input class="admin-input" type="text" name="socialX" value={data.settings.social?.x ?? ''} />
              </div>
            </div>
            <div class="flex items-center justify-end pt-2">
              <button class="admin-btn admin-btn-primary" type="submit">
                <span class="material-symbols-outlined">save</span>
                Guardar ajustes generales
              </button>
            </div>
          </form>
            </div>
          ) : null}

          {settingsView === 'hero' ? (
            <div class="rounded-xl border border-gray-200 bg-gray-50 p-2">
              <div class="mb-2 px-3 py-2 flex items-center justify-between">
                <h5 class="text-sm font-semibold text-gray-700">2) Hero principal</h5>
                <a href="/admin?tab=settings" class="text-xs font-semibold text-emerald-700 hover:underline">← Volver a módulos</a>
              </div>
          <form method="POST" action="/api/admin/hero" encType="multipart/form-data" class="grid gap-5 rounded-xl border border-gray-200 bg-white p-5">
            <h5 class="text-sm font-semibold text-gray-700">2) Hero principal</h5>
