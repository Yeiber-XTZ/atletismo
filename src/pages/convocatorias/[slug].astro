---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar.astro';
import FooterKinetic from '../../components/FooterKinetic.astro';
import { getHomeData } from '../../lib/content';
import { slugify } from '../../lib/slug';
import { getClubByOwnerUserId } from '../../lib/clubs';
import { hasPermission } from '../../lib/rbac';
import { listAthletes } from '../../lib/athletes-admin';
import { listAthleticsCatalogs } from '../../lib/catalogs';

const data = await getHomeData();
const { settings, convocatorias } = data;

const slug = Astro.params.slug ?? '';
const convocatoria = (convocatorias ?? []).find((c) => slugify(c.title) === slug);
const user = Astro.locals.user;
const postulated = Astro.url.searchParams.get('postulated');
const error = Astro.url.searchParams.get('error');
let effectiveClubId = user?.clubId ? Number(user.clubId) : 0;
if (!effectiveClubId && user?.role === 'CLUB' && user?.id) {
  const ownedClub = await getClubByOwnerUserId(Number(user.id));
  effectiveClubId = ownedClub?.id ?? 0;
}

const postulationErrorMessage =
  error === 'duplicate'
    ? 'Ese atleta ya fue postulado en esa misma prueba para esta convocatoria.'
    : error === 'max_events_reached'
      ? 'El atleta ya alcanzó el maximo de pruebas permitidas por esta convocatoria.'
    : error === 'athlete_not_found'
      ? 'El atleta seleccionado no pertenece a tu club.'
      : error === 'invalid_event'
        ? 'Debes seleccionar una prueba valida.'
        : error === 'discipline_disabled'
          ? 'La disciplina del atleta no esta habilitada en esta convocatoria.'
          : error === 'event_disabled'
            ? 'La prueba seleccionada no esta habilitada en esta convocatoria.'
            : error === 'athlete_discipline_mismatch'
              ? 'El atleta no tiene registrada la disciplina de la prueba seleccionada.'
              : error === 'not_open'
                ? 'La convocatoria aun no esta habilitada para postulaciones.'
                : error === 'closed'
                  ? 'La convocatoria esta cerrada y ya no admite nuevas postulaciones.'
                  : error === 'not_found'
                    ? 'La convocatoria no fue encontrada.'
                    : error
                      ? 'No se pudo enviar la postulacion. Verifica los datos.'
                      : '';

if (!convocatoria) {
  Astro.response.status = 404;
}

const clubAthletes = user?.role === 'CLUB' && effectiveClubId
  ? await listAthletes({ clubId: effectiveClubId, status: 'active' })
  : [];

const convocatoriaEvents = Array.isArray((convocatoria as any)?.events)
  ? (convocatoria as any).events.map((item: string) => String(item).trim()).filter(Boolean)
  : [];
const fallbackAthleticsEvents = convocatoriaEvents.length === 0 ? (await listAthleticsCatalogs()).events.map((item) => item.name) : [];
const eventOptions = convocatoriaEvents.length > 0 ? convocatoriaEvents : fallbackAthleticsEvents;
const maxEventsPerAthlete = Math.max(1, Number((convocatoria as any)?.maxEventsPerAthlete ?? 1) || 1);
---
<BaseLayout
  title={`${convocatoria ? convocatoria.title : 'Convocatoria no encontrada'} | Liga de Atletismo del Choco`}
  description="Detalle de convocatoria y requisitos de postulacion."
>
  <Navbar siteName={settings.siteName} logoUrl={settings.logoUrl || '/logo.png'} />

  <main class="pt-[72px]">
    <section class="page-hero">
      <div class="container mx-auto px-6">
        <nav class="page-breadcrumb">
          <a href="/" class="page-breadcrumb-link">
            <span class="material-symbols-outlined text-sm">home</span>
            Inicio
          </a>
          <span class="material-symbols-outlined text-sm">chevron_right</span>
          <a href="/convocatorias" class="page-breadcrumb-link">Convocatorias</a>
          <span class="material-symbols-outlined text-sm">chevron_right</span>
          <span class="page-breadcrumb-current">{convocatoria ? convocatoria.title : 'No encontrada'}</span>
        </nav>
        <h1 class="page-title">{convocatoria ? convocatoria.title : 'Convocatoria no encontrada'}</h1>
        <p class="page-subtitle">
          {convocatoria ? convocatoria.description : 'La convocatoria solicitada no existe o fue retirada.'}
        </p>
      </div>
    </section>

    <section class="page-section">
      <div class="container mx-auto px-6">
        {convocatoria ? (
          <div class="grid gap-10 md:grid-cols-3">
            <div class="md:col-span-2">
              <h2 class="section-heading">Requisitos</h2>
              <ul class="list-disc pl-6 text-[var(--text-secondary)] leading-relaxed">
                {convocatoria.requirements.map((r) => (
                  <li>{r}</li>
                ))}
              </ul>

              <h2 class="section-heading mt-10">Categorias</h2>
              <div class="flex flex-wrap gap-2">
                {convocatoria.categories.map((c) => (
                  <span class="rounded-full bg-[#f1f5f9] px-3 py-1 text-sm font-semibold text-[#334155]">{c}</span>
                ))}
              </div>
            </div>
            <aside class="rounded-2xl border border-[var(--border)] bg-white p-6">
              <div class="text-xs font-bold uppercase tracking-wider text-[var(--tertiary)]">{convocatoria.audience}</div>
              <div class="mt-3 flex flex-wrap gap-2">
                <span
                  class:list={[
                    'rounded-full px-3 py-1 text-xs font-bold uppercase',
                    convocatoria.status === 'Abierta' ? 'bg-[#e8f5e0] text-[#006b1b]' : 'bg-[#f1f5f9] text-[#334155]'
                  ]}
                >
                  {convocatoria.status}
                </span>
              </div>
              <div class="mt-6 space-y-3 text-sm text-[var(--text-secondary)]">
                <div class="flex items-center gap-2">
                  <span class="material-symbols-outlined text-base">event</span>
                  Apertura: <strong class="text-[#0f172a]">{convocatoria.openDate}</strong>
                </div>
                <div class="flex items-center gap-2">
                  <span class="material-symbols-outlined text-base">event_busy</span>
                  Cierre: <strong class="text-[#0f172a]">{convocatoria.closeDate}</strong>
                </div>
                <div class="flex items-center gap-2">
                  <span class="material-symbols-outlined text-base">rule</span>
                  Maximo pruebas por deportista: <strong class="text-[#0f172a]">{maxEventsPerAthlete}</strong>
                </div>
              </div>

              <div class="mt-8 flex flex-col gap-3">
                {postulated ? (
                  <div class="rounded-lg border border-green-200 bg-green-50 p-3 text-sm text-green-700">
                    Postulacion enviada correctamente.
                  </div>
                ) : null}
                {error ? (
                  <div class="rounded-lg border border-red-200 bg-red-50 p-3 text-sm text-red-700">
                    {postulationErrorMessage}
                  </div>
                ) : null}

                {user?.role === 'CLUB' ? (
                  effectiveClubId ? (
                    <form method="POST" action="/api/dashboard/club/postulaciones" encType="multipart/form-data" class="grid gap-3">
                      <input type="hidden" name="clubId" value={String(effectiveClubId)} />
                      <input type="hidden" name="convocatoriaTitle" value={convocatoria.title} />
                      <input type="hidden" name="convocatoriaSlug" value={slug} />
                      <label class="form-label">Atleta *</label>
                      <select class="form-input" name="athleteId" required>
                        <option value="">Selecciona atleta</option>
                        {clubAthletes.map((athlete) => (
                          <option value={String(athlete.id)}>{athlete.fullName} - {athlete.documentType} {athlete.document}</option>
                        ))}
                      </select>
                      <label class="form-label">Prueba *</label>
                      <select class="form-input" name="eventName" required>
                        <option value="">Selecciona prueba</option>
                        {eventOptions.map((eventName) => (
                          <option value={eventName}>{eventName}</option>
                        ))}
                      </select>
                      <p class="text-xs text-[var(--text-muted)]">Esta convocatoria permite hasta {maxEventsPerAthlete} prueba(s) por deportista.</p>
                      <label class="form-label">Soporte documental (opcional)</label>
                      <input class="form-input" type="file" name="supportFile" accept=".pdf,.jpg,.jpeg,.png,.webp" />
                      <label class="form-label">Observaciones</label>
                      <textarea class="form-input min-h-[90px]" name="notes" placeholder="Opcional"></textarea>
                      <button type="submit" class="btn-primary">
                        <span class="material-symbols-outlined">send</span>
                        Postular atleta
                      </button>
                    </form>
                  ) : (
                    <div class="rounded-lg border border-yellow-200 bg-yellow-50 p-3 text-sm text-yellow-700">
                      <span class="material-symbols-outlined text-base align-middle mr-1">warning</span>
                      Tu cuenta no tiene un club asignado. Contacta al administrador de la Liga.
                    </div>
                  )
                ) : user?.role === 'SUPERADMIN' || user?.role === 'ADMIN' || user?.role === 'LIGA' ? (
                  <div class="grid gap-3">
                    <div class="rounded-lg border border-emerald-200 bg-emerald-50 p-3 text-sm text-emerald-800">
                      <span class="material-symbols-outlined text-base align-middle mr-1">admin_panel_settings</span>
                      Como administrador puedes revisar y gestionar todas las postulaciones a esta convocatoria.
                    </div>
                    <a href="/admin?tab=convocatorias" class="btn-primary">
                      <span class="material-symbols-outlined">manage_search</span>
                      Gestionar postulaciones
                    </a>
                  </div>
                ) : user && (hasPermission(user, 'assembly:self_panel') || hasPermission(user, 'asambleas:manage')) ? (
                  <div class="rounded-lg border border-blue-200 bg-blue-50 p-3 text-sm text-blue-700">
                    <span class="material-symbols-outlined text-base align-middle mr-1">visibility</span>
                    Puedes consultar el estado de esta convocatoria desde tu <a href="/admin?tab=convocatorias" class="font-semibold underline">panel</a>.
                  </div>
                ) : (
                  <>
                    <p class="text-sm text-[var(--text-secondary)]">Los clubes afiliados pueden postular atletas a esta convocatoria.</p>
                    <a href={`/login?next=${encodeURIComponent(`/convocatorias/${slug}`)}`} class="btn-primary">
                      <span class="material-symbols-outlined">login</span>
                      Iniciar sesion
                    </a>
                    <a href="/registro/club" class="btn-secondary">
                      <span class="material-symbols-outlined">person_add</span>
                      Registro Club
                    </a>
                  </>
                )}
              </div>
              <p class="mt-4 text-xs text-[var(--text-muted)]">El estado de tu postulacion se consulta en el panel del club.</p>
            </aside>
          </div>
        ) : (
          <div class="rounded-2xl border border-[var(--border)] bg-white p-8">
            <p class="text-[var(--text-secondary)]">Vuelve al listado de convocatorias para continuar.</p>
            <div class="mt-6">
              <a href="/convocatorias" class="btn-primary">Ver convocatorias</a>
            </div>
          </div>
        )}
      </div>
    </section>
  </main>

  <FooterKinetic siteName={settings.siteName} social={settings.social} />
</BaseLayout>
