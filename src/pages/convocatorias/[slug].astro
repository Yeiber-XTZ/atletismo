---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar.astro';
import FooterKinetic from '../../components/FooterKinetic.astro';
import { getHomeData } from '../../lib/content';
import { slugify } from '../../lib/slug';
import { getClubByOwnerUserId } from '../../lib/clubs';
import { listAthletes } from '../../lib/athletes-admin';
import { listAthleticsCatalogs } from '../../lib/catalogs';

const data = await getHomeData();
const { settings, convocatorias } = data;

const slug = Astro.params.slug ?? '';
const convocatoria = (convocatorias ?? []).find((c) => slugify(c.title) === slug);
const user = Astro.locals.user;
const postulated = Astro.url.searchParams.get('postulated');
const error = Astro.url.searchParams.get('error');

let effectiveClubId = user?.clubId ? Number(user.clubId) : 0;
if (!effectiveClubId && user?.role === 'CLUB' && user?.id) {
  const ownedClub = await getClubByOwnerUserId(Number(user.id));
  effectiveClubId = ownedClub?.id ?? 0;
}

const postulationErrorMessage =
  error === 'duplicate'
    ? 'Ese atleta ya fue postulado en esa misma prueba para esta convocatoria.'
    : error === 'max_events_reached'
      ? 'El atleta ya alcanzó el máximo de pruebas permitidas por esta convocatoria.'
      : error === 'athlete_not_found'
        ? 'El atleta seleccionado no pertenece a tu club.'
        : error === 'invalid_event'
          ? 'Debes seleccionar una prueba válida.'
          : error === 'discipline_disabled'
            ? 'La disciplina del atleta no está habilitada en esta convocatoria.'
            : error === 'event_disabled'
              ? 'La prueba seleccionada no está habilitada en esta convocatoria.'
              : error === 'athlete_discipline_mismatch'
                ? 'El atleta no tiene registrada la disciplina de la prueba seleccionada.'
                : error === 'invalid_batch'
                  ? 'La lista de postulaciones está vacía o tiene datos inválidos.'
                  : error === 'not_open'
                    ? 'La convocatoria aún no está habilitada para postulaciones.'
                    : error === 'closed'
                      ? 'La convocatoria está cerrada y ya no admite nuevas postulaciones.'
                      : error === 'not_found'
                        ? 'La convocatoria no fue encontrada.'
                        : error
                          ? 'No se pudo enviar la postulación. Verifica los datos.'
                          : '';

const postulationSuccessMessage = postulated
  ? Number(postulated) > 1
    ? `Se enviaron ${String(postulated)} postulaciones correctamente.`
    : 'Postulación enviada correctamente.'
  : '';

if (!convocatoria) {
  Astro.response.status = 404;
}

const clubAthletes = user?.role === 'CLUB' && effectiveClubId
  ? await listAthletes({ clubId: effectiveClubId, status: 'active' })
  : [];

const athleticsCatalog = await listAthleticsCatalogs();
const convocatoriaDisciplines = Array.isArray((convocatoria as any)?.disciplines)
  ? (convocatoria as any).disciplines.map((item: string) => String(item).trim()).filter(Boolean)
  : [];
const convocatoriaEvents = Array.isArray((convocatoria as any)?.events)
  ? (convocatoria as any).events.map((item: string) => String(item).trim()).filter(Boolean)
  : [];
const fallbackAthleticsEvents = convocatoriaEvents.length === 0 ? athleticsCatalog.events.map((item) => item.name) : [];
const eventOptions = convocatoriaEvents.length > 0 ? convocatoriaEvents : fallbackAthleticsEvents;

const normalizeText = (value: string) =>
  String(value ?? '')
    .trim()
    .toLowerCase()
    .normalize('NFD')
    .replace(/[\u0300-\u036f]/g, '');

const convocatoriaDisciplineNormSet = new Set(convocatoriaDisciplines.map((item) => normalizeText(item)).filter(Boolean));
const athleticsEventMap = new Map(
  (athleticsCatalog.events ?? []).map((item) => [String(item.name ?? '').trim().toLowerCase(), item])
);

const eventOptionsPayload = eventOptions
  .map((eventName) => {
    const eventItem = athleticsEventMap.get(String(eventName).toLowerCase());
    const discipline = String(eventItem?.disciplineName ?? '').trim();
    const gender = String((eventItem as any)?.gender ?? '').trim();
    return {
      name: String(eventName),
      discipline,
      gender
    };
  })
  .filter((item) => {
    if (convocatoriaEvents.length > 0) return true;
    return !convocatoriaDisciplines.length || !item.discipline || convocatoriaDisciplineNormSet.has(normalizeText(item.discipline));
  });

const effectiveConvocatoriaDisciplineNormSet = (() => {
  if (convocatoriaEvents.length > 0) {
    const fromEvents = new Set(
      eventOptionsPayload.map((item) => normalizeText(item.discipline)).filter(Boolean)
    );
    if (fromEvents.size > 0) return fromEvents;
  }
  return convocatoriaDisciplineNormSet;
})();

const maxEventsPerAthlete = Math.max(1, Number((convocatoria as any)?.maxEventsPerAthlete ?? 1) || 1);
const pageTitle = `${String(convocatoria ? convocatoria.title : 'Convocatoria no encontrada')} | Liga de Atletismo del Chocó`;
const statusText = String(convocatoria?.status ?? '').toLowerCase();
const isStatusOpen = statusText.includes('abierta') || statusText.includes('open');
const todayIso = new Date().toISOString().slice(0, 10);
const openDate = String(convocatoria?.openDate ?? '').slice(0, 10);
const closeDate = String(convocatoria?.closeDate ?? '').slice(0, 10);
const byDateOpen = (!openDate || openDate <= todayIso) && (!closeDate || closeDate >= todayIso);
const convocatoriaIsOpen = Boolean(convocatoria) && (isStatusOpen || byDateOpen);

const summaryText = String(convocatoria?.description ?? '').trim();
const summaryShort = summaryText.length > 280 ? `${summaryText.slice(0, 280).trim()}...` : summaryText;
const needsSummaryExpand = summaryText.length > 280;

const isClubUser = user?.role === 'CLUB';
const canPostulate = isClubUser && effectiveClubId > 0 && convocatoriaIsOpen;
---

<BaseLayout title={pageTitle} description="Detalle de convocatoria y panel de postulación.">
  <Navbar siteName={settings.siteName} logoUrl={settings.logoUrl || '/logo.png'} />

  <main class="convx-page">
    {convocatoria ? (
      <section class="convx-wrap container">
        <nav class="convx-breadcrumb">
          <a href="/">Inicio</a>
          <span>›</span>
          <a href="/convocatorias">Convocatorias</a>
          <span>›</span>
          <span class="current">{convocatoria.title}</span>
        </nav>

        <header class="convx-topcard">
          <div class="topcard-left">
            <p class="kicker">CONVOCATORIA OFICIAL</p>
            <h1>{convocatoria.title}</h1>
            <p class="audience">{convocatoria.audience || 'Público general'}</p>
            <div class="meta-pills">
              <span class:list={['pill-status', convocatoriaIsOpen ? 'open' : 'closed']}>
                {convocatoriaIsOpen ? 'ABIERTA' : 'CERRADA'}
              </span>
              <span class="pill-info">Apertura: {convocatoria.openDate || '-'}</span>
              <span class="pill-info">Cierre: {convocatoria.closeDate || '-'}</span>
              <span class="pill-info">Máx. pruebas: {maxEventsPerAthlete}</span>
            </div>
          </div>
          <a href="/convocatorias" class="topcard-cta">VER CONVOCATORIAS</a>
        </header>

        <div class="convx-grid">
          <div class="convx-main">
            <article class="panel white">
              <h2>RESUMEN OPERATIVO</h2>
              <p class="desc js-summary-short">{summaryShort || 'Sin descripción disponible.'}</p>
              {needsSummaryExpand ? (
                <>
                  <p class="desc js-summary-full hidden">{summaryText}</p>
                  <button type="button" class="summary-toggle js-summary-toggle">Ver más</button>
                </>
              ) : null}

              <div class="sep"></div>
              <h2>REQUISITOS</h2>
              {convocatoria.requirements.length > 0 ? (
                <ul class="req-grid">
                  {convocatoria.requirements.map((item) => (
                    <li>{item}</li>
                  ))}
                </ul>
              ) : (
                <p class="empty">No hay requisitos publicados.</p>
              )}

              <div class="sep"></div>
              <h2>CATEGORÍAS HABILITADAS</h2>
              <div class="chips">
                {convocatoria.categories.length > 0 ? (
                  convocatoria.categories.map((item) => <span class="chip">{item}</span>)
                ) : (
                  <p class="empty">No hay categorías configuradas.</p>
                )}
              </div>
            </article>

            {isClubUser ? (
              <article id="postulacion-club-panel" class="panel white post-panel">
                <div class="post-title">
                  <h3>POSTULAR DEPORTISTAS</h3>
                  <p>CARGA RÁPIDA TIPO CARRITO: AGREGA ATLETAS Y PRUEBAS ANTES DE ENVIAR.</p>
                </div>

                {!effectiveClubId ? (
                  <div class="alert warn">
                    Tu usuario CLUB no tiene un club asociado. Solicita al administrador la asociación del club para poder postular.
                  </div>
                ) : !convocatoriaIsOpen ? (
                  <div class="alert warn">
                    Esta convocatoria no está abierta para postulaciones en este momento.
                  </div>
                ) : null}

                {effectiveClubId ? (
                  <form
                    method="POST"
                    action="/api/dashboard/club/postulaciones"
                    class="post-form js-postulation-batch-form"
                    data-convocatoria-disciplines={Array.from(effectiveConvocatoriaDisciplineNormSet).join('|')}
                  >
                    <input type="hidden" name="clubId" value={String(effectiveClubId)} />
                    <input type="hidden" name="convocatoriaTitle" value={convocatoria.title} />
                    <input type="hidden" name="convocatoriaSlug" value={slug} />
                    <input type="hidden" name="entriesJson" value="[]" class="js-post-entries-json" />

                    <section class="zone selector">
                      <div class="zone-head"><span>1</span><h4>SELECTOR RÁPIDO</h4></div>

                      <div class="selector-grid">
                        <div>
                          <label class="label">Atleta *</label>
                          <select class="input js-post-athlete" disabled={!canPostulate}>
                            <option value="">Selecciona atleta</option>
                            {clubAthletes.map((athlete) => (
                              <option
                                value={String(athlete.id)}
                                data-disciplines={(Array.isArray(athlete.disciplines) ? athlete.disciplines : []).join('|')}
                                data-sex-code={String(athlete.sexCode ?? athlete.gender ?? '')}
                                data-club-name={String(athlete.clubName ?? '')}
                              >
                                {athlete.fullName} - {athlete.documentType} {athlete.document}
                              </option>
                            ))}
                          </select>
                          <p class="field-error js-post-error-athlete hidden"></p>
                        </div>

                        <div>
                          <label class="label">Pruebas *</label>
                          <div class="event-picker js-post-events-picker" data-max-events={String(maxEventsPerAthlete)}>
                            <button
                              type="button"
                              class="js-post-events-toggle dd-toggle"
                              aria-expanded="false"
                              disabled={!canPostulate}
                            >
                              <span>Selecciona pruebas</span>
                              <span class="js-post-events-count dd-count">0</span>
                            </button>
                            <div class="js-post-events-panel hidden dd-panel">
                              <div class="js-post-events-list events-list">
                                {eventOptionsPayload.map((eventItem) => (
                                  <label class="event-opt">
                                    <input
                                      type="checkbox"
                                      class="js-post-event-check"
                                      value={eventItem.name}
                                      data-discipline={eventItem.discipline}
                                      data-gender={eventItem.gender}
                                      disabled={!canPostulate}
                                    />
                                    <span>{eventItem.name}</span>
                                  </label>
                                ))}
                              </div>
                            </div>
                          </div>
                          <p class="field-error js-post-error-events hidden"></p>
                        </div>
                      </div>

                      <p class="help">Esta convocatoria permite hasta {maxEventsPerAthlete} prueba(s) por deportista.</p>
                      <button type="button" class="btn-secondary js-post-add-item opacity-50 pointer-events-none" disabled={!canPostulate}>
                        + AGREGAR A LISTA
                      </button>
                      <p class="js-post-warning inline-warning hidden"></p>
                    </section>

                    <section class="zone list">
                      <div class="zone-head split">
                        <div><span>2</span><h4>CARRITO DE POSTULACIONES</h4></div>
                        <span class="count-badge"><strong class="js-post-count">0</strong> en lista</span>
                      </div>
                      <div class="overflow-x-auto js-post-list-wrapper hidden">
                        <table class="cart-table">
                          <thead>
                            <tr>
                              <th>Deportista</th>
                              <th>Club</th>
                              <th>Pruebas</th>
                              <th>Acciones</th>
                            </tr>
                          </thead>
                          <tbody class="js-post-table-body"></tbody>
                        </table>
                      </div>
                      <p class="empty js-post-empty">No hay atletas/pruebas agregados.</p>
                      <p class="ready">Listas para enviar: <strong class="js-post-ready-count">0</strong></p>
                    </section>

                    <section class="zone submit">
                      <div class="zone-head"><span>3</span><h4>CONFIRMAR Y ENVIAR</h4></div>
                      <button type="submit" class="btn-primary js-post-submit submit-desktop" disabled={!canPostulate} data-locked={!canPostulate ? '1' : '0'}>
                        ENVIAR POSTULACIONES (<span class="js-post-submit-count">0</span>)
                      </button>
                      <p class="muted">Solo se enviarán las filas válidas del carrito.</p>
                    </section>

                    <button type="submit" class="btn-primary js-post-submit js-post-submit-mobile submit-mobile" disabled={!canPostulate} data-locked={!canPostulate ? '1' : '0'}>
                      ENVIAR (<span class="js-post-submit-count">0</span>)
                    </button>
                  </form>
                ) : null}
              </article>
            ) : null}
          </div>

          <aside class="convx-side">
            <article class="panel side-tech">
              <h3>FICHA TÉCNICA</h3>
              <div class="side-sep"></div>
              <ul>
                <li><strong>PÚBLICO OBJETIVO</strong><p>{convocatoria.audience || 'General'}</p></li>
                <li><strong>ESTADO</strong><p>{convocatoriaIsOpen ? 'Abierta' : 'Cerrada'}</p></li>
                <li><strong>VENTANA DE POSTULACIÓN</strong><p>{convocatoria.openDate || '-'} a {convocatoria.closeDate || '-'}</p></li>
                <li><strong>MÁXIMO POR ATLETA</strong><p>{maxEventsPerAthlete} prueba(s)</p></li>
              </ul>
              <div class="ref">REF: CONV-2026-CH-001</div>
            </article>

            <article class="panel side-guide">
              <h3>GUÍA RÁPIDA</h3>
              <ol>
                <li><span>01</span><p>Selecciona un atleta activo de tu club.</p></li>
                <li><span>02</span><p>Elige sus pruebas habilitadas.</p></li>
                <li><span>03</span><p>Agrega al carrito y revisa el resumen.</p></li>
                <li><span>04</span><p>Envía todas las postulaciones en un solo clic.</p></li>
              </ol>
            </article>

            <article class="panel side-tip">
              <h3>CONSEJO PRO</h3>
              <p>Recuerda que los atletas con más de 2 años de inactividad requieren validación especial por parte del comité técnico antes de procesar el carrito.</p>
            </article>
          </aside>
        </div>

        {!isClubUser ? (
          <div class="panel white" style="margin-top:18px;">
            <div class="alert warn" style="margin:0;">Inicia sesión como CLUB para habilitar la postulación de atletas.</div>
          </div>
        ) : null}
      </section>
    ) : (
      <section class="convx-wrap container" style="padding-top:20px;padding-bottom:36px;">
        <article class="panel white not-found">
          <h2>Convocatoria no encontrada</h2>
          <p>La URL solicitada no corresponde a una convocatoria vigente.</p>
          <a href="/convocatorias" class="btn-secondary">VOLVER A CONVOCATORIAS</a>
        </article>
      </section>
    )}

    {(postulationSuccessMessage || postulationErrorMessage) && (
      <div class="fixed inset-0 z-[130] hidden items-center justify-center bg-black/45 px-4 js-post-result-modal" data-type={postulationSuccessMessage ? 'success' : 'error'} data-message={postulationSuccessMessage || postulationErrorMessage}>
        <div class="w-full max-w-md rounded-2xl border border-green-100 bg-white p-6 shadow-2xl">
          <div class="flex items-start gap-3">
            <span class="material-symbols-outlined text-3xl js-post-result-icon">check_circle</span>
            <div class="min-w-0">
              <h3 class="text-lg font-black uppercase tracking-tight text-[var(--brand-primary)] js-post-result-title"></h3>
              <p class="mt-2 text-sm text-gray-700 js-post-result-message"></p>
            </div>
          </div>
          <div class="mt-6 flex justify-end">
            <button type="button" class="btn-primary js-post-result-close">ENTENDIDO</button>
          </div>
        </div>
      </div>
    )}
  </main>

  <FooterKinetic siteName={settings.siteName} social={settings.social} />

  <script is:inline>
    (() => {
      const initSummaryToggle = () => {
        const toggleBtn = document.querySelector('.js-summary-toggle');
        const shortEl = document.querySelector('.js-summary-short');
        const fullEl = document.querySelector('.js-summary-full');
        if (!(toggleBtn instanceof HTMLButtonElement) || !(shortEl instanceof HTMLElement) || !(fullEl instanceof HTMLElement)) return;
        if (toggleBtn.dataset.bound === '1') return;
        toggleBtn.dataset.bound = '1';
        toggleBtn.addEventListener('click', () => {
          const expanded = !fullEl.classList.contains('hidden');
          fullEl.classList.toggle('hidden', expanded);
          shortEl.classList.toggle('hidden', !expanded);
          toggleBtn.textContent = expanded ? 'Ver más' : 'Ver menos';
        });
      };

      const initPostulationBatchForm = () => {
        const form = document.querySelector('.js-postulation-batch-form');
        if (!(form instanceof HTMLFormElement)) return;
        if (form.dataset.bound === '1') return;
        form.dataset.bound = '1';
        try {
          const athletesSelect = form.querySelector('.js-post-athlete');
          const eventsToggle = form.querySelector('.js-post-events-toggle');
          const eventsPanel = form.querySelector('.js-post-events-panel');
          const eventsCount = form.querySelector('.js-post-events-count');
          const addBtn = form.querySelector('.js-post-add-item');
          const warningEl = form.querySelector('.js-post-warning');
          const athleteErrorEl = form.querySelector('.js-post-error-athlete');
          const eventsErrorEl = form.querySelector('.js-post-error-events');
          const tableBody = form.querySelector('.js-post-table-body');
          const listWrapper = form.querySelector('.js-post-list-wrapper');
          const emptyEl = form.querySelector('.js-post-empty');
          const countEl = form.querySelector('.js-post-count');
          const readyEl = form.querySelector('.js-post-ready-count');
          const submitCountEls = form.querySelectorAll('.js-post-submit-count');
          const entriesInput = form.querySelector('.js-post-entries-json');
          const submitBtns = form.querySelectorAll('.js-post-submit');
          const checks = Array.from(form.querySelectorAll('.js-post-event-check'));
          const picker = form.querySelector('.js-post-events-picker');

          if (!(athletesSelect instanceof HTMLSelectElement) || !(eventsToggle instanceof HTMLButtonElement) || !(eventsPanel instanceof HTMLElement) || !(eventsCount instanceof HTMLElement) || !(addBtn instanceof HTMLButtonElement) || !(warningEl instanceof HTMLElement) || !(athleteErrorEl instanceof HTMLElement) || !(eventsErrorEl instanceof HTMLElement) || !(tableBody instanceof HTMLElement) || !(listWrapper instanceof HTMLElement) || !(emptyEl instanceof HTMLElement) || !(countEl instanceof HTMLElement) || !(readyEl instanceof HTMLElement) || !(entriesInput instanceof HTMLInputElement) || !picker) {
            return;
          }

          const maxEventsPerAthlete = Math.max(1, Number(picker.getAttribute('data-max-events') || '1') || 1);
          const submitBtnsList = Array.from(submitBtns).filter((btn) => btn instanceof HTMLButtonElement);
          const state = [];
          const norm = (value) => String(value || '').trim().toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '');
          const getSelectedEventNames = () => checks.filter((check) => check.checked).map((check) => String(check.value || '').trim()).filter(Boolean);

          const setFieldError = (el, text) => {
            if (!el) return;
            el.textContent = text;
            el.classList.toggle('hidden', !text);
          };
          const setWarning = (text) => {
            warningEl.textContent = text;
            warningEl.classList.toggle('hidden', !text);
          };
          const syncEventsCount = () => {
            eventsCount.textContent = String(getSelectedEventNames().length);
          };
          const syncAddButtonState = () => {
            const canAdd = Boolean(String(athletesSelect.value || '').trim()) && getSelectedEventNames().length > 0;
            addBtn.disabled = !canAdd;
            addBtn.classList.toggle('opacity-50', !canAdd);
            addBtn.classList.toggle('pointer-events-none', !canAdd);
          };
          const updateStateOutputs = () => {
            entriesInput.value = JSON.stringify(state.map((item) => ({ athleteId: item.athleteId, eventName: item.eventName })));
            const count = state.length;
            countEl.textContent = String(count);
            readyEl.textContent = String(count);
            submitCountEls.forEach((el) => {
              if (el instanceof HTMLElement) el.textContent = String(count);
            });
            const hasItems = count > 0;
            listWrapper.classList.toggle('hidden', !hasItems);
            emptyEl.classList.toggle('hidden', hasItems);
            submitBtnsList.forEach((btn) => {
              const locked = btn.getAttribute('data-locked') === '1';
              btn.disabled = locked || !hasItems;
            });
          };
          const renderList = () => {
            tableBody.innerHTML = '';
            state.forEach((item, index) => {
              const tr = document.createElement('tr');
              tr.innerHTML = `<td>${item.athleteLabel}</td><td>${item.clubName || '-'}</td><td>${item.eventName}</td><td class="actions-cell"><button type="button" class="btn-danger" data-remove="${index}">Quitar</button></td>`;
              tableBody.appendChild(tr);
            });
          };

          eventsToggle.addEventListener('click', () => {
            const expanded = eventsToggle.getAttribute('aria-expanded') === 'true';
            eventsToggle.setAttribute('aria-expanded', expanded ? 'false' : 'true');
            eventsPanel.classList.toggle('hidden', expanded);
          });

          checks.forEach((check) => {
            check.addEventListener('change', () => {
              if (getSelectedEventNames().length > maxEventsPerAthlete) {
                check.checked = false;
                setWarning(`Solo puedes seleccionar hasta ${String(maxEventsPerAthlete)} prueba(s) por atleta.`);
              } else {
                setWarning('');
              }
              syncEventsCount();
              syncAddButtonState();
              setFieldError(eventsErrorEl, '');
            });
          });

          athletesSelect.addEventListener('change', () => {
            setFieldError(athleteErrorEl, '');
            setWarning('');
            syncAddButtonState();
          });

          tableBody.addEventListener('click', (event) => {
            const target = event.target;
            if (!(target instanceof HTMLElement)) return;
            const btn = target.closest('[data-remove]');
            if (!(btn instanceof HTMLElement)) return;
            const index = Number(btn.getAttribute('data-remove'));
            if (Number.isNaN(index) || index < 0 || index >= state.length) return;
            state.splice(index, 1);
            renderList();
            updateStateOutputs();
          });

          addBtn.addEventListener('click', () => {
            const athleteId = String(athletesSelect.value || '').trim();
            const selectedEventNames = getSelectedEventNames();
            if (!athleteId) {
              setFieldError(athleteErrorEl, 'Selecciona un atleta.');
              return;
            }
            if (!selectedEventNames.length) {
              setFieldError(eventsErrorEl, 'Selecciona al menos una prueba.');
              return;
            }
            const athleteOption = athletesSelect.selectedOptions?.[0];
            const athleteLabel = athleteOption ? athleteOption.textContent || athleteId : athleteId;
            const clubName = athleteOption ? String(athleteOption.getAttribute('data-club-name') || '') : '';
            let selectedCountForAthlete = state.filter((item) => String(item.athleteId) === athleteId).length;
            let addedAny = false;

            for (const eventName of selectedEventNames) {
              if (selectedCountForAthlete >= maxEventsPerAthlete) {
                setWarning(`Este deportista ya tiene ${String(maxEventsPerAthlete)} prueba(s) en la lista.`);
                break;
              }
              const exists = state.some((item) => String(item.athleteId) === athleteId && norm(item.eventName) === norm(eventName));
              if (exists) continue;
              state.push({ athleteId, athleteLabel: String(athleteLabel), clubName, eventName });
              selectedCountForAthlete += 1;
              addedAny = true;
            }

            checks.forEach((check) => {
              check.checked = false;
            });
            syncEventsCount();
            syncAddButtonState();
            if (addedAny) {
              setFieldError(athleteErrorEl, '');
              setFieldError(eventsErrorEl, '');
              setWarning('');
            }
            renderList();
            updateStateOutputs();
          });

          renderList();
          updateStateOutputs();
          syncEventsCount();
          syncAddButtonState();
        } catch (err) {
          console.error('[convocatorias] postulation batch script failed', err);
        }
      };

      const initPostulationResultModal = () => {
        const modal = document.querySelector('.js-post-result-modal');
        if (!(modal instanceof HTMLElement)) return;
        if (modal.dataset.bound === '1') return;
        modal.dataset.bound = '1';

        const message = String(modal.dataset.message || '').trim();
        const type = String(modal.dataset.type || '').trim();
        if (!message || !type) return;

        const titleEl = modal.querySelector('.js-post-result-title');
        const messageEl = modal.querySelector('.js-post-result-message');
        const iconEl = modal.querySelector('.js-post-result-icon');
        const closeBtn = modal.querySelector('.js-post-result-close');
        if (!(titleEl instanceof HTMLElement) || !(messageEl instanceof HTMLElement) || !(iconEl instanceof HTMLElement) || !(closeBtn instanceof HTMLButtonElement)) return;

        const isSuccess = type === 'success';
        titleEl.textContent = isSuccess ? 'Postulación enviada' : 'No se pudo enviar';
        messageEl.textContent = message;
        iconEl.textContent = isSuccess ? 'check_circle' : 'error';
        iconEl.classList.toggle('text-green-600', isSuccess);
        iconEl.classList.toggle('text-red-600', !isSuccess);

        modal.classList.remove('hidden');
        modal.classList.add('flex');

        try {
          const url = new URL(window.location.href);
          url.searchParams.delete('postulated');
          url.searchParams.delete('error');
          window.history.replaceState({}, '', `${String(url.pathname)}${String(url.search)}${String(url.hash)}`);
        } catch {}

        const closeModal = () => {
          modal.classList.add('hidden');
          modal.classList.remove('flex');
        };

        closeBtn.addEventListener('click', closeModal);
        modal.addEventListener('click', (event) => {
          const target = event.target;
          if (!(target instanceof Element)) return;
          if (target === modal) closeModal();
        });
      };

      initSummaryToggle();
      initPostulationBatchForm();
      initPostulationResultModal();
      document.addEventListener('DOMContentLoaded', initSummaryToggle);
      document.addEventListener('DOMContentLoaded', initPostulationBatchForm);
      document.addEventListener('DOMContentLoaded', initPostulationResultModal);
      document.addEventListener('astro:page-load', initSummaryToggle);
      document.addEventListener('astro:page-load', initPostulationBatchForm);
      document.addEventListener('astro:page-load', initPostulationResultModal);
    })();
  </script>

