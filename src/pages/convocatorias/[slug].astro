---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar.astro';
import FooterKinetic from '../../components/FooterKinetic.astro';
import { getHomeData } from '../../lib/content';
import { slugify } from '../../lib/slug';
import { getClubByOwnerUserId } from '../../lib/clubs';
import { listAthletes } from '../../lib/athletes-admin';
import { listAthleticsCatalogs } from '../../lib/catalogs';

const data = await getHomeData();
const { settings, convocatorias } = data;

const slug = Astro.params.slug ?? '';
const convocatoria = (convocatorias ?? []).find((c) => slugify(c.title) === slug);
const user = Astro.locals.user;
const postulated = Astro.url.searchParams.get('postulated');
const error = Astro.url.searchParams.get('error');

let effectiveClubId = user?.clubId ? Number(user.clubId) : 0;
if (!effectiveClubId && user?.role === 'CLUB' && user?.id) {
  const ownedClub = await getClubByOwnerUserId(Number(user.id));
  effectiveClubId = ownedClub?.id ?? 0;
}

const postulationErrorMessage =
  error === 'duplicate'
    ? 'Ese atleta ya fue postulado en esa misma prueba para esta convocatoria.'
    : error === 'max_events_reached'
      ? 'El atleta ya alcanzó el máximo de pruebas permitidas por esta convocatoria.'
      : error === 'athlete_not_found'
        ? 'El atleta seleccionado no pertenece a tu club.'
        : error === 'invalid_event'
          ? 'Debes seleccionar una prueba válida.'
          : error === 'discipline_disabled'
            ? 'La disciplina del atleta no está habilitada en esta convocatoria.'
            : error === 'event_disabled'
              ? 'La prueba seleccionada no está habilitada en esta convocatoria.'
              : error === 'athlete_discipline_mismatch'
                ? 'El atleta no tiene registrada la disciplina de la prueba seleccionada.'
                : error === 'invalid_batch'
                  ? 'La lista de postulaciones está vacía o tiene datos inválidos.'
                  : error === 'not_open'
                    ? 'La convocatoria aún no está habilitada para postulaciones.'
                    : error === 'closed'
                      ? 'La convocatoria está cerrada y ya no admite nuevas postulaciones.'
                      : error === 'not_found'
                        ? 'La convocatoria no fue encontrada.'
                        : error
                          ? 'No se pudo enviar la postulación. Verifica los datos.'
                          : '';

const postulationSuccessMessage = postulated
  ? Number(postulated) > 1
    ? `Se enviaron ${String(postulated)} postulaciones correctamente.`
    : 'Postulación enviada correctamente.'
  : '';

if (!convocatoria) {
  Astro.response.status = 404;
}

const clubAthletes = user?.role === 'CLUB' && effectiveClubId
  ? await listAthletes({ clubId: effectiveClubId, status: 'active' })
  : [];

const athleticsCatalog = await listAthleticsCatalogs();
const convocatoriaDisciplines = Array.isArray((convocatoria as any)?.disciplines)
  ? (convocatoria as any).disciplines.map((item: string) => String(item).trim()).filter(Boolean)
  : [];
const convocatoriaEvents = Array.isArray((convocatoria as any)?.events)
  ? (convocatoria as any).events.map((item: string) => String(item).trim()).filter(Boolean)
  : [];
const fallbackAthleticsEvents = convocatoriaEvents.length === 0 ? athleticsCatalog.events.map((item) => item.name) : [];
const eventOptions = convocatoriaEvents.length > 0 ? convocatoriaEvents : fallbackAthleticsEvents;
const normalizeText = (value: string) =>
  String(value ?? '')
    .trim()
    .toLowerCase()
    .normalize('NFD')
    .replace(/[\u0300-\u036f]/g, '');
const convocatoriaDisciplineNormSet = new Set(convocatoriaDisciplines.map((item) => normalizeText(item)).filter(Boolean));
const athleticsEventMap = new Map(
  (athleticsCatalog.events ?? []).map((item) => [String(item.name ?? '').trim().toLowerCase(), item])
);
const eventOptionsPayload = eventOptions
  .map((eventName) => {
    const eventItem = athleticsEventMap.get(String(eventName).toLowerCase());
    const discipline = String(eventItem?.disciplineName ?? '').trim();
    const gender = String((eventItem as any)?.gender ?? '').trim();
    return {
      name: String(eventName),
      discipline,
      gender
    };
  })
  .filter((item) => {
    if (convocatoriaEvents.length > 0) return true;
    return !convocatoriaDisciplines.length || !item.discipline || convocatoriaDisciplineNormSet.has(normalizeText(item.discipline));
  });

const effectiveConvocatoriaDisciplineNormSet = (() => {
  if (convocatoriaEvents.length > 0) {
    const fromEvents = new Set(
      eventOptionsPayload.map((item) => normalizeText(item.discipline)).filter(Boolean)
    );
    if (fromEvents.size > 0) return fromEvents;
  }
  return convocatoriaDisciplineNormSet;
})();

const maxEventsPerAthlete = Math.max(1, Number((convocatoria as any)?.maxEventsPerAthlete ?? 1) || 1);
const pageTitle = `${String(convocatoria ? convocatoria.title : 'Convocatoria no encontrada')} | Liga de Atletismo del Chocó`;
const statusText = String(convocatoria?.status ?? '').toLowerCase();
const isStatusOpen = statusText.includes('abierta') || statusText.includes('open');
const todayIso = new Date().toISOString().slice(0, 10);
const openDate = String(convocatoria?.openDate ?? '').slice(0, 10);
const closeDate = String(convocatoria?.closeDate ?? '').slice(0, 10);
const byDateOpen = (!openDate || openDate <= todayIso) && (!closeDate || closeDate >= todayIso);
const convocatoriaIsOpen = Boolean(convocatoria) && (isStatusOpen || byDateOpen);
const summaryText = String(convocatoria?.description ?? '').trim();
const summaryShort = summaryText.length > 220 ? `${summaryText.slice(0, 220).trim()}...` : summaryText;
const needsSummaryExpand = summaryText.length > 220;
const isClubUser = user?.role === 'CLUB';
const canPostulate = isClubUser && effectiveClubId > 0 && convocatoriaIsOpen;
---

<BaseLayout title={pageTitle} description="Detalle de convocatoria y panel de postulación.">
  <Navbar siteName={settings.siteName} logoUrl={settings.logoUrl || '/logo.png'} />

  <main class="convocatoria-page">
    {convocatoria ? (
      <>
        <section class="convocatoria-tech-bar-wrap">
          <div class="container">
            <div class="convocatoria-tech-bar">
              <nav class="convocatoria-breadcrumb">
                <a href="/" class="convocatoria-breadcrumb-link">
                  <span class="material-symbols-outlined text-sm">home</span>
                  Inicio
                </a>
                <span class="material-symbols-outlined text-sm">chevron_right</span>
                <a href="/convocatorias" class="convocatoria-breadcrumb-link">Convocatorias</a>
                <span class="material-symbols-outlined text-sm">chevron_right</span>
                <span class="convocatoria-breadcrumb-current">{convocatoria.title}</span>
              </nav>

              <div class="tech-main">
                <div class="tech-title-wrap">
                  <p class="tech-kicker">Convocatoria oficial</p>
                  <h1 class="tech-title">{convocatoria.title}</h1>
                  <p class="tech-audience">{convocatoria.audience || 'Público general'}</p>
                </div>
                <div class="tech-meta">
                  <span class:list={['tech-status', convocatoriaIsOpen ? 'status-open' : 'status-closed']}>
                    {convocatoriaIsOpen ? 'Abierta' : 'Cerrada'}
                  </span>
                  <span class="tech-chip">
                    <span class="material-symbols-outlined">event_upcoming</span>
                    Apertura: {convocatoria.openDate || '-'}
                  </span>
                  <span class="tech-chip">
                    <span class="material-symbols-outlined">event_busy</span>
                    Cierre: {convocatoria.closeDate || '-'}
                  </span>
                  <span class="tech-chip">
                    <span class="material-symbols-outlined">rule</span>
                    Máx. pruebas: {maxEventsPerAthlete}
                  </span>
                </div>
                <a href="/convocatorias" class="btn-secondary tech-secondary-cta">Ver convocatorias</a>
              </div>
            </div>
          </div>
        </section>

        <section class="convocatoria-section">
          <div class="container">
            <div class="convocatoria-grid">
              <div class="convocatoria-main-stack">
                <article class="content-card">
                  <h2>Resumen operativo</h2>
                  <p class="desc-break js-summary-short">{summaryShort || 'Sin descripción disponible.'}</p>
                  {needsSummaryExpand ? (
                    <>
                      <p class="desc-break js-summary-full hidden">{summaryText}</p>
                      <button type="button" class="summary-toggle-btn js-summary-toggle">Ver más</button>
                    </>
                  ) : null}
                </article>

                <article class="content-card">
                  <h2>Requisitos</h2>
                  {convocatoria.requirements.length > 0 ? (
                    <ul class="requirement-list">
                      {convocatoria.requirements.map((r) => (
                        <li>{r}</li>
                      ))}
                    </ul>
                  ) : (
                    <p class="empty-copy">No hay requisitos publicados.</p>
                  )}
                </article>

                <article class="content-card">
                  <h2>Categorías habilitadas</h2>
                  <div class="category-grid">
                    {convocatoria.categories.length > 0 ? (
                      convocatoria.categories.map((c) => <span class="category-pill">{c}</span>)
                    ) : (
                      <p class="empty-copy">No hay categorías configuradas.</p>
                    )}
                  </div>
                </article>

                {isClubUser ? (
                  <article id="postulacion-club-panel" class="post-card">
                    <div class="post-head">
                      <h3>Postular deportistas</h3>
                      <p>Carga rápida tipo carrito: agrega atletas y pruebas antes de enviar.</p>
                    </div>

                    {!effectiveClubId ? (
                      <div class="alert warn">
                        Tu usuario CLUB no tiene un club asociado. Solicita al administrador la asociación del club para poder postular.
                      </div>
                    ) : !convocatoriaIsOpen ? (
                      <div class="alert warn">
                        Esta convocatoria no está abierta para postulaciones en este momento.
                      </div>
                    ) : null}

                    {effectiveClubId ? (
                      <form
                        method="POST"
                        action="/api/dashboard/club/postulaciones"
                        class="post-form-grid js-postulation-batch-form"
                        data-convocatoria-disciplines={Array.from(effectiveConvocatoriaDisciplineNormSet).join('|')}
                      >
                        <input type="hidden" name="clubId" value={String(effectiveClubId)} />
                        <input type="hidden" name="convocatoriaTitle" value={convocatoria.title} />
                        <input type="hidden" name="convocatoriaSlug" value={slug} />
                        <input type="hidden" name="entriesJson" value="[]" class="js-post-entries-json" />

                        <section class="post-zone post-zone-picker">
                          <h4>1) Selector rápido</h4>
                          <label class="form-label">Atleta *</label>
                          <select class="form-input js-post-athlete" disabled={!canPostulate}>
                            <option value="">Selecciona atleta</option>
                            {clubAthletes.map((athlete) => (
                              <option
                                value={String(athlete.id)}
                                data-disciplines={(Array.isArray(athlete.disciplines) ? athlete.disciplines : []).join('|')}
                                data-sex-code={String(athlete.sexCode ?? athlete.gender ?? '')}
                                data-club-name={String(athlete.clubName ?? '')}
                              >
                                {athlete.fullName} - {athlete.documentType} {athlete.document}
                              </option>
                            ))}
                          </select>
                          <p class="field-error js-post-error-athlete hidden"></p>

                          <label class="form-label">Pruebas *</label>
                          <div class="event-picker js-post-events-picker" data-max-events={String(maxEventsPerAthlete)}>
                            <button
                              type="button"
                              class="js-post-events-toggle flex w-full items-center justify-between px-3 py-2 text-sm text-gray-700"
                              aria-expanded="false"
                              disabled={!canPostulate}
                            >
                              <span>Selecciona pruebas</span>
                              <span class="js-post-events-count inline-flex min-w-[28px] items-center justify-center rounded-full bg-amber-100 px-2 py-0.5 text-xs font-semibold text-amber-800">0</span>
                            </button>
                            <div class="js-post-events-panel hidden max-h-52 overflow-auto border-t border-gray-300 p-2">
                              <div class="grid gap-1 js-post-events-list">
                                {eventOptionsPayload.map((eventItem) => (
                                  <label class="inline-flex items-center gap-2 rounded-md px-2 py-1 text-xs font-semibold text-gray-800 hover:bg-white">
                                    <input
                                      type="checkbox"
                                      class="js-post-event-check"
                                      value={eventItem.name}
                                      data-discipline={eventItem.discipline}
                                      data-gender={eventItem.gender}
                                      disabled={!canPostulate}
                                    />
                                    <span>{eventItem.name}</span>
                                  </label>
                                ))}
                              </div>
                            </div>
                          </div>
                          <p class="field-help">Esta convocatoria permite hasta {maxEventsPerAthlete} prueba(s) por deportista.</p>
                          <p class="field-error js-post-error-events hidden"></p>

                          <button type="button" class="btn-secondary js-post-add-item opacity-50 pointer-events-none" disabled={!canPostulate}>
                            <span class="material-symbols-outlined">add</span>
                            Agregar a lista
                          </button>
                          <p class="js-post-warning hidden rounded-md border border-amber-200 bg-amber-50 px-2 py-2 text-xs text-amber-800"></p>
                        </section>

                        <section class="post-zone post-zone-list">
                          <div class="post-zone-header">
                            <h4>2) Carrito de postulaciones</h4>
                            <span class="post-count-pill"><strong class="js-post-count">0</strong> en lista</span>
                          </div>
                          <div class="overflow-x-auto js-post-list-wrapper hidden">
                            <table class="min-w-full text-sm">
                              <thead>
                                <tr class="text-left text-gray-500">
                                  <th class="px-2 py-1">Deportista</th>
                                  <th class="px-2 py-1">Club</th>
                                  <th class="px-2 py-1 text-center">Pruebas</th>
                                  <th class="px-2 py-1 text-right">Acciones</th>
                                </tr>
                              </thead>
                              <tbody class="js-post-table-body"></tbody>
                            </table>
                          </div>
                          <p class="text-xs text-[var(--text-muted)] js-post-empty">No hay atletas/pruebas agregados.</p>
                          <p class="post-ready">Listas para enviar: <strong class="js-post-ready-count">0</strong></p>
                        </section>

                        <section class="post-zone post-zone-submit">
                          <h4>3) Confirmar y enviar</h4>
                          <button type="submit" class="btn-primary js-post-submit post-submit-desktop" disabled={!canPostulate}>
                            <span class="material-symbols-outlined">send</span>
                            Enviar postulaciones (<span class="js-post-submit-count">0</span>)
                          </button>
                          <p class="muted-copy">Solo se enviarán las filas válidas del carrito.</p>
                        </section>

                        <button type="submit" class="btn-primary js-post-submit js-post-submit-mobile post-submit-mobile" disabled={!canPostulate}>
                          <span class="material-symbols-outlined">send</span>
                          Enviar (<span class="js-post-submit-count">0</span>)
                        </button>
                      </form>
                    ) : null}
                  </article>
                ) : null}
              </div>

              <aside class="convocatoria-side">
                <article class="quick-side-card">
                  <h3>Ficha técnica</h3>
                  <ul class="quick-side-list">
                    <li>
                      <span class="material-symbols-outlined">groups</span>
                      <div>
                        <strong>Público objetivo</strong>
                        <p>{convocatoria.audience || 'General'}</p>
                      </div>
                    </li>
                    <li>
                      <span class="material-symbols-outlined">verified</span>
                      <div>
                        <strong>Estado</strong>
                        <p>{convocatoriaIsOpen ? 'Abierta' : 'Cerrada'}</p>
                      </div>
                    </li>
                    <li>
                      <span class="material-symbols-outlined">calendar_month</span>
                      <div>
                        <strong>Ventana de postulación</strong>
                        <p>{convocatoria.openDate || '-'} a {convocatoria.closeDate || '-'}</p>
                      </div>
                    </li>
                    <li>
                      <span class="material-symbols-outlined">flag</span>
                      <div>
                        <strong>Máximo por atleta</strong>
                        <p>{maxEventsPerAthlete} prueba(s)</p>
                      </div>
                    </li>
                  </ul>
                </article>

                <article class="quick-side-card help-card">
                  <h3>Guía rápida</h3>
                  <ol>
                    <li>Selecciona un atleta activo de tu club.</li>
                    <li>Elige sus pruebas habilitadas.</li>
                    <li>Agrega al carrito y revisa el resumen.</li>
                    <li>Envía todas las postulaciones en un solo clic.</li>
                  </ol>
                </article>
              </aside>
            </div>
          </div>
        </section>
      </>
    ) : (
      <section class="convocatoria-section">
        <div class="container">
          <div class="not-found-card">
            <h2>Convocatoria no encontrada</h2>
            <p>Vuelve al listado de convocatorias para continuar.</p>
            <a href="/convocatorias" class="btn-primary">Ver convocatorias</a>
          </div>
        </div>
      </section>
    )}

    <div class="fixed inset-0 z-[90] hidden items-center justify-center bg-black/50 p-4 js-post-modal">
      <div class="w-full max-w-lg rounded-xl bg-white p-4 shadow-xl">
        <div class="mb-3 flex items-center justify-between">
          <h4 class="text-sm font-semibold text-gray-800 js-post-modal-title">Pruebas del deportista</h4>
          <button type="button" class="rounded-md border border-gray-200 px-2 py-1 text-xs js-post-modal-close">Cerrar</button>
        </div>
        <div class="max-h-72 overflow-auto rounded-md border border-gray-200 p-2">
          <ul class="list-disc pl-5 text-sm text-gray-700 js-post-modal-list"></ul>
        </div>
      </div>
    </div>
    <div
      class="fixed inset-0 z-[95] hidden items-center justify-center bg-black/50 p-4 js-post-result-modal"
      data-message={postulationSuccessMessage || postulationErrorMessage}
      data-type={postulationSuccessMessage ? 'success' : postulationErrorMessage ? 'error' : ''}
    >
      <div class="w-full max-w-md rounded-xl bg-white p-5 shadow-xl">
        <div class="flex items-start gap-3">
          <span class="material-symbols-outlined js-post-result-icon text-2xl">check_circle</span>
          <div class="flex-1">
            <h4 class="text-base font-semibold text-[#0f172a] js-post-result-title">Resultado</h4>
            <p class="mt-1 text-sm text-gray-700 js-post-result-message"></p>
          </div>
        </div>
        <div class="mt-4 flex justify-end">
          <button type="button" class="rounded-md border border-gray-300 px-3 py-1.5 text-sm js-post-result-close">Entendido</button>
        </div>
      </div>
    </div>
  </main>

  <FooterKinetic siteName={settings.siteName} social={settings.social} />

  <script is:inline>
    (() => {
      const normalize = (value) =>
        String(value || '')
          .trim()
          .toLowerCase()
          .normalize('NFD')
          .replace(/[\u0300-\u036f]/g, '');

      const parsePipeSet = (raw) =>
        new Set(
          String(raw || '')
            .split(/[|,;\n\r]+/g)
            .map((item) => normalize(item))
            .filter(Boolean)
        );

      const initSummaryToggle = () => {
        const btn = document.querySelector('.js-summary-toggle');
        const shortEl = document.querySelector('.js-summary-short');
        const fullEl = document.querySelector('.js-summary-full');
        if (!(btn instanceof HTMLButtonElement) || !(shortEl instanceof HTMLElement) || !(fullEl instanceof HTMLElement)) return;

        let expanded = false;
        btn.addEventListener('click', () => {
          expanded = !expanded;
          shortEl.classList.toggle('hidden', expanded);
          fullEl.classList.toggle('hidden', !expanded);
          btn.textContent = expanded ? 'Ver menos' : 'Ver más';
        });
      };

      const initPostulationBatchForm = () => {
        try {
          const form = document.querySelector('.js-postulation-batch-form');
          if (!(form instanceof HTMLFormElement)) return;
          if (form.dataset.postBatchBound === '1') return;
          form.dataset.postBatchBound = '1';

          const athleteSelect = form.querySelector('.js-post-athlete');
          const eventsPicker = form.querySelector('.js-post-events-picker');
          const eventsToggle = form.querySelector('.js-post-events-toggle');
          const eventsPanel = form.querySelector('.js-post-events-panel');
          const eventsCount = form.querySelector('.js-post-events-count');
          const eventChecks = Array.from(form.querySelectorAll('.js-post-event-check'));
          const addBtn = form.querySelector('.js-post-add-item');
          const entriesInput = form.querySelector('.js-post-entries-json');
          const listTableWrapper = form.querySelector('.js-post-list-wrapper');
          const tableBody = form.querySelector('.js-post-table-body');
          const emptyText = form.querySelector('.js-post-empty');
          const countEl = form.querySelector('.js-post-count');
          const readyCountEl = form.querySelector('.js-post-ready-count');
          const submitButtons = Array.from(form.querySelectorAll('.js-post-submit')).filter((el) => el instanceof HTMLButtonElement);
          const submitCountEls = Array.from(form.querySelectorAll('.js-post-submit-count')).filter((el) => el instanceof HTMLElement);
          const warningEl = form.querySelector('.js-post-warning');
          const athleteErrorEl = form.querySelector('.js-post-error-athlete');
          const eventsErrorEl = form.querySelector('.js-post-error-events');
          const modal = document.querySelector('.js-post-modal');
          const modalTitle = document.querySelector('.js-post-modal-title');
          const modalList = document.querySelector('.js-post-modal-list');
          const modalClose = document.querySelector('.js-post-modal-close');

          if (
            !(athleteSelect instanceof HTMLSelectElement) ||
            !(eventsPicker instanceof HTMLElement) ||
            !(eventsToggle instanceof HTMLButtonElement) ||
            !(eventsPanel instanceof HTMLElement) ||
            !(eventsCount instanceof HTMLElement) ||
            !(addBtn instanceof HTMLButtonElement) ||
            !(entriesInput instanceof HTMLInputElement) ||
            !(listTableWrapper instanceof HTMLElement) ||
            !(tableBody instanceof HTMLElement) ||
            !(emptyText instanceof HTMLElement) ||
            !(countEl instanceof HTMLElement) ||
            !(readyCountEl instanceof HTMLElement) ||
            submitButtons.length === 0 ||
            !(warningEl instanceof HTMLElement) ||
            !(athleteErrorEl instanceof HTMLElement) ||
            !(eventsErrorEl instanceof HTMLElement) ||
            !(modal instanceof HTMLElement) ||
            !(modalTitle instanceof HTMLElement) ||
            !(modalList instanceof HTMLElement) ||
            !(modalClose instanceof HTMLButtonElement)
          ) return;

          const maxEventsPerAthlete = Math.max(1, Number(eventsPicker.dataset.maxEvents ?? 1) || 1);
          const convocatoriaDisciplines = parsePipeSet(form.dataset.convocatoriaDisciplines || '');
          const athleteMap = new Map(
            Array.from(athleteSelect.options)
              .filter((opt) => String(opt.value || '').trim())
              .map((opt) => [
                String(opt.value),
                {
                  label: String(opt.textContent || '').trim(),
                  fullName: String(opt.textContent || '').split(' - ')[0]?.trim() || String(opt.textContent || '').trim(),
                  clubName: String(opt.dataset.clubName || ''),
                  sexCode: normalize(opt.dataset.sexCode || ''),
                  disciplines: parsePipeSet(opt.dataset.disciplines || '')
                }
              ])
          );
          const allEvents = eventChecks
            .filter((input) => input instanceof HTMLInputElement)
            .map((input) => ({
              input,
              name: String(input.value || '').trim(),
              discipline: normalize(input.dataset.discipline || ''),
              gender: normalize(input.dataset.gender || '')
            }));

          const state = [];
          const norm = normalize;
          let pickerDisabled = true;

          const setFieldError = (el, message) => {
            const text = String(message || '').trim();
            if (!text) {
              el.textContent = '';
              el.classList.add('hidden');
              return;
            }
            el.textContent = text;
            el.classList.remove('hidden');
          };

          const setWarning = (message) => {
            const text = String(message || '').trim();
            if (!text) {
              warningEl.textContent = '';
              warningEl.classList.add('hidden');
              return;
            }
            warningEl.textContent = text;
            warningEl.classList.remove('hidden');
          };

          const setAddDisabled = (disabled) => {
            addBtn.disabled = Boolean(disabled);
            addBtn.classList.toggle('opacity-50', Boolean(disabled));
            addBtn.classList.toggle('pointer-events-none', Boolean(disabled));
          };

          const setPickerOpen = (open) => {
            eventsPanel.classList.toggle('hidden', !open);
            eventsToggle.setAttribute('aria-expanded', open ? 'true' : 'false');
          };

          const clearEventChecks = () => {
            allEvents.forEach((item) => {
              item.input.checked = false;
            });
          };

          const getSelectedEventNames = () =>
            allEvents
              .filter((item) => !item.input.disabled && item.input.checked)
              .map((item) => item.name)
              .filter(Boolean);

          const syncEventsCount = () => {
            const count = getSelectedEventNames().length;
            eventsCount.textContent = String(count);
            setFieldError(eventsErrorEl, count === 0 ? 'Selecciona al menos una prueba.' : '');
          };

          const syncAddButtonState = () => {
            const hasAthlete = Boolean(String(athleteSelect.value || '').trim());
            const hasEventsSelected = getSelectedEventNames().length > 0;
            setFieldError(athleteErrorEl, hasAthlete ? '' : 'Selecciona un atleta.');
            setAddDisabled(!hasAthlete || pickerDisabled || !hasEventsSelected);
          };

          const genderBucket = (sexCode) => {
            const value = norm(sexCode);
            if (!value) return 'unknown';
            if (value.includes('f') || value.includes('muj') || value.includes('femen')) return 'f';
            if (value.includes('m') || value.includes('hom') || value.includes('mascul')) return 'm';
            return 'unknown';
          };

          const eventMatchesGender = (eventGender, athleteSexCode) => {
            const eg = norm(eventGender);
            const ag = genderBucket(athleteSexCode);
            if (!eg || eg === 'todos' || eg === 'mixto' || eg.includes('mix')) return true;
            if (ag === 'f') return eg.includes('fem');
            if (ag === 'm') return eg.includes('masc');
            return true;
          };

          const renderEventsByAthlete = () => {
            const athleteId = String(athleteSelect.value || '');
            const athlete = athleteMap.get(athleteId);
            const disciplines = athlete?.disciplines instanceof Set ? athlete.disciplines : new Set();

            clearEventChecks();
            syncEventsCount();
            if (!athleteId || !athlete) {
              pickerDisabled = true;
              allEvents.forEach((item) => {
                const row = item.input.closest('label') || item.input.parentElement;
                item.input.disabled = true;
                if (row instanceof HTMLElement) row.style.display = '';
              });
              syncAddButtonState();
              setWarning('Selecciona un deportista para ver sus pruebas habilitadas.');
              return;
            }

            const hasEnabledDiscipline =
              convocatoriaDisciplines.size === 0 ||
              Array.from(disciplines).some(
                (discipline) =>
                  convocatoriaDisciplines.has(discipline) ||
                  Array.from(convocatoriaDisciplines).some(
                    (enabledDiscipline) => discipline.includes(enabledDiscipline) || enabledDiscipline.includes(discipline)
                  )
              );

            if (!hasEnabledDiscipline) {
              pickerDisabled = true;
              allEvents.forEach((item) => {
                const row = item.input.closest('label') || item.input.parentElement;
                item.input.disabled = true;
                if (row instanceof HTMLElement) row.style.display = 'none';
              });
              syncAddButtonState();
              setWarning('La disciplina del deportista no está habilitada en esta convocatoria.');
              return;
            }

            const allowedEvents = allEvents.filter((eventItem) => {
              if (!eventItem.discipline) return false;
              const disciplineMatch =
                disciplines.has(eventItem.discipline) ||
                Array.from(disciplines).some(
                  (discipline) => discipline.includes(eventItem.discipline) || eventItem.discipline.includes(discipline)
                );
              if (!disciplineMatch) return false;
              return eventMatchesGender(eventItem.gender, athlete.sexCode);
            });

            allEvents.forEach((eventItem) => {
              const row = eventItem.input.closest('label') || eventItem.input.parentElement;
              const visible = allowedEvents.includes(eventItem);
              eventItem.input.disabled = !visible;
              eventItem.input.checked = false;
              if (row instanceof HTMLElement) row.style.display = visible ? '' : 'none';
            });

            pickerDisabled = allowedEvents.length === 0;
            syncEventsCount();
            syncAddButtonState();
            if (allowedEvents.length === 0) {
              setWarning('No hay pruebas habilitadas para las disciplinas de este deportista.');
            } else {
              setWarning('');
            }
          };

          const updateStateOutputs = () => {
            entriesInput.value = JSON.stringify(
              state.map((item) => ({ athleteId: Number(item.athleteId), eventName: item.eventName }))
            );
            countEl.textContent = String(state.length);
            readyCountEl.textContent = String(state.length);
            submitCountEls.forEach((el) => (el.textContent = String(state.length)));
            emptyText.classList.toggle('hidden', state.length > 0);
            submitButtons.forEach((btn) => {
              btn.disabled = state.length === 0;
            });
          };

          const renderList = () => {
            tableBody.innerHTML = '';
            const grouped = new Map();
            state.forEach((item) => {
              const key = String(item.athleteId);
              if (!grouped.has(key)) grouped.set(key, []);
              grouped.get(key).push(item.eventName);
            });

            Array.from(grouped.entries()).forEach(([athleteId, eventNames]) => {
              const athlete = athleteMap.get(String(athleteId));
              const tr = document.createElement('tr');
              tr.className = 'border-t border-gray-200';

              const tdAthlete = document.createElement('td');
              tdAthlete.className = 'px-2 py-2 text-gray-700';
              tdAthlete.textContent = String(athlete?.fullName || athlete?.label || athleteId);

              const tdClub = document.createElement('td');
              tdClub.className = 'px-2 py-2 text-gray-600';
              tdClub.textContent = String(athlete?.clubName || '-');

              const tdCount = document.createElement('td');
              tdCount.className = 'px-2 py-2 text-center';
              const countBtn = document.createElement('button');
              countBtn.type = 'button';
              countBtn.className = 'rounded px-2 py-1 text-sm font-semibold text-blue-700 hover:bg-blue-50';
              countBtn.textContent = String(eventNames.length);

              const tdActions = document.createElement('td');
              tdActions.className = 'px-2 py-2 text-right';
              const removeBtn = document.createElement('button');
              removeBtn.type = 'button';
              removeBtn.className = 'rounded bg-red-50 px-2 py-1 text-[11px] text-red-700';
              removeBtn.textContent = 'Quitar';
              removeBtn.addEventListener('click', () => {
                for (let i = state.length - 1; i >= 0; i -= 1) {
                  if (String(state[i].athleteId) === String(athleteId)) state.splice(i, 1);
                }
                renderList();
                updateStateOutputs();
              });

              tdActions.appendChild(removeBtn);
              tdCount.appendChild(countBtn);
              tr.appendChild(tdAthlete);
              tr.appendChild(tdClub);
              tr.appendChild(tdCount);
              tr.appendChild(tdActions);
              tableBody.appendChild(tr);

              countBtn.addEventListener('click', () => {
                modalTitle.textContent = `Pruebas de ${String(athlete?.fullName || athlete?.label || athleteId)}`;
                modalList.innerHTML = '';
                eventNames.forEach((eventName) => {
                  const li = document.createElement('li');
                  li.textContent = String(eventName);
                  modalList.appendChild(li);
                });
                modal.classList.remove('hidden');
                modal.classList.add('flex');
              });
            });

            listTableWrapper.classList.toggle('hidden', grouped.size === 0);
          };

          athleteSelect.addEventListener('change', () => {
            renderEventsByAthlete();
          });

          eventsToggle.addEventListener('click', (event) => {
            event.preventDefault();
            if (pickerDisabled) return;
            const isOpen = !eventsPanel.classList.contains('hidden');
            setPickerOpen(!isOpen);
          });

          allEvents.forEach((eventItem) => {
            eventItem.input.addEventListener('change', () => {
              if (maxEventsPerAthlete <= 1 && eventItem.input.checked) {
                allEvents.forEach((other) => {
                  if (other !== eventItem) other.input.checked = false;
                });
              }
              syncEventsCount();
              syncAddButtonState();
            });
          });

          document.addEventListener('click', (event) => {
            const target = event.target;
            if (!(target instanceof Element)) return;
            if (!eventsPicker.contains(target)) setPickerOpen(false);
          });

          modalClose.addEventListener('click', () => {
            modal.classList.add('hidden');
            modal.classList.remove('flex');
          });

          modal.addEventListener('click', (event) => {
            const target = event.target;
            if (!(target instanceof Element)) return;
            if (target === modal) {
              modal.classList.add('hidden');
              modal.classList.remove('flex');
            }
          });

          addBtn.addEventListener('click', () => {
            const athleteId = String(athleteSelect.value || '').trim();
            const selectedEventNames = getSelectedEventNames();
            if (!athleteId) {
              setFieldError(athleteErrorEl, 'Selecciona un atleta.');
              return;
            }
            if (selectedEventNames.length === 0) {
              setFieldError(eventsErrorEl, 'Selecciona al menos una prueba.');
              return;
            }

            const athlete = athleteMap.get(athleteId);
            if (!athlete) return;

            let selectedCountForAthlete = state.filter((item) => String(item.athleteId) === athleteId).length;
            let addedAny = false;

            for (const eventName of selectedEventNames) {
              if (selectedCountForAthlete >= maxEventsPerAthlete) {
                setWarning(`Este deportista ya tiene ${String(maxEventsPerAthlete)} prueba(s) en la lista.`);
                break;
              }

              const exists = state.some((item) => String(item.athleteId) === athleteId && norm(item.eventName) === norm(eventName));
              if (exists) continue;

              state.push({
                athleteId,
                athleteLabel: String(athlete.label || athleteId),
                eventName
              });
              selectedCountForAthlete += 1;
              addedAny = true;
            }

            clearEventChecks();
            syncEventsCount();
            syncAddButtonState();
            if (addedAny) {
              setFieldError(athleteErrorEl, '');
              setFieldError(eventsErrorEl, '');
              setWarning('');
            }
            renderList();
            updateStateOutputs();
          });

          renderEventsByAthlete();
          renderList();
          updateStateOutputs();
        } catch (err) {
          console.error('[convocatorias] postulation batch script failed', err);
        }
      };

      const initPostulationResultModal = () => {
        const modal = document.querySelector('.js-post-result-modal');
        if (!(modal instanceof HTMLElement)) return;
        if (modal.dataset.bound === '1') return;
        modal.dataset.bound = '1';

        const message = String(modal.dataset.message || '').trim();
        const type = String(modal.dataset.type || '').trim();
        if (!message || !type) return;

        const titleEl = modal.querySelector('.js-post-result-title');
        const messageEl = modal.querySelector('.js-post-result-message');
        const iconEl = modal.querySelector('.js-post-result-icon');
        const closeBtn = modal.querySelector('.js-post-result-close');
        if (
          !(titleEl instanceof HTMLElement) ||
          !(messageEl instanceof HTMLElement) ||
          !(iconEl instanceof HTMLElement) ||
          !(closeBtn instanceof HTMLButtonElement)
        ) return;

        const isSuccess = type === 'success';
        titleEl.textContent = isSuccess ? 'Postulación enviada' : 'No se pudo enviar';
        messageEl.textContent = message;
        iconEl.textContent = isSuccess ? 'check_circle' : 'error';
        iconEl.classList.toggle('text-green-600', isSuccess);
        iconEl.classList.toggle('text-red-600', !isSuccess);

        modal.classList.remove('hidden');
        modal.classList.add('flex');

        try {
          const url = new URL(window.location.href);
          url.searchParams.delete('postulated');
          url.searchParams.delete('error');
          window.history.replaceState({}, '', `${String(url.pathname)}${String(url.search)}${String(url.hash)}`);
        } catch {}

        const closeModal = () => {
          modal.classList.add('hidden');
          modal.classList.remove('flex');
        };

        closeBtn.addEventListener('click', closeModal);
        modal.addEventListener('click', (event) => {
          const target = event.target;
          if (!(target instanceof Element)) return;
          if (target === modal) closeModal();
        });
      };

      initSummaryToggle();
      initPostulationBatchForm();
      initPostulationResultModal();
      document.addEventListener('DOMContentLoaded', initSummaryToggle);
      document.addEventListener('DOMContentLoaded', initPostulationBatchForm);
      document.addEventListener('DOMContentLoaded', initPostulationResultModal);
      document.addEventListener('astro:page-load', initSummaryToggle);
      document.addEventListener('astro:page-load', initPostulationBatchForm);
      document.addEventListener('astro:page-load', initPostulationResultModal);
    })();
  </script>
</BaseLayout>

