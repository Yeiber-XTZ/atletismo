---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar.astro';
import FooterKinetic from '../../components/FooterKinetic.astro';
import { getHomeData } from '../../lib/content';

const data = await getHomeData();
const { settings, blogPosts } = data;

const slug = Astro.params.slug ?? '';
const posts = Array.isArray(blogPosts) ? blogPosts : [];
const post = posts.find((p) => p.slug === slug);
if (!post) {
  Astro.response.status = 404;
}
---
<BaseLayout
  title={`${post ? post.title : 'Artículo no encontrado'} | Liga de Atletismo del Chocó`}
  description="Artículo del blog de la Liga de Atletismo del Chocó."
>
  <Navbar siteName={settings.siteName} logoUrl={settings.logoUrl || '/logo.png'} />

  <main class="pt-[80px] bg-gray-50">
    <section class="page-hero">
      <div class="container mx-auto px-6">
        <nav class="page-breadcrumb">
          <a href="/" class="page-breadcrumb-link">
            <span class="material-symbols-outlined text-sm">home</span>
            Inicio
          </a>
          <span class="material-symbols-outlined text-sm">chevron_right</span>
          <a href="/blog" class="page-breadcrumb-link">Blog</a>
          <span class="material-symbols-outlined text-sm">chevron_right</span>
          <span class="page-breadcrumb-current">{post ? post.title : 'No encontrado'}</span>
        </nav>
        <h1 class="page-title">{post ? post.title : 'Artículo no encontrado'}</h1>
        <p class="page-subtitle">{post ? post.excerpt : 'El artículo solicitado no existe o fue retirado.'}</p>
      </div>
    </section>

    <section class="page-section">
      <div class="container mx-auto px-6">
        {post ? (
          <article class="rounded-2xl border border-[var(--border)] bg-white p-8">
            {post.imageUrl ? (
              <div class="mb-8 overflow-hidden rounded-2xl ring-1 ring-slate-100">
                <img src={post.imageUrl} alt={post.title} class="w-full max-h-[420px] object-cover" referrerpolicy="no-referrer" />
              </div>
            ) : null}
            {post.videoUrl ? (
              <div class="mb-8 overflow-hidden rounded-2xl ring-1 ring-slate-100 bg-black">
                <video class="w-full max-h-[420px]" controls preload="metadata" src={post.videoUrl}>
                  Tu navegador no soporta video HTML5.
                </video>
              </div>
            ) : null}
            <div class="flex flex-wrap items-center gap-2 text-sm text-[var(--text-secondary)]">
              <span class="inline-flex items-center gap-2">
                <span class="material-symbols-outlined text-base">calendar_month</span>
                {post.date}
              </span>
              <span class="text-[var(--text-muted)]">·</span>
              <div class="flex flex-wrap gap-2">
                {post.tags.map((t) => (
                  <span class="rounded-full bg-[#f1f5f9] px-3 py-1 text-xs font-bold text-[#334155]">{t}</span>
                ))}
              </div>
            </div>
            <div class="mt-8 space-y-4 text-[var(--text-secondary)] leading-relaxed">
              {(Array.isArray(post.body) ? post.body : []).map((p) => (
                <p>{p}</p>
              ))}
            </div>
          </article>
        ) : (
          <div class="rounded-2xl border border-[var(--border)] bg-white p-8">
            <p class="text-[var(--text-secondary)]">Vuelve al blog para continuar.</p>
            <div class="mt-6">
              <a href="/blog" class="btn-primary">Ver blog</a>
            </div>
          </div>
        )}
      </div>
    </section>
  </main>

  <FooterKinetic siteName={settings.siteName} social={settings.social} />
</BaseLayout>
