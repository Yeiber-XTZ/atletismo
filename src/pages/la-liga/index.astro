---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar.astro';
import FooterKinetic from '../../components/FooterKinetic.astro';
import { getHomeData } from '../../lib/content';

const data = await getHomeData();
const { settings, federation, hero, publicSite } = data;
const laLigaContent = publicSite?.laLiga;
const pageHeroes = publicSite?.pageHeroes ?? {};

const heroImage =
  pageHeroes.laLiga ||
  hero?.imageUrl ||
  'https://images.unsplash.com/photo-1552674605-db6ffd4facb5?q=80&w=2070&auto=format&fit=crop';

const historyImage =
  laLigaContent?.historyImageUrl ||
  'https://images.unsplash.com/photo-1517649763962-0c623066013b?q=80&w=2070&auto=format&fit=crop';

const aboutParagraphs = (federation?.about ?? '')
  .split(/\n\s*\n/g)
  .map((p) => p.trim())
  .filter(Boolean);

const principles = laLigaContent?.principles ?? [];

const governanceItems = laLigaContent?.governanceItems ?? [];

const normativeDocs = laLigaContent?.normativeDocs ?? [];

const year = new Date().getFullYear();
---

<BaseLayout
  title={`La Liga | ${settings.siteName}`}
  description="Conoce la historia, misión, visión y estructura organizacional de la Liga de Atletismo del Chocó."
>
  <Navbar siteName={settings.siteName} logoUrl={settings.logoUrl || '/logo.png'} />

  <main class="pt-[80px]">
    <!-- HERO (replica del repo de referencia) -->
    <section class="relative flex min-h-[720px] items-center overflow-hidden bg-slate-950">
      <div class="absolute inset-0">
        <img
          alt="Atletas en competencia"
          class="h-full w-full object-cover"
          src={heroImage}
          referrerpolicy="no-referrer"
        />
      </div>

      <div class="relative z-10 mx-auto w-full max-w-7xl px-6 lg:px-8">
        <div class="max-w-4xl">
          <span class="inline-block -skew-x-12 bg-[#5AAC32] px-4 py-1 font-headline text-base font-black uppercase tracking-tight text-white">
            {hero?.badge || 'Impacto Pacífico'}
          </span>
          <h1 class="mt-6 font-headline text-5xl font-black uppercase italic tracking-tighter text-white sm:text-7xl lg:text-8xl leading-[0.9]">
            {laLigaContent?.heroTitle || 'La Liga'}
          </h1>
          <p class="mt-6 max-w-2xl text-lg font-medium leading-relaxed text-slate-200 sm:text-2xl">
            {laLigaContent?.heroSubtitle || 'Forjando campeones con pasión tropical desde el corazón del Pacífico colombiano.'}
          </p>

          <div class="mt-10 flex flex-wrap gap-4">
            <a
              class="bg-[#5AAC32] px-8 py-4 font-headline text-base font-black uppercase tracking-widest text-white transition hover:bg-[#4a9528] [clip-path:polygon(0_0,90%_0,100%_100%,10%_100%)]"
              href="#historia"
            >
              Explorar historia
            </a>
            <a
              class="bg-white/10 px-8 py-4 font-headline text-base font-black uppercase tracking-widest text-white backdrop-blur-md ring-1 ring-white/20 transition hover:bg-white/20 [clip-path:polygon(10%_0,100%_0,90%_100%,0%_100%)]"
              href="#organos"
            >
              Ver organigrama
            </a>
          </div>
        </div>
      </div>

      <div class="absolute bottom-10 right-10 hidden gap-4 lg:flex">
        <div class="border-l-4 border-[#5AAC32] bg-black/40 p-6 backdrop-blur-md">
          <span class="block font-headline text-3xl font-black text-[#5AAC32]">40+</span>
          <span class="text-xs font-bold uppercase tracking-widest text-white">Clubes afiliados</span>
        </div>
        <div class="border-l-4 border-[#eab308] bg-black/40 p-6 backdrop-blur-md">
          <span class="block font-headline text-3xl font-black text-[#eab308]">1.2k</span>
          <span class="text-xs font-bold uppercase tracking-widest text-white">Atletas activos</span>
        </div>
      </div>
    </section>

    <!-- HISTORIA -->
    <section id="historia" class="relative bg-white py-20 sm:py-24">
      <div class="mx-auto max-w-7xl px-6 lg:px-8">
        <div class="grid items-center gap-12 lg:grid-cols-2 lg:gap-16">
          <div class="relative">
            <h2 class="speed-line mb-10 font-headline text-4xl font-black uppercase italic tracking-tighter text-slate-900 sm:text-5xl">
              Nuestra historia
            </h2>

            <div class="space-y-6 text-base font-medium leading-relaxed text-slate-600 sm:text-lg">
              {aboutParagraphs.length ? (
                aboutParagraphs.map((p) => <p>{p}</p>)
              ) : (
                <>
                  <p>
                    Nacida bajo el sol ardiente del Chocó, nuestra liga no es solo una organización deportiva; es el latido de un pueblo que corre,
                    salta y lanza con la fuerza de la selva y el mar.
                  </p>
                  <p>
                    Desde nuestra fundación, hemos transformado la carencia en potencia, convirtiendo calles de tierra en pistas de oro y jóvenes
                    soñadores en referentes nacionales.
                  </p>
                </>
              )}
            </div>

            <div class="mt-10 flex items-center gap-5 rounded-r-lg border-l-4 border-[#5AAC32] bg-slate-50 p-7 transition hover:bg-slate-100">
              <div class="rounded-full bg-[#5AAC32]/10 p-4 text-[#5AAC32]">
                <span class="material-symbols-outlined text-3xl">trending_up</span>
              </div>
              <div>
                <h4 class="font-headline text-lg font-bold uppercase tracking-tight text-slate-900">Transformación continua</h4>
                <p class="text-sm text-slate-500">Décadas impulsando el futuro del atletismo del Pacífico.</p>
              </div>
            </div>
          </div>

          <div class="group relative">
            <div class="absolute inset-0 -skew-x-6 scale-105 bg-slate-100 transition-transform group-hover:scale-110"></div>
            <img
              alt="Atletismo Chocó"
              class="relative z-10 h-[460px] w-full object-cover [clip-path:polygon(0_0,100%_5%,100%_100%,0_95%)]"
              src={historyImage}
              referrerpolicy="no-referrer"
            />
          </div>
        </div>
      </div>
    </section>

    <!-- MISIÓN / VISIÓN -->
    <section id="mision-vision" class="relative overflow-hidden bg-slate-50 py-20 sm:py-24">
      <div class="relative z-10 mx-auto max-w-7xl px-6 lg:px-8">
        <div class="grid gap-6 md:grid-cols-2 md:gap-8">
          <div class="rounded-2xl border-t-4 border-[#5AAC32] bg-white p-10 shadow-sm transition hover:-translate-y-1 hover:shadow-xl sm:p-12">
            <span class="material-symbols-outlined mb-6 text-[44px] text-[#5AAC32]">target</span>
            <h3 class="mb-5 font-headline text-3xl font-black uppercase italic text-slate-900 sm:text-4xl">Misión</h3>
            <p class="text-lg leading-relaxed text-slate-600 sm:text-xl">
              {federation?.mission ||
                'Impulsar el desarrollo integral de los atletas en la región del Pacífico, con programas de formación técnica y valores que honren nuestra identidad.'}
            </p>
          </div>

          <div class="rounded-2xl border-t-4 border-[#4252b4] bg-white p-10 shadow-sm transition hover:-translate-y-1 hover:shadow-xl sm:p-12">
            <span class="material-symbols-outlined mb-6 text-[44px] text-[#4252b4]">visibility</span>
            <h3 class="mb-5 font-headline text-3xl font-black uppercase italic text-slate-900 sm:text-4xl">Visión</h3>
            <p class="text-lg leading-relaxed text-slate-600 sm:text-xl">
              {federation?.vision ||
                'Ser reconocidos para 2030 como un semillero de talentos, con un modelo de gestión sostenible, transparente e inclusivo.'}
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- PRINCIPIOS -->
    <section id="principios" class="bg-white py-20 sm:py-24">
      <div class="mx-auto max-w-7xl px-6 lg:px-8">
        <div class="mx-auto mb-12 max-w-3xl text-center sm:mb-16">
          <h2 class="mb-3 font-headline text-4xl font-black uppercase italic tracking-tighter text-slate-900 sm:text-5xl">
            Principios institucionales
          </h2>
          <p class="text-base text-slate-500 sm:text-lg">El ADN que guía cada decisión y competencia.</p>
        </div>

        <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
          {principles.map((p) => (
            <div class="group rounded-2xl border border-slate-100 p-8 transition hover:border-[#5AAC32]/30 hover:bg-slate-50 sm:p-10">
              <div class="mb-4 inline-flex rounded-2xl bg-[#5AAC32]/10 p-4 text-[#5AAC32] transition group-hover:scale-110">
                <span class="material-symbols-outlined text-[28px]">{p.icon}</span>
              </div>
              <h4 class="mb-2 font-headline text-xl font-bold uppercase text-slate-900 transition group-hover:text-[#5AAC32] sm:text-2xl">
                {p.title}
              </h4>
              <p class="text-sm text-slate-500 sm:text-base">{p.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ÓRGANOS -->
    <section id="organos" class="bg-slate-950 py-20 text-white sm:py-24">
      <div class="mx-auto max-w-7xl px-6 lg:px-8">
        <div class="mb-12 flex flex-col gap-6 md:mb-16 md:flex-row md:items-end md:justify-between">
          <div class="max-w-2xl">
            <h2 class="mb-3 font-headline text-4xl font-black uppercase italic tracking-tighter text-[#5AAC32] sm:text-5xl">
              Órganos de dirección
            </h2>
            <p class="text-base text-slate-300 sm:text-lg">Estructura administrativa que garantiza estabilidad y crecimiento institucional.</p>
          </div>
          <div class="hidden h-1 w-28 bg-[#5AAC32] md:block"></div>
        </div>

        <div class="grid gap-px border border-slate-800 bg-slate-800 md:grid-cols-2 lg:grid-cols-3">
          {governanceItems.map((it) => (
            <div class="cursor-default bg-slate-950 p-10 transition-colors hover:bg-slate-900 sm:p-12">
              <span class="mb-4 block font-headline text-xs font-black uppercase tracking-widest text-[#5AAC32] transition-transform hover:translate-x-2">
                {it.label}
              </span>
              <h4 class="font-headline text-xl font-bold uppercase sm:text-2xl">{it.title}</h4>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- MARCO NORMATIVO -->
    <section id="estatutos" class="bg-white py-20 sm:py-24">
      <div class="mx-auto max-w-7xl px-6 lg:px-8">
        <div class="grid gap-12 lg:grid-cols-3 lg:gap-16">
          <div>
            <h2 class="mb-6 font-headline text-4xl font-black uppercase italic tracking-tighter text-slate-900 sm:text-5xl leading-tight">
              Marco normativo
            </h2>
            <p class="mb-8 text-base leading-relaxed text-slate-500 sm:text-lg">
              Nuestros cimientos legales aseguran una operación profesional alineada con estándares deportivos nacionales e internacionales.
            </p>
            <div class="inline-flex items-center gap-3 rounded-lg border border-[#5AAC32]/20 bg-[#5AAC32]/5 p-4">
              <span class="material-symbols-outlined text-2xl text-[#5AAC32]">verified_user</span>
              <span class="font-headline text-xs font-black uppercase tracking-tight text-[#5AAC32]">Vigencia {year}-{year + 1}</span>
            </div>
          </div>

          <div class="space-y-4 lg:col-span-2">
            {normativeDocs.map((doc) => (
              <a
                class="group flex items-center justify-between rounded-2xl border border-slate-100 bg-slate-50 p-7 shadow-sm transition hover:border-[#5AAC32]/30 hover:bg-white hover:shadow-md sm:p-8"
                href={doc.href}
              >
                <div class="flex items-center gap-4 sm:gap-6">
                  <span class="material-symbols-outlined text-[34px] text-[#5AAC32]">{doc.icon}</span>
                  <h4 class="font-headline text-lg font-bold uppercase text-slate-900 sm:text-2xl">{doc.title}</h4>
                </div>
                <span class="material-symbols-outlined text-3xl text-slate-400 transition-colors group-hover:text-[#5AAC32]">
                  download
                </span>
              </a>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- TRANSPARENCIA -->
    <section id="transparencia" class="relative overflow-hidden bg-slate-50 py-20 sm:py-24">
      <div class="mx-auto max-w-7xl px-6 text-center lg:px-8">
        <span class="mb-4 block font-headline text-base font-black uppercase tracking-[0.3em] text-[#5AAC32] sm:text-xl">
          Buen gobierno
        </span>
        <h2 class="mx-auto mb-10 max-w-5xl font-headline text-4xl font-black uppercase italic leading-none text-slate-900 sm:text-5xl md:text-6xl lg:text-7xl">
          Transparencia y gestión de cara a la comunidad
        </h2>
        <div class="flex flex-wrap justify-center gap-4 sm:gap-6">
          <a
            class="bg-[#5AAC32] px-8 py-4 font-headline text-base font-black uppercase tracking-widest text-white transition hover:bg-[#4a9528] [clip-path:polygon(5%_0,100%_0,95%_100%,0%_100%)] sm:px-12 sm:py-5 sm:text-lg"
            href="/documentos"
          >
            Ver documentos públicos
          </a>
          <a
            class="bg-white px-8 py-4 font-headline text-base font-black uppercase tracking-widest text-[#5AAC32] ring-2 ring-[#5AAC32] transition hover:bg-[#5AAC32] hover:text-white [clip-path:polygon(0%_0,95%_0,100%_100%,5%_100%)] sm:px-12 sm:py-5 sm:text-lg"
            href="/contacto"
          >
            Solicitar información
          </a>
        </div>
      </div>
    </section>
  </main>

  <FooterKinetic siteName={settings.siteName} social={settings.social} />
</BaseLayout>

