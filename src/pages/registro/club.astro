---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar.astro';
import FooterKinetic from '../../components/FooterKinetic.astro';
import { getHomeData } from '../../lib/content';
import { listGeoCatalogs } from '../../lib/catalogs';

const data = await getHomeData();
const { settings } = data;
const geoCatalog = await listGeoCatalogs();
const geoCountries = geoCatalog.countries ?? [];
const geoDepartments = geoCatalog.departments ?? [];
const geoMunicipalities = geoCatalog.municipalities ?? [];
const success = Astro.url.searchParams.get('success');
const error = Astro.url.searchParams.get('error');
const radicado = Astro.url.searchParams.get('radicado');
const errorMessage = Astro.url.searchParams.get('message');
---
<BaseLayout title="Registro Club | Liga de Atletismo del Choco" description="Solicitud de afiliacion/registro de club ante la Liga.">
  <Navbar siteName={settings.siteName} logoUrl={settings.logoUrl || '/logo.png'} />

  <main class="pt-[72px]">
    <section class="page-hero">
      <div class="container mx-auto px-6">
        <nav class="page-breadcrumb">
          <a href="/" class="page-breadcrumb-link">
            <span class="material-symbols-outlined text-sm">home</span>
            Inicio
          </a>
          <span class="material-symbols-outlined text-sm">chevron_right</span>
          <a href="/registro" class="page-breadcrumb-link">Registro</a>
          <span class="material-symbols-outlined text-sm">chevron_right</span>
          <span class="page-breadcrumb-current">Club</span>
        </nav>
        <h1 class="page-title">Registro de Club</h1>
        <p class="page-subtitle">Radica tu solicitud. La Liga revisara documentos y notificara el estado de aprobacion.</p>
      </div>
    </section>

    <section class="page-section">
      <div class="container mx-auto px-6">
        <form method="POST" action="/api/registro" encType="multipart/form-data" class="rounded-2xl border border-[var(--border)] bg-white p-8">
          <input type="hidden" name="profile" value="club" />
          <div class="grid gap-5 md:grid-cols-2">
            <div class="md:col-span-2">
              <label class="form-label">Nombre legal del club *</label>
              <input class="form-input" type="text" name="name" required placeholder="Nombre del club" />
            </div>
            <div>
              <label class="form-label">Correo oficial del club *</label>
              <input class="form-input" type="email" name="email" required placeholder="club@correo.com" />
            </div>
            <div>
              <label class="form-label">Telefono *</label>
              <input class="form-input" type="tel" name="phone" required placeholder="+57 3xx xxx xxxx" pattern="^[0-9+() -]{7,20}$" inputmode="tel" />
            </div>
            <div>
              <label class="form-label">Pais *</label>
              <select class="form-input js-geo-country" name="countryIso2" required>
                <option value="">Selecciona pais</option>
                {geoCountries.map((country) => (
                  <option value={country.iso2} selected={country.iso2 === 'CO'}>{country.shortName}</option>
                ))}
              </select>
            </div>
            <div>
              <label class="form-label">Departamento *</label>
              <select class="form-input js-geo-department" name="departmentCode" required>
                <option value="">Selecciona departamento</option>
              </select>
            </div>
            <div>
              <label class="form-label">Municipio *</label>
              <select class="form-input js-geo-municipality" name="municipalityCode" required>
                <option value="">Selecciona municipio</option>
              </select>
              <input type="hidden" name="municipality" class="js-geo-municipality-name" />
            </div>
            <div>
              <label class="form-label">NIT (si aplica)</label>
              <input class="form-input" type="text" name="nit" placeholder="NIT" pattern="^[0-9-]{5,20}$" inputmode="numeric" />
            </div>
            <div class="md:col-span-2">
              <label class="form-label">Representante legal *</label>
              <input class="form-input" type="text" name="legalRepresentative" required placeholder="Nombre completo" />
            </div>
            <div class="md:col-span-2">
              <label class="form-label">Documento de reconocimiento deportivo (URL o referencia)</label>
              <input class="form-input" type="text" name="recognitionDoc" placeholder="URL / numero de resolucion / referencia" />
            </div>
            <div class="md:col-span-2">
              <label class="form-label">Logo (opcional)</label>
              <input class="form-input" type="file" name="logoFile" accept="image/*" />
            </div>
            <div class="md:col-span-2">
              <label class="form-label">Documentos anexos (lista/URLs)</label>
              <textarea class="form-input form-textarea" name="documents" placeholder="Estatutos, acta, certificados, etc."></textarea>
            </div>
            <div class="md:col-span-2">
              <label class="form-label">Contrasena *</label>
              <input class="form-input" type="password" name="password" required minlength="8" maxlength="200" placeholder="Minimo 8 caracteres" />
            </div>
          </div>

          <div class="mt-8 flex items-center justify-end">
            <button class="btn-primary" type="submit">
              <span class="material-symbols-outlined">send</span>
              Radicar solicitud
            </button>
          </div>
        </form>
      </div>
    </section>
  </main>

  <FooterKinetic siteName={settings.siteName} social={settings.social} />
  <div id="registroFlags" data-success={success ?? ''} data-error={error ?? ''} data-radicado={radicado ?? ''} data-error-message={errorMessage ?? ''} hidden></div>

  <dialog id="registroModal" class="rounded-xl p-0 w-[min(92vw,460px)] backdrop:bg-black/40">
    <div class="p-5 bg-white border border-gray-200 rounded-xl">
      <h3 id="registroModalTitle" class="text-lg font-bold text-on-surface">Registro</h3>
      <p id="registroModalMessage" class="mt-2 text-sm text-[var(--text-secondary)]"></p>
      <div class="mt-4 flex justify-end">
        <button id="registroModalClose" class="btn-primary" type="button">Entendido</button>
      </div>
    </div>
  </dialog>

  <script is:inline define:vars={{ geoDepartments, geoMunicipalities }}>
    const GEO_DEPARTMENTS = geoDepartments;
    const GEO_MUNICIPALITIES = geoMunicipalities;
    const modal = document.getElementById('registroModal');
    const modalTitle = document.getElementById('registroModalTitle');
    const modalMessage = document.getElementById('registroModalMessage');
    const closeBtn = document.getElementById('registroModalClose');
    const form = document.querySelector('form[action="/api/registro"]');

    const showModal = (title, message) => {
      modalTitle.textContent = title;
      modalMessage.textContent = message;
      if (modal && typeof modal.showModal === 'function') modal.showModal();
      else window.alert(`${title}: ${message}`);
    };

    closeBtn?.addEventListener('click', () => modal?.close());

    const getErrorNode = (input) => {
      if (!input) return null;
      let node = input.parentElement?.querySelector('[data-inline-error]');
      if (!node) {
        node = document.createElement('p');
        node.setAttribute('data-inline-error', '1');
        node.className = 'mt-1 text-xs text-red-600';
        input.parentElement?.appendChild(node);
      }
      return node;
    };

    const setFieldError = (input, message) => {
      const node = getErrorNode(input);
      if (!node) return;
      node.textContent = message;
      input.classList.add('border-red-400');
    };

    const clearFieldError = (input) => {
      const node = getErrorNode(input);
      if (node) node.textContent = '';
      input?.classList.remove('border-red-400');
    };

    const emailInput = form?.querySelector('input[name="email"]');
    const phoneInput = form?.querySelector('input[name="phone"]');
    const nitInput = form?.querySelector('input[name="nit"]');
    const passwordInput = form?.querySelector('input[name="password"]');
    const countrySelect = form?.querySelector('.js-geo-country');
    const departmentSelect = form?.querySelector('.js-geo-department');
    const municipalitySelect = form?.querySelector('.js-geo-municipality');
    const municipalityNameInput = form?.querySelector('.js-geo-municipality-name');

    const normalizeCode = (value) => String(value || '').trim().toUpperCase();
    const matchesCode = (left, right) => {
      const a = normalizeCode(left);
      const b = normalizeCode(right);
      if (!a || !b) return false;
      return a === b || a.startsWith(b) || b.startsWith(a);
    };

    const fillSelect = (selectEl, items, placeholder, selectedValue, valueKey, labelKey) => {
      if (!(selectEl instanceof HTMLSelectElement)) return;
      selectEl.innerHTML = '';
      const ph = document.createElement('option');
      ph.value = '';
      ph.textContent = placeholder;
      selectEl.appendChild(ph);
      items.forEach((item) => {
        const option = document.createElement('option');
        option.value = String(item?.[valueKey] ?? '');
        option.textContent = String(item?.[labelKey] ?? '');
        if (selectedValue && option.value === String(selectedValue)) option.selected = true;
        selectEl.appendChild(option);
      });
    };

    const syncMunicipalityName = () => {
      if (!(municipalitySelect instanceof HTMLSelectElement) || !(municipalityNameInput instanceof HTMLInputElement)) return;
      municipalityNameInput.value = municipalitySelect.value
        ? (municipalitySelect.options[municipalitySelect.selectedIndex]?.text || '')
        : '';
    };

    const initGeo = () => {
      if (!(countrySelect instanceof HTMLSelectElement) || !(departmentSelect instanceof HTMLSelectElement) || !(municipalitySelect instanceof HTMLSelectElement)) return;
      const countryCode = normalizeCode(countrySelect.value || 'CO');
      if (!countrySelect.value) countrySelect.value = countryCode;
      const deps = GEO_DEPARTMENTS.filter((item) => matchesCode(item.countryIso2, countryCode));
      fillSelect(departmentSelect, deps, 'Selecciona departamento', departmentSelect.value || '', 'code', 'name');
      const depCode = normalizeCode(departmentSelect.value || '');
      const muns = GEO_MUNICIPALITIES.filter((item) => matchesCode(item.departmentCode, depCode));
      fillSelect(municipalitySelect, muns, 'Selecciona municipio', municipalitySelect.value || '', 'code', 'name');
      syncMunicipalityName();
    };

    countrySelect?.addEventListener('change', () => {
      if (!(departmentSelect instanceof HTMLSelectElement) || !(municipalitySelect instanceof HTMLSelectElement)) return;
      const countryCode = normalizeCode(countrySelect.value || '');
      const deps = GEO_DEPARTMENTS.filter((item) => matchesCode(item.countryIso2, countryCode));
      fillSelect(departmentSelect, deps, 'Selecciona departamento', '', 'code', 'name');
      fillSelect(municipalitySelect, [], 'Selecciona municipio', '', 'code', 'name');
      syncMunicipalityName();
    });

    departmentSelect?.addEventListener('change', () => {
      if (!(departmentSelect instanceof HTMLSelectElement) || !(municipalitySelect instanceof HTMLSelectElement)) return;
      const depCode = normalizeCode(departmentSelect.value || '');
      const muns = GEO_MUNICIPALITIES.filter((item) => matchesCode(item.departmentCode, depCode));
      fillSelect(municipalitySelect, muns, 'Selecciona municipio', '', 'code', 'name');
      syncMunicipalityName();
    });

    municipalitySelect?.addEventListener('change', syncMunicipalityName);

    const validateEmail = () => {
      const value = (emailInput?.value || '').trim();
      if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(value)) {
        setFieldError(emailInput, 'Ingresa un correo valido (ejemplo@correo.com).');
        return false;
      }
      clearFieldError(emailInput);
      return true;
    };

    const validatePhone = () => {
      const value = (phoneInput?.value || '').trim();
      if (!/^[0-9+() -]{7,20}$/.test(value)) {
        setFieldError(phoneInput, 'El telefono solo puede tener numeros y simbolos validos (+ - ( )).');
        return false;
      }
      clearFieldError(phoneInput);
      return true;
    };

    const validateNit = () => {
      const value = (nitInput?.value || '').trim();
      if (value && !/^[0-9-]{5,20}$/.test(value)) {
        setFieldError(nitInput, 'El NIT solo puede contener numeros y guiones.');
        return false;
      }
      clearFieldError(nitInput);
      return true;
    };

    const validatePassword = () => {
      const value = passwordInput?.value || '';
      if (value.length < 8) {
        setFieldError(passwordInput, 'La contrasena debe tener al menos 8 caracteres.');
        return false;
      }
      clearFieldError(passwordInput);
      return true;
    };

    const validateGeo = () => {
      if (!(countrySelect instanceof HTMLSelectElement) || !(departmentSelect instanceof HTMLSelectElement) || !(municipalitySelect instanceof HTMLSelectElement)) return true;
      let valid = true;
      if (!countrySelect.value) {
        setFieldError(countrySelect, 'Selecciona un pais.');
        valid = false;
      } else clearFieldError(countrySelect);
      if (!departmentSelect.value) {
        setFieldError(departmentSelect, 'Selecciona un departamento.');
        valid = false;
      } else clearFieldError(departmentSelect);
      if (!municipalitySelect.value) {
        setFieldError(municipalitySelect, 'Selecciona un municipio.');
        valid = false;
      } else clearFieldError(municipalitySelect);
      syncMunicipalityName();
      return valid;
    };

    emailInput?.addEventListener('input', validateEmail);
    phoneInput?.addEventListener('input', validatePhone);
    nitInput?.addEventListener('input', validateNit);
    passwordInput?.addEventListener('input', validatePassword);
    countrySelect?.addEventListener('change', validateGeo);
    departmentSelect?.addEventListener('change', validateGeo);
    municipalitySelect?.addEventListener('change', validateGeo);

    form?.addEventListener('submit', (event) => {
      const isValid = [validateEmail(), validatePhone(), validateNit(), validatePassword(), validateGeo()].every(Boolean);
      if (!isValid) {
        event.preventDefault();
        showModal('Dato invalido', 'Corrige los campos marcados en rojo para continuar.');
      }
    });

    form?.addEventListener('invalid', (event) => {
      event.preventDefault();
      const target = event.target;
      const label = target?.closest('div')?.querySelector('label')?.textContent?.replace('*', '').trim() || 'campo';
      showModal('Dato invalido', `Revisa el campo "${label}" y vuelve a intentarlo.`);
    }, true);

    const flags = document.getElementById('registroFlags');
    const successValue = flags?.dataset?.success || '';
    const errorValue = flags?.dataset?.error || '';
    const radicadoValue = flags?.dataset?.radicado || '';
    const errorMessageValue = flags?.dataset?.errorMessage || '';

    if (successValue && radicadoValue) {
      showModal('Registro enviado', `Tu solicitud fue enviada correctamente. Radicado: ${radicadoValue}.`);
    } else if (errorValue) {
      showModal('No se pudo enviar', errorMessageValue || 'Revisa los datos del formulario e intentalo nuevamente.');
    }

    initGeo();
  </script>
</BaseLayout>
