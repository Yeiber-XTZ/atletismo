---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar.astro';
import FooterKinetic from '../../components/FooterKinetic.astro';
import { getHomeData } from '../../lib/content';
import { slugify } from '../../lib/slug';

const data = await getHomeData();
const { settings, competencias } = data;

const slug = Astro.params.slug ?? '';
const competencia = competencias.find((c) => slugify(c.title) === slug);
if (!competencia) {
  Astro.response.status = 404;
}
---
<BaseLayout
  title={`${competencia ? competencia.title : 'Competencia no encontrada'} | Liga de Atletismo del Chocó`}
  description="Ficha de competencia: fecha, sede, circular y manual técnico."
>
  <Navbar siteName={settings.siteName} logoUrl={settings.logoUrl || '/logo.png'} />

  <main class="pt-[72px]">
    <section class="page-hero">
      <div class="container mx-auto px-6">
        <nav class="page-breadcrumb">
          <a href="/" class="page-breadcrumb-link">
            <span class="material-symbols-outlined text-sm">home</span>
            Inicio
          </a>
          <span class="material-symbols-outlined text-sm">chevron_right</span>
          <a href="/competencias" class="page-breadcrumb-link">Competencias</a>
          <span class="material-symbols-outlined text-sm">chevron_right</span>
          <span class="page-breadcrumb-current">{competencia ? competencia.title : 'No encontrada'}</span>
        </nav>
        <h1 class="page-title">{competencia ? competencia.title : 'Competencia no encontrada'}</h1>
        <p class="page-subtitle">
          {competencia ? `${competencia.location} · ${competencia.date}` : 'La competencia solicitada no existe o fue retirada.'}
        </p>
      </div>
    </section>

    <section class="page-section">
      <div class="container mx-auto px-6">
        {competencia ? (
          <div class="grid gap-10 md:grid-cols-3">
            <div class="md:col-span-2">
              <h2 class="section-heading">Descripción</h2>
              <p class="text-[var(--text-secondary)] leading-relaxed">{competencia.description}</p>

              <h2 class="section-heading mt-10">Descargables</h2>
              <div class="grid gap-3">
                {competencia.downloads.map((d) => (
                  <a class="rounded-xl border border-[var(--border)] bg-white p-4 transition-colors hover:bg-[#f8fafc]" href={d.href} target="_blank" rel="noopener noreferrer">
                    <div class="flex items-center justify-between">
                      <div class="flex items-center gap-3">
                        <span class="material-symbols-outlined text-[var(--primary)]">description</span>
                        <span class="font-bold text-[var(--text-primary)]">{d.label}</span>
                      </div>
                      <span class="material-symbols-outlined text-[var(--text-muted)]">download</span>
                    </div>
                  </a>
                ))}
              </div>
            </div>
            <aside class="rounded-2xl border border-[var(--border)] bg-white p-6">
              <div class="text-xs font-bold uppercase tracking-wider text-[var(--tertiary)]">Estado</div>
              <div class="mt-2">
                <span class="rounded-full bg-[#f1f5f9] px-3 py-1 text-xs font-bold uppercase text-[#334155]">{competencia.status}</span>
              </div>
              <div class="mt-6 space-y-3 text-sm text-[var(--text-secondary)]">
                <div class="flex items-center gap-2">
                  <span class="material-symbols-outlined text-base">location_on</span>
                  <strong class="text-[#0f172a]">{competencia.location}</strong>
                </div>
                <div class="flex items-center gap-2">
                  <span class="material-symbols-outlined text-base">event</span>
                  <strong class="text-[#0f172a]">{competencia.date}</strong>
                </div>
              </div>
              <div class="mt-8 flex flex-col gap-3">
                <a href="/calendario" class="btn-primary">Ver calendario</a>
                <a href="/contacto" class="btn-secondary">Contactar</a>
              </div>
            </aside>
          </div>
        ) : (
          <div class="rounded-2xl border border-[var(--border)] bg-white p-8">
            <p class="text-[var(--text-secondary)]">Vuelve al listado para continuar.</p>
            <div class="mt-6">
              <a href="/competencias" class="btn-primary">Ver competencias</a>
            </div>
          </div>
        )}
      </div>
    </section>
  </main>

  <FooterKinetic siteName={settings.siteName} social={settings.social} />
</BaseLayout>
