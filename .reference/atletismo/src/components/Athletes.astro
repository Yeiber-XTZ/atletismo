---
---
<section class="py-24 px-8 md:px-24">
    <div class="flex flex-col items-center text-center mb-20">
        <h2 class="text-5xl font-headline font-black uppercase tracking-tighter italic">Nuestras Estrellas</h2>
        <div class="w-24 h-1.5 bg-[#fdd835] mt-4"></div>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
        <!-- Athlete Card 1 -->
        <div class="group relative">
            <div class="aspect-[3/4] overflow-hidden bg-[#acecbb] rounded-xl relative">
                <img 
                    class="w-full h-full object-cover transition-all duration-500 group-hover:scale-105 group-hover:grayscale-0 grayscale-[0.5]" 
                    src="https://images.unsplash.com/photo-1461896756984-8fd40bfb3202?q=80&w=2070&auto=format&fit=crop" 
                    alt="Mateo Córdoba"
                    referrerpolicy="no-referrer"
                />
                <div class="absolute inset-0 bg-gradient-to-t from-[#006b1b]/90 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
            </div>
            <div class="absolute -bottom-6 left-6 right-6 bg-white p-6 shadow-2xl transition-transform group-hover:-translate-y-4 rounded-xl">
                <span class="text-[#4252b4] font-bold text-[10px] uppercase tracking-widest">100M / 200M VELOCIDAD</span>
                <h3 class="text-2xl font-headline font-black uppercase tracking-tighter text-[#0b361d]">Mateo Córdoba</h3>
                <div class="mt-4 flex justify-between items-center">
                    <span class="text-[#006b1b] font-bold">10.02s PB</span>
                    <span class="material-symbols-outlined text-[#6c5a00]">military_tech</span>
                </div>
            </div>
        </div>
        <!-- Athlete Card 2 -->
        <div class="group relative mt-12 md:mt-0">
            <div class="aspect-[3/4] overflow-hidden bg-[#acecbb] rounded-xl relative">
                <img 
                    class="w-full h-full object-cover transition-all duration-500 group-hover:scale-105 group-hover:grayscale-0 grayscale-[0.5]" 
                    src="https://images.unsplash.com/photo-1486218119243-13883505764c?q=80&w=2072&auto=format&fit=crop" 
                    alt="Elena Rentería"
                    referrerpolicy="no-referrer"
                />
                <div class="absolute inset-0 bg-gradient-to-t from-[#006b1b]/90 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
            </div>
            <div class="absolute -bottom-6 left-6 right-6 bg-white p-6 shadow-2xl transition-transform group-hover:-translate-y-4 rounded-xl">
                <span class="text-[#4252b4] font-bold text-[10px] uppercase tracking-widest">VALLAS 110M</span>
                <h3 class="text-2xl font-headline font-black uppercase tracking-tighter text-[#0b361d]">Elena Rentería</h3>
                <div class="mt-4 flex justify-between items-center">
                    <span class="text-[#006b1b] font-bold">Campeona Jr</span>
                    <span class="material-symbols-outlined text-[#6c5a00]">star</span>
                </div>
            </div>
        </div>
        <!-- Athlete Card 3 -->
        <div class="group relative mt-12 md:mt-0">
            <div class="aspect-[3/4] overflow-hidden bg-[#acecbb] rounded-xl relative">
                <img 
                    class="w-full h-full object-cover transition-all duration-500 group-hover:scale-105 group-hover:grayscale-0 grayscale-[0.5]" 
                    src="https://images.unsplash.com/photo-1517649763962-0c623066013b?q=80&w=2070&auto=format&fit=crop" 
                    alt="Andrés Mena"
                    referrerpolicy="no-referrer"
                />
                <div class="absolute inset-0 bg-gradient-to-t from-[#006b1b]/90 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
            </div>
            <div class="absolute -bottom-6 left-6 right-6 bg-white p-6 shadow-2xl transition-transform group-hover:-translate-y-4 rounded-xl">
                <span class="text-[#4252b4] font-bold text-[10px] uppercase tracking-widest">SALTO LARGO / TRIPLE</span>
                <h3 class="text-2xl font-headline font-black uppercase tracking-tighter text-[#0b361d]">Andrés Mena</h3>
                <div class="mt-4 flex justify-between items-center">
                    <span class="text-[#006b1b] font-bold">8.15m PB</span>
                    <span class="material-symbols-outlined text-[#6c5a00]">emoji_events</span>
                </div>
            </div>
        </div>
    </div>
</section>
